---
import { ClientRouter } from "astro:transitions";
import { SITE } from "../data/services";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schemaType?: "WebSite" | "LocalBusiness" | "Service";
  schemaData?: Record<string, unknown>;
}

const {
  title = "Lumo Arte — Fabricación digital en Cancún | Corte láser, impresión 3D y gran formato",
  description = SITE.description,
  canonical,
  ogImage = SITE.ogDefault,
  schemaType,
  schemaData,
} = Astro.props;

const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}#business`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: `+${SITE.whatsapp}`,
  email: SITE.email,
  image: `${SITE.url}${SITE.ogDefault}`,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    addressCountry: SITE.address.country,
  },
  sameAs: [SITE.instagram],
  areaServed: {
    "@type": "City",
    name: "Cancún",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.url}#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  inLanguage: "es-MX",
  publisher: { "@id": `${SITE.url}#business` },
};

let injectedSchema: Record<string, unknown> | null = null;
if (schemaType === "LocalBusiness") injectedSchema = localBusinessSchema;
else if (schemaType === "WebSite") injectedSchema = websiteSchema;
else if (schemaType === "Service" && schemaData) {
  injectedSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    provider: { "@id": `${SITE.url}#business` },
    areaServed: { "@type": "City", name: "Cancún" },
    ...schemaData,
  };
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="theme-color" content="#A53A04" />
    <link rel="icon" type="image/png" href="/images/logo-nav.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    {injectedSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(injectedSchema)} />
    )}

    <ClientRouter />
  </head>
  <body>
    <slot />

    <script>
      import { initAll } from "../scripts/animations";
      initAll();
      document.addEventListener("astro:page-load", initAll);
    </script>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #ffffff;
    --color-bg-alt: #f5f4f2;
    --color-surface: #e8e6e3;
    --color-accent: #A53A04;
    --color-accent-dark: #7d2b02;
    --color-text: #1a1a1a;
    --color-muted: #666666;
    --color-dark: #0f0f0f;
    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", system-ui, sans-serif;
    --max-w: 1200px;
    --nav-h: 72px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--nav-h);
  }

  /* Hide reveal elements until JS animates them in */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    will-change: opacity, transform;
  }

  .materials-grid .material-card,
  .film-item {
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      transition-duration: 0.001ms !important;
    }
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    font-family: inherit;
    border: none;
    background: none;
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    line-height: 1.2;
    font-weight: 600;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: 120px 0;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.75;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.1s;
  }

  .btn:active {
    transform: scale(0.98);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-dark);
  }

  .btn-outline {
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
  }

  .btn-outline:hover {
    background: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 768px) {
    .section {
      padding: 80px 0;
    }

    .section-header {
      margin-bottom: 48px;
    }
  }
</style>
