---
import { ClientRouter } from "astro:transitions";
import { SITE } from "../data/services";
import PageTransition from "../components/PageTransition.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schemaType?: "WebSite" | "LocalBusiness" | "Service";
  schemaData?: Record<string, unknown>;
  pageAccent?: "laser" | "3d" | "plotter";
}

const {
  title = "Lumo Arte — Fabricación digital en Cancún | Corte láser, impresión 3D y gran formato",
  description = SITE.description,
  canonical,
  ogImage = SITE.ogDefault,
  schemaType,
  schemaData,
  pageAccent = "laser",
} = Astro.props;

const canonicalURL = new URL(canonical ?? Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}#business`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: `+${SITE.whatsapp}`,
  email: SITE.email,
  image: `${SITE.url}${SITE.ogDefault}`,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    addressCountry: SITE.address.country,
  },
  sameAs: [SITE.instagram],
  areaServed: {
    "@type": "City",
    name: "Cancún",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.url}#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  inLanguage: "es-MX",
  publisher: { "@id": `${SITE.url}#business` },
};

let injectedSchema: Record<string, unknown> | null = null;
if (schemaType === "LocalBusiness") injectedSchema = localBusinessSchema;
else if (schemaType === "WebSite") injectedSchema = websiteSchema;
else if (schemaType === "Service" && schemaData) {
  injectedSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    provider: { "@id": `${SITE.url}#business` },
    areaServed: { "@type": "City", name: "Cancún" },
    ...schemaData,
  };
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="theme-color" content="#A53A04" />
    <link rel="icon" type="image/png" href="/images/logo-nav.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    {injectedSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(injectedSchema)} />
    )}

    <ClientRouter />
  </head>
  <body data-page={pageAccent}>
    <slot />
    <PageTransition transition:persist />

    <script>
      import { initAll } from "../scripts/animations";
      initAll();
      document.addEventListener("astro:page-load", initAll);
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Surfaces — warm, no clinical white */
    --color-bg: #faf7f2;
    --color-bg-alt: #f0e7d8;
    --color-bg-tint: #ebd9bf;
    --color-bg-ink: #1a0f06;
    --color-bg-clay: #2a1605;
    --color-surface: #e0d5c2;

    /* Accents */
    --color-accent: #A53A04;
    --color-accent-dark: #7d2b02;
    --color-accent-honey: #c87a2a;
    --color-accent-rust: #6b2c0a;

    /* Per-service tints (hero bg + accents) */
    --service-laser: #A53A04;
    --service-3d: #c87a2a;
    --service-plotter: #6b2c0a;
    --service-laser-bg: #f4e3cf;
    --service-3d-bg: #f5e6c8;
    --service-plotter-bg: #ead9c2;

    /* Page-level accent — defaults to brand terracotta. Service pages override. */
    --page-accent: var(--color-accent);
    --page-accent-soft: rgba(165, 58, 4, 0.12);

    /* Text */
    --color-text: #1a1208;
    --color-text-on-dark: #f5e9d8;
    --color-muted: #7a6a55;
    --color-dark: #0f0f0f;

    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", system-ui, sans-serif;
    --max-w: 1200px;
    --nav-h: 72px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--nav-h);
  }

  /* Hide reveal elements until JS animates them in.
     Gated by .js class so no-JS / slow-JS / preview bots see content by default. */
  html.js [data-reveal],
  html.js .materials-grid .material-card,
  html.js .film-item {
    opacity: 0;
    transform: translateY(28px);
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      transition-duration: 0.001ms !important;
    }
    html.js [data-reveal],
    html.js .materials-grid .material-card,
    html.js .film-item {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background:
      radial-gradient(ellipse 60vw 80vh at 100% 0%, rgba(200, 122, 42, 0.06), transparent 60%),
      radial-gradient(ellipse 50vw 60vh at 0% 70%, rgba(165, 58, 4, 0.045), transparent 60%),
      var(--color-bg);
    background-attachment: fixed;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* Per-page accent overrides — service pages route their identity through cascading tokens */
  body[data-page="3d"] {
    --page-accent: var(--service-3d);
    --page-accent-soft: rgba(200, 122, 42, 0.14);
  }

  body[data-page="plotter"] {
    --page-accent: var(--service-plotter);
    --page-accent-soft: rgba(107, 44, 10, 0.14);
  }

  /* Section eyebrows + accent dashes pick up the per-page accent colour.
     Brand elements (logo, primary buttons, nav) keep their hardcoded terracotta. */
  .materials-eyebrow,
  .servicios-eyebrow,
  .sectores-eyebrow,
  .tech-eyebrow,
  .machines-eyebrow,
  .usos-eyebrow,
  .cross-eyebrow,
  .ig-eyebrow,
  .gallery-eyebrow,
  .gallery-empty-eyebrow,
  .specs-eyebrow,
  .faq-eyebrow,
  .form-eyebrow,
  .contact-eyebrow {
    color: var(--page-accent) !important;
  }

  body[data-page="3d"] .materials-eyebrow {
    color: var(--color-accent-honey) !important;
  }

  /* Dark "page end" — a shared anchor wrapping Contact + Footer so a
     single warm radial gradient spans both sections continuously. */
  .page-end {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-dark);
  }

  .page-end::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 45%
        at calc(82% + var(--glow-shift-x, 0%)) calc(15% + var(--glow-shift-y, 0%)),
      rgba(200, 122, 42, 0.22),
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
    transition: background 0.5s linear;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    font-family: inherit;
    border: none;
    background: none;
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    line-height: 1.2;
    font-weight: 600;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: 120px 0;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.75;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.1s;
  }

  .btn:active {
    transform: scale(0.98);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-dark);
  }

  .btn-outline {
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
  }

  .btn-outline:hover {
    background: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 768px) {
    .section {
      padding: 80px 0;
    }

    .section-header {
      margin-bottom: 48px;
    }
  }
</style>
