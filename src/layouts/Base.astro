---
import { ClientRouter } from "astro:transitions";
import { SITE, services } from "../data/services";
import PageTransition from "../components/PageTransition.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schemaType?: "WebSite" | "LocalBusiness" | "Service";
  schemaData?: Record<string, unknown>;
  /** Additional JSON-LD blocks injected alongside the sitewide Organization
   *  and the per-page schemaType. Use for Article, Person, Project, etc. */
  extraSchemas?: Record<string, unknown>[];
  pageAccent?: "laser" | "3d" | "plotter";
  /** Adds <meta name="robots" content="noindex,nofollow"> — for dormant EMD pages. */
  noindex?: boolean;
}

const {
  title = "Lumo Cancún — Fabricación digital en Cancún | Corte láser, impresión 3D y gran formato",
  description = SITE.description,
  canonical,
  ogImage = SITE.ogDefault,
  schemaType,
  schemaData,
  extraSchemas = [],
  pageAccent = "laser",
  noindex = false,
} = Astro.props;

// Normalise the canonical to a trailing slash so it matches the sitemap and the
// directory URLs Vercel actually serves. Mismatched slash vs no-slash was making
// GSC file the sitemap URLs as "Alternative page with proper canonical tag".
const _canonical = new URL(canonical ?? Astro.url.pathname, Astro.site);
if (!/\.[a-z0-9]+$/i.test(_canonical.pathname) && !_canonical.pathname.endsWith("/")) {
  _canonical.pathname += "/";
}
const canonicalURL = _canonical.href;
const ogImageURL = new URL(ogImage, Astro.site).href;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}#business`,
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  telephone: `+${SITE.phone}`,
  email: SITE.email,
  image: `${SITE.url}${SITE.ogDefault}`,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  sameAs: [SITE.instagram, SITE.gbp],
  geo: {
    "@type": "GeoCoordinates",
    latitude: SITE.geo.lat,
    longitude: SITE.geo.lng,
  },
  hasMap: SITE.gbp,
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: SITE.hours.days,
    opens: SITE.hours.opens,
    closes: SITE.hours.closes,
  },
  areaServed: {
    "@type": "City",
    name: "Cancún",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE.url}#website`,
  url: SITE.url,
  name: SITE.name,
  description: SITE.description,
  inLanguage: "es-MX",
  publisher: { "@id": `${SITE.url}#business` },
};

// Sitewide Organization + Person(founder) + OfferCatalog. Injected on every
// page so AI crawlers see the brand entity, its founder, and the full catalog
// of services regardless of which page they land on. Linked by @id to
// LocalBusiness so they form a single graph.
const founderSchema = {
  "@type": "Person",
  "@id": `${SITE.url}#founder`,
  name: "Adriano Abascal",
  jobTitle: "Arquitecto · Fundador",
  worksFor: { "@id": `${SITE.url}#organization` },
  affiliation: {
    "@type": "Organization",
    name: "Abascal Arquitectos",
    url: "https://abascalarquitectos.com/",
  },
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${SITE.url}#organization`,
  name: SITE.name,
  alternateName: "Lumo",
  url: SITE.url,
  logo: `${SITE.url}/images/logo-nav.png`,
  image: `${SITE.url}${SITE.ogDefault}`,
  description: SITE.description,
  email: SITE.email,
  telephone: `+${SITE.phone}`,
  sameAs: [SITE.instagram, SITE.gbp],
  founder: founderSchema,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.postalCode,
    addressCountry: SITE.address.country,
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Servicios de fabricación digital",
    // All four services are genuinely offered by the business and live under
    // /servicios/*. The `emdDomain` flag only changes where marketing links
    // point (dormant EMD strategy) — it must NOT prune the offer catalog, or
    // the two flagship services (corte láser, impresión 3D) vanish from the
    // brand's structured offering. Always list every service.
    itemListElement: services.map((s) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: s.name,
        description: s.metaDescription,
        url: `${SITE.url}${s.slug}`,
        provider: { "@id": `${SITE.url}#business` },
        areaServed: { "@type": "City", name: "Cancún" },
      },
    })),
  },
};

// Build the list of JSON-LD blocks to emit. Order: Organization (entity),
// per-page schema (LocalBusiness / WebSite / Service), then any extras
// passed by the page (Article, Person, Project, etc.).
const schemas: Record<string, unknown>[] = [organizationSchema];

if (schemaType === "LocalBusiness") schemas.push(localBusinessSchema);
else if (schemaType === "WebSite") schemas.push(websiteSchema);
else if (schemaType === "Service" && schemaData) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "Service",
    provider: { "@id": `${SITE.url}#business` },
    areaServed: { "@type": "City", name: "Cancún" },
    ...schemaData,
  });
}

schemas.push(...extraSchemas);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="theme-color" content="#A53A04" />
    <link rel="icon" type="image/png" href="/images/logo-nav.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500;1,600&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <ClientRouter />
  </head>
  <body data-page={pageAccent}>
    <slot />
    <PageTransition transition:persist />

    <script>
      import { initAll } from "../scripts/animations";
      initAll();
      document.addEventListener("astro:page-load", initAll);
    </script>

    <!-- Skeleton shimmer for images on slow networks / weak devices.
         Only images near the viewport get the shimmer (via IntersectionObserver),
         so a weak device never animates the whole gallery at once. -->
    <script is:inline>
      (function () {
        function activate(img) {
          if (img.dataset.skelOn) return;
          img.dataset.skelOn = "1";
          if (img.complete && img.naturalWidth > 0) {
            img.classList.add("lumo-skel", "is-loaded");
            return;
          }
          img.classList.add("lumo-skel");
          var done = function () { img.classList.add("is-loaded"); };
          img.addEventListener("load", done, { once: true });
          img.addEventListener("error", done, { once: true });
        }
        var io =
          "IntersectionObserver" in window
            ? new IntersectionObserver(
                function (entries) {
                  entries.forEach(function (e) {
                    if (e.isIntersecting) {
                      activate(e.target);
                      io.unobserve(e.target);
                    }
                  });
                },
                { rootMargin: "300px 0px" }
              )
            : null;
        function init() {
          var imgs = document.querySelectorAll("img");
          for (var i = 0; i < imgs.length; i++) {
            var img = imgs[i];
            if (img.dataset.skel) continue;
            img.dataset.skel = "1";
            if (io) io.observe(img);
            else activate(img);
          }
        }
        init();
        document.addEventListener("astro:page-load", init);
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Surfaces — warm, no clinical white */
    --color-bg: #faf7f2;
    --color-bg-alt: #f0e7d8;
    --color-bg-tint: #ebd9bf;
    --color-bg-ink: #1a0f06;
    --color-bg-clay: #2a1605;
    --color-surface: #e0d5c2;

    /* Accents */
    --color-accent: #A53A04;
    --color-accent-dark: #7d2b02;
    --color-accent-honey: #c87a2a;
    --color-accent-rust: #6b2c0a;

    /* Per-service tints (hero bg + accents) */
    --service-laser: #A53A04;
    --service-3d: #c87a2a;
    --service-plotter: #6b2c0a;
    --service-laser-bg: #f4e3cf;
    --service-3d-bg: #f5e6c8;
    --service-plotter-bg: #ead9c2;

    /* Page-level accent — defaults to brand terracotta. Service pages override. */
    --page-accent: var(--color-accent);
    --page-accent-soft: rgba(165, 58, 4, 0.12);

    /* Text */
    --color-text: #1a1208;
    --color-text-on-dark: #f5e9d8;
    --color-muted: #7a6a55;
    --color-dark: #0f0f0f;

    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", system-ui, sans-serif;
    --max-w: 1200px;
    --nav-h: 72px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--nav-h);
  }

  /* Hide reveal elements until JS animates them in.
     Gated by .js class so no-JS / slow-JS / preview bots see content by default. */
  html.js [data-reveal],
  html.js .materials-grid .material-card,
  html.js .film-item {
    opacity: 0;
    transform: translateY(28px);
    will-change: opacity, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      transition-duration: 0.001ms !important;
    }
    html.js [data-reveal],
    html.js .materials-grid .material-card,
    html.js .film-item {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background:
      radial-gradient(ellipse 60vw 80vh at 100% 0%, rgba(200, 122, 42, 0.06), transparent 60%),
      radial-gradient(ellipse 50vw 60vh at 0% 70%, rgba(165, 58, 4, 0.045), transparent 60%),
      var(--color-bg);
    background-attachment: fixed;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* Per-page accent overrides — service pages route their identity through cascading tokens */
  body[data-page="3d"] {
    --page-accent: var(--service-3d);
    --page-accent-soft: rgba(200, 122, 42, 0.14);
  }

  body[data-page="plotter"] {
    --page-accent: var(--service-plotter);
    --page-accent-soft: rgba(107, 44, 10, 0.14);
  }

  /* Section eyebrows + accent dashes pick up the per-page accent colour.
     Brand elements (logo, primary buttons, nav) keep their hardcoded terracotta. */
  .materials-eyebrow,
  .servicios-eyebrow,
  .sectores-eyebrow,
  .tech-eyebrow,
  .machines-eyebrow,
  .usos-eyebrow,
  .cross-eyebrow,
  .ig-eyebrow,
  .gallery-eyebrow,
  .gallery-empty-eyebrow,
  .specs-eyebrow,
  .faq-eyebrow,
  .form-eyebrow,
  .contact-eyebrow {
    color: var(--page-accent) !important;
  }

  body[data-page="3d"] .materials-eyebrow {
    color: var(--color-accent-honey) !important;
  }

  /* Dark "page end" — a shared anchor wrapping Contact + Footer so a
     single warm radial gradient spans both sections continuously. */
  .page-end {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-dark);
  }

  .page-end::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 45%
        at calc(82% + var(--glow-shift-x, 0%)) calc(15% + var(--glow-shift-y, 0%)),
      rgba(200, 122, 42, 0.22),
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
    transition: background 0.5s linear;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Visually hidden but readable by crawlers + screen readers.
     Used to expose clean heading text where the visible version is split
     into styled spans/lines (which naive text extractors glue together). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  button {
    cursor: pointer;
    font-family: inherit;
    border: none;
    background: none;
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    line-height: 1.2;
    font-weight: 600;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: 120px 0;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.75;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.1s;
  }

  .btn:active {
    transform: scale(0.98);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-dark);
  }

  .btn-outline {
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
  }

  .btn-outline:hover {
    background: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 768px) {
    .section {
      padding: 80px 0;
    }

    .section-header {
      margin-bottom: 48px;
    }
  }

  /* ── Image skeleton loaders ──────────────────────────────────────────
     A warm shimmer fills an image's reserved box (Astro <Image> already sets
     width/height, so there's no layout shift) until its load event fires.
     Tagged by the inline observer script near </body>. */
  @keyframes lumo-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  img.lumo-skel:not(.is-loaded) {
    background-color: var(--color-surface);
    background-image: linear-gradient(
      100deg,
      rgba(224, 213, 194, 0) 20%,
      rgba(255, 255, 255, 0.55) 45%,
      rgba(224, 213, 194, 0) 70%
    );
    background-size: 200% 100%;
    background-repeat: no-repeat;
    animation: lumo-shimmer 1.5s ease-in-out infinite;
    /* hide alt-text flash while the shimmer is showing */
    color: transparent;
    font-size: 0;
  }

  img.lumo-skel.is-loaded {
    background: none;
    animation: none;
  }

  @media (prefers-reduced-motion: reduce) {
    img.lumo-skel:not(.is-loaded) {
      animation: none;
    }
  }
</style>
