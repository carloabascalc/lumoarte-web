---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lumo Arte — Corte Láser Artesanal en Cancún",
  description = "Transformamos materiales en esculturas, estructuras, maquetas y objetos personalizados combinando tecnología de precisión con mano de obra artesanal.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/logo-nav.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #ffffff;
    --color-bg-alt: #f5f4f2;
    --color-surface: #e8e6e3;
    --color-accent: #A53A04;
    --color-accent-dark: #7d2b02;
    --color-text: #1a1a1a;
    --color-muted: #666666;
    --color-dark: #0f0f0f;
    --font-display: "Playfair Display", Georgia, serif;
    --font-body: "DM Sans", system-ui, sans-serif;
    --max-w: 1200px;
    --nav-h: 72px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    font-family: inherit;
    border: none;
    background: none;
  }

  h1, h2, h3 {
    font-family: var(--font-display);
    line-height: 1.2;
    font-weight: 600;
  }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: 120px 0;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 20px;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--color-muted);
    max-width: 560px;
    line-height: 1.75;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border-radius: 4px;
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-body);
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.1s;
  }

  .btn:active {
    transform: scale(0.98);
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-dark);
  }

  .btn-outline {
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
  }

  .btn-outline:hover {
    background: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 768px) {
    .section {
      padding: 80px 0;
    }

    .section-header {
      margin-bottom: 48px;
    }
  }
</style>
