---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { SITE } from "../data/services";

interface Props {
  title: string;
  description: string;
  slug: string;
  datePublished: string; // ISO date
  dateModified?: string;
  readingTime?: string; // e.g. "6 min"
  topic?: string; // e.g. "Corte láser"
  ogImage?: string;
}

const {
  title,
  description,
  slug,
  datePublished,
  dateModified = datePublished,
  readingTime,
  topic,
  ogImage = "/og/default.jpg",
} = Astro.props;

const canonical = `/recursos/${slug}`;
const url = `${SITE.url}${canonical}`;

// Freshness signal: only surface "Actualizado" when the guide was genuinely
// revised after publishing (dateModified defaults to datePublished).
const wasUpdated = dateModified && dateModified !== datePublished;
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("es-MX", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  url,
  image: `${SITE.url}${ogImage}`,
  datePublished,
  dateModified,
  author: { "@id": `${SITE.url}#founder` },
  publisher: { "@id": `${SITE.url}#organization` },
  mainEntityOfPage: { "@type": "WebPage", "@id": url },
  inLanguage: "es-MX",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".article-title", ".article-body p:first-child"],
  },
  ...(topic ? { about: topic } : {}),
};
---

<Base
  title={`${title} — Recursos | Lumo Cancún`}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  extraSchemas={[articleSchema]}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Recursos", href: "/recursos" },
        { label: title },
      ]}
    />

    <article class="article-page">
      <header class="article-header container">
        {topic && <p class="article-eyebrow" data-reveal>{topic}</p>}
        <h1 class="article-title" data-reveal data-reveal-delay="0.06">
          {title}
        </h1>
        <p class="article-meta" data-reveal data-reveal-delay="0.12">
          Por <a href="/sobre-nosotros">Adriano Abascal</a>
          <span aria-hidden="true">·</span>
          <time datetime={datePublished}>{fmtDate(datePublished)}</time>
          {readingTime && (
            <>
              <span aria-hidden="true">·</span>
              <span>{readingTime} de lectura</span>
            </>
          )}
          {wasUpdated && (
            <>
              <span aria-hidden="true">·</span>
              <span class="article-updated">
                Actualizado: <time datetime={dateModified}>{fmtDate(dateModified)}</time>
              </span>
            </>
          )}
        </p>
      </header>

      <div class="article-body container">
        <slot />
      </div>

      <aside class="author-box container" aria-label="Sobre el autor">
        {/* Monograma de marca como avatar. Cuando Adriano envíe una foto suya,
            reemplaza este <div> por un <img src="/images/adriano-abascal.jpg" ...>
            y añade `image` al founderSchema en Base.astro. */}
        <div class="author-avatar" aria-hidden="true">AA</div>
        <div class="author-info">
          <p class="author-name">Adriano Abascal</p>
          <p class="author-role">Arquitecto y fundador de Lumo Cancún</p>
          <p class="author-bio">
            Arquitecto cancunense. Dirige el taller donde su práctica profesional
            se encuentra con la fabricación digital: corte láser, impresión 3D y
            gran formato. Estas guías salen del trabajo diario en el taller.
          </p>
          <a class="author-link" href="/sobre-nosotros">Conoce a Lumo Cancún →</a>
        </div>
      </aside>

      <footer class="article-footer container">
        <p class="article-cta-eyebrow">¿Listo para tu proyecto?</p>
        <a href={`https://wa.me/${SITE.whatsapp}`} class="btn btn-primary">
          Cotiza por WhatsApp
        </a>
      </footer>
    </article>
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  .article-page {
    padding-bottom: 80px;
  }

  .article-header {
    padding: 32px 24px 40px;
    max-width: 820px;
    margin: 0 auto;
  }

  .article-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin-bottom: 22px;
  }

  .article-meta {
    font-size: 0.9375rem;
    color: var(--color-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .article-meta a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body {
    max-width: 760px;
    margin: 0 auto;
    padding: 16px 24px 40px;
  }

  .article-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 56px;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .article-body :global(h2:first-child) {
    margin-top: 0;
  }

  .article-body :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 32px;
    margin-bottom: 10px;
  }

  .article-body :global(p) {
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--color-text);
    margin-bottom: 18px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 18px 1.5rem;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-body :global(li) {
    margin-bottom: 6px;
  }

  .article-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0 24px;
    font-size: 0.9375rem;
  }

  .article-body :global(th),
  .article-body :global(td) {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--color-surface);
    vertical-align: top;
  }

  .article-body :global(th) {
    font-weight: 600;
    background: var(--color-bg-alt);
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding: 6px 0 6px 20px;
    margin: 18px 0;
    color: var(--color-muted);
    font-style: italic;
  }

  /* Methodology / source note — frames quantitative claims as first-party
     shop data (E-E-A-T) and flags general material specs as manufacturer
     typicals. Understated card so it reads as a footnote, not a CTA. */
  .article-body :global(.source-note) {
    margin: 40px 0 8px;
    padding: 18px 20px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-left: 3px solid var(--color-accent);
    border-radius: 6px;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .article-body :global(.source-note strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .article-updated {
    color: var(--color-muted);
  }

  /* Author box — Experience/Expertise signal (E-E-A-T): puts a real, named,
     credentialed author at the foot of every guide, linked to the About page. */
  .author-box {
    max-width: 760px;
    margin: 24px auto 0;
    padding: 24px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-radius: 10px;
  }

  .author-avatar {
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
  }

  .author-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: 1.0625rem;
  }

  .author-role {
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .author-bio {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: 10px;
  }

  .author-link {
    color: var(--color-text);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 540px) {
    .author-box {
      flex-direction: column;
      gap: 14px;
    }
  }

  .article-footer {
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px;
    border-top: 1px solid var(--color-surface);
    text-align: center;
  }

  .article-cta-eyebrow {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 14px;
  }
</style>
