---
import { Image } from "astro:assets";
import imgMain from "../assets/gallery/gal-01.jpg";
import imgBack from "../assets/gallery/gal-04.jpg";
import imgFront from "../assets/gallery/gal-08.jpg";
import imgSide from "../assets/gallery/gal-07.jpg";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="hero-pill" data-reveal>
        <span class="hero-pill-dot" aria-hidden="true"></span>
        Especialistas en corte láser · Cancún
      </p>

      <h1 class="hero-title" data-reveal data-reveal-delay="0.06">
        De la idea<br />al <em>objeto</em>
      </h1>

      <p class="hero-sub" data-reveal data-reveal-delay="0.12">
        Corte láser, impresión 3D e impresión gran formato bajo un mismo techo.
        Manufactura creativa en Cancún.
      </p>

      <div class="hero-ctas" data-reveal data-reveal-delay="0.18">
        <a href="#cotiza" class="btn btn-primary hero-cta">Solicita tu cotización</a>
        <a href="#servicios" class="hero-cta-text">
          Ver servicios
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <p class="hero-proof" data-reveal data-reveal-delay="0.24">
        <span class="hero-proof-stars" aria-hidden="true">★★★★★</span>
        <strong>+200 proyectos</strong> entregados desde Cancún
      </p>
    </div>

    <div class="hero-stack" data-reveal data-reveal-delay="0.10">
      <div class="hero-card hero-card--back">
        <Image src={imgBack} alt="Lámpara trébol cuatro corazones" widths={[400, 600]} sizes="380px" quality={80} loading="eager" decoding="async" class="hero-img" />
      </div>
      <div class="hero-card hero-card--side">
        <Image src={imgSide} alt="Cajones apilados con ensamble dovetail" widths={[400, 600]} sizes="380px" quality={80} loading="eager" decoding="async" class="hero-img" />
      </div>
      <div class="hero-card hero-card--main">
        <Image src={imgMain} alt="Lámparas corazón apiladas en MDF" widths={[600, 900]} sizes="500px" quality={82} loading="eager" decoding="async" fetchpriority="high" class="hero-img" />
      </div>
      <div class="hero-card hero-card--front">
        <Image src={imgFront} alt="Caja corazón con rosas y chocolates" widths={[400, 600]} sizes="380px" quality={80} loading="eager" decoding="async" class="hero-img" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    padding: calc(var(--nav-h) + 32px) 0 80px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse 90% 65% at 100% -10%, rgba(200, 122, 42, 0.34), transparent 55%),
      radial-gradient(ellipse 60% 80% at -10% 110%, rgba(165, 58, 4, 0.22), transparent 60%),
      radial-gradient(ellipse 40% 40% at 30% 25%, rgba(245, 220, 180, 0.6), transparent 70%),
      linear-gradient(180deg, #f3e7d3 0%, var(--color-bg) 65%);
  }

  /* Wood grain — horizontally stretched fractal turbulence creates flowing
     organic lines that feel like the surface of a cut wood plank. */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='600' height='600'><filter id='w'><feTurbulence type='turbulence' baseFrequency='0.012 0.6' numOctaves='3' seed='4' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.36  0 0 0 0 0.18  0 0 0 0 0.04  0 0 0 0.7 0'/></filter><rect width='100%' height='100%' filter='url(%23w)'/></svg>");
    background-size: 600px 600px;
    pointer-events: none;
    mix-blend-mode: multiply;
    opacity: 0.32;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, transparent 30%, rgba(74, 38, 8, 0.08) 95%),
      linear-gradient(to bottom, transparent 75%, var(--color-bg));
    pointer-events: none;
    z-index: 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Left: text ────────────────────────────────────── */
  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 16px;
    border: 1px solid rgba(165, 58, 4, 0.18);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(6px);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 28px;
  }

  .hero-pill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(165, 58, 4, 0.16);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6.4vw, 5.25rem);
    font-weight: 500;
    line-height: 1.04;
    color: var(--color-text);
    letter-spacing: -0.018em;
    margin-bottom: 28px;
  }

  .hero-title em {
    font-style: italic;
  }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 520px;
    margin-bottom: 40px;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .hero-cta {
    font-size: 0.95rem;
    padding: 14px 28px;
  }

  .hero-cta-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    color: var(--color-text);
    font-weight: 500;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .hero-cta-text:hover {
    gap: 12px;
    color: var(--color-accent);
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid var(--color-surface);
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .hero-proof strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .hero-proof-stars {
    color: var(--color-accent-honey);
    letter-spacing: 0.05em;
    font-size: 0.875rem;
  }

  /* ── Right: photo stack ────────────────────────────── */
  .hero-stack {
    position: relative;
    aspect-ratio: 1/1;
    max-width: 540px;
    justify-self: end;
    width: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-bg-alt);
    box-shadow:
      0 24px 56px rgba(20, 10, 4, 0.20),
      0 0 0 1px rgba(165, 58, 4, 0.06);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-card--main {
    width: 70%;
    aspect-ratio: 4/5;
    top: 12%;
    left: 14%;
    z-index: 3;
    transform: rotate(-2deg);
  }

  .hero-card--back {
    width: 52%;
    aspect-ratio: 1/1;
    top: 0;
    right: 4%;
    z-index: 1;
    transform: rotate(7deg);
    opacity: 0.95;
  }

  .hero-card--side {
    width: 46%;
    aspect-ratio: 4/5;
    top: 36%;
    right: 0;
    z-index: 2;
    transform: rotate(4deg);
  }

  .hero-card--front {
    width: 50%;
    aspect-ratio: 1/1;
    bottom: 4%;
    left: 0;
    z-index: 4;
    transform: rotate(-6deg);
  }

  .hero-stack:hover .hero-card--main { transform: rotate(-1deg) translateY(-4px); }
  .hero-stack:hover .hero-card--back { transform: rotate(8deg) translateX(4px); }
  .hero-stack:hover .hero-card--side { transform: rotate(5deg) translateX(6px); }
  .hero-stack:hover .hero-card--front { transform: rotate(-7deg) translate(-4px, 4px); }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero-stack {
      max-width: 420px;
      justify-self: center;
    }
  }

  @media (max-width: 540px) {
    .hero {
      padding: calc(var(--nav-h) + 16px) 0 56px;
    }

    .hero-stack {
      max-width: 320px;
    }
  }
</style>
