---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Pull all gallery photos for the marquee — they form the visual proof of work.
const galleryFiles = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/gal-*.jpg",
  { eager: true },
);

const marqueeImages = Object.entries(galleryFiles)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([_, mod]) => mod.default);

// Split images into two rows so each row carries its own slice of the work.
const rowA = marqueeImages.filter((_, i) => i % 2 === 0);
const rowB = marqueeImages.filter((_, i) => i % 2 === 1);

// Variable sizing pattern — tighter range so the rows feel curated, not chaotic.
const sizes = [
  { w: 220, h: 220 },
  { w: 260, h: 180 },
  { w: 200, h: 240 },
  { w: 240, h: 200 },
  { w: 220, h: 240 },
  { w: 240, h: 200 },
  { w: 200, h: 220 },
];
const sizeFor = (i: number) => sizes[i % sizes.length];
---

<section class="hero">
  {/* Atelier mark — top-right signature plaque */}
  <div class="hero-stamp" aria-hidden="true">
    <span class="hero-stamp-mark">lm</span>
    <span class="hero-stamp-meta">
      <span>Lumo Arte</span>
      <span>Atelier · Cancún</span>
    </span>
  </div>

  <div class="container hero-content">
    <p class="hero-kicker" data-reveal>
      <span class="hero-kicker-line" aria-hidden="true"></span>
      Fabricación digital · Cancún
    </p>

    <h1 class="hero-title" data-reveal data-reveal-delay="0.06">
      <span class="title-line title-line--top">De la idea</span>
      <span class="title-line title-line--bottom">al <em class="title-em">objeto.</em></span>
    </h1>

    <p class="hero-sub" data-reveal data-reveal-delay="0.12">
      Corte láser, impresión 3D e impresión de gran formato bajo un mismo techo.
      Manufactura creativa para arquitectos, diseñadores, agencias y eventos.
    </p>

    <div class="hero-ctas" data-reveal data-reveal-delay="0.18">
      <a href="#cotiza" class="btn btn-primary hero-cta">Solicita tu cotización</a>
      <a href="#servicios" class="hero-cta-text">
        Ver servicios
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <p class="hero-proof" data-reveal data-reveal-delay="0.24">
      <span class="hero-proof-stars" aria-hidden="true">★★★★★</span>
      <strong><span data-count="200" data-prefix="+">+0</span> proyectos</strong> entregados desde Cancún
    </p>
  </div>

  {/* Marquee — two rows, opposite directions, variable sizes */}
  <div class="hero-marquee" aria-hidden="true" data-reveal data-reveal-delay="0.30">
    <div class="marquee-row marquee-row--top">
      <div class="marquee-track marquee-track--ltr">
        {rowA.map((src, i) => {
          const s = sizeFor(i);
          return (
            <figure
              class="marquee-item"
              style={`width: ${s.w}px; height: ${s.h}px;`}
            >
              <Image
                src={src}
                alt=""
                widths={[280, 420]}
                sizes="240px"
                quality={75}
                loading={i < 3 ? "eager" : "lazy"}
                decoding="async"
                class="marquee-img"
              />
            </figure>
          );
        })}
        {rowA.map((src, i) => {
          const s = sizeFor(i);
          return (
            <figure
              class="marquee-item"
              style={`width: ${s.w}px; height: ${s.h}px;`}
              aria-hidden="true"
            >
              <Image
                src={src}
                alt=""
                widths={[280, 420]}
                sizes="240px"
                quality={75}
                loading="lazy"
                decoding="async"
                class="marquee-img"
              />
            </figure>
          );
        })}
      </div>
    </div>

    <div class="marquee-row marquee-row--bottom">
      <div class="marquee-track marquee-track--rtl">
        {rowB.map((src, i) => {
          const s = sizeFor(i + 3);
          return (
            <figure
              class="marquee-item"
              style={`width: ${s.w}px; height: ${s.h}px;`}
            >
              <Image
                src={src}
                alt=""
                widths={[280, 420]}
                sizes="240px"
                quality={75}
                loading="lazy"
                decoding="async"
                class="marquee-img"
              />
            </figure>
          );
        })}
        {rowB.map((src, i) => {
          const s = sizeFor(i + 3);
          return (
            <figure
              class="marquee-item"
              style={`width: ${s.w}px; height: ${s.h}px;`}
              aria-hidden="true"
            >
              <Image
                src={src}
                alt=""
                widths={[280, 420]}
                sizes="240px"
                quality={75}
                loading="lazy"
                decoding="async"
                class="marquee-img"
              />
            </figure>
          );
        })}
      </div>
    </div>
  </div>

  <a href="#servicios" class="hero-scroll" aria-label="Bajar a servicios">
    <span class="hero-scroll-label">Scroll</span>
    <span class="hero-scroll-line" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding-top: var(--nav-h);
    background:
      radial-gradient(ellipse 90% 65% at 100% -10%, rgba(200, 122, 42, 0.34), transparent 55%),
      radial-gradient(ellipse 60% 80% at -10% 110%, rgba(165, 58, 4, 0.22), transparent 60%),
      radial-gradient(ellipse 40% 40% at 30% 25%, rgba(245, 220, 180, 0.6), transparent 70%),
      linear-gradient(180deg, #f3e7d3 0%, var(--color-bg) 65%);
  }

  /* Wood grain texture overlay */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='600' height='600'><filter id='w'><feTurbulence type='turbulence' baseFrequency='0.012 0.6' numOctaves='3' seed='4' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.36  0 0 0 0 0.18  0 0 0 0 0.04  0 0 0 0.7 0'/></filter><rect width='100%' height='100%' filter='url(%23w)'/></svg>");
    background-size: 600px 600px;
    pointer-events: none;
    mix-blend-mode: multiply;
    opacity: 0.28;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, transparent 30%, rgba(74, 38, 8, 0.08) 95%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Atelier signature stamp (top-right, decorative) ─── */
  .hero-stamp {
    position: absolute;
    top: calc(var(--nav-h) + 20px);
    right: 32px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 14px 8px 10px;
    border: 1px solid rgba(165, 58, 4, 0.22);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    pointer-events: none;
  }

  .hero-stamp-mark {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-accent);
    letter-spacing: -0.04em;
  }

  .hero-stamp-meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(20, 10, 4, 0.7);
    line-height: 1.3;
  }

  .hero-stamp-meta span:last-child {
    color: rgba(20, 10, 4, 0.45);
    font-weight: 500;
  }

  /* ── Content (top, centered) ───────────────────────── */
  .hero-content {
    position: relative;
    z-index: 1;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 56px 24px 40px;
    max-width: 1080px;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 24px;
  }

  .hero-kicker-line {
    display: inline-block;
    width: 36px;
    height: 1.5px;
    background: currentColor;
    flex-shrink: 0;
  }

  /* Massive editorial type — the headline IS the visual */
  .hero-title {
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 0.94;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0 0 28px;
  }

  .title-line {
    display: block;
  }

  .title-line--top {
    font-size: clamp(3rem, 9vw, 8rem);
  }

  .title-line--bottom {
    font-size: clamp(3.5rem, 10.5vw, 9.5rem);
    margin-top: -0.04em;
  }

  .title-em {
    font-style: italic;
    color: var(--color-accent);
    position: relative;
    display: inline-block;
  }

  /* Subtle accent dot after objeto. */
  .title-em::after {
    content: "";
    position: absolute;
    bottom: 0.18em;
    right: -0.12em;
    width: 0.18em;
    height: 0.18em;
    background: var(--color-accent);
    border-radius: 50%;
    transform: scale(0.5);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    line-height: 1.65;
    color: var(--color-muted);
    max-width: 580px;
    margin: 0 0 32px;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .hero-cta {
    font-size: 0.9375rem;
    padding: 14px 28px;
  }

  .hero-cta-text {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    color: var(--color-text);
    font-weight: 500;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .hero-cta-text:hover {
    gap: 12px;
    color: var(--color-accent);
  }

  .hero-proof {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0 0;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .hero-proof strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .hero-proof strong [data-count] {
    font-variant-numeric: tabular-nums;
    display: inline-block;
    min-width: 2ch;
  }

  .hero-proof-stars {
    color: var(--color-accent-honey);
    letter-spacing: 0.05em;
    font-size: 0.875rem;
  }

  /* ── Marquee — two rows, opposite directions ───────── */
  .hero-marquee {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    padding: 16px 0 28px;
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 5%, #000 95%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0, #000 5%, #000 95%, transparent 100%);
  }

  .marquee-row {
    overflow: hidden;
  }

  .marquee-row--top {
    margin-bottom: 12px;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 14px;
    width: max-content;
    will-change: transform;
  }

  .marquee-track--ltr {
    animation: marquee-ltr 95s linear infinite;
  }

  .marquee-track--rtl {
    animation: marquee-rtl 80s linear infinite;
  }

  @keyframes marquee-ltr {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes marquee-rtl {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .marquee-item {
    flex: 0 0 auto;
    border-radius: 10px;
    overflow: hidden;
    margin: 0;
    background: var(--color-bg-alt);
    box-shadow:
      0 14px 32px rgba(20, 10, 4, 0.14),
      0 0 0 1px rgba(165, 58, 4, 0.05);
  }

  /* Subtle alternating tilt for editorial gallery-wall feel */
  .marquee-track--ltr .marquee-item:nth-child(odd)  { transform: rotate(-0.8deg) translateY(-4px); }
  .marquee-track--ltr .marquee-item:nth-child(even) { transform: rotate(0.6deg)  translateY(3px); }
  .marquee-track--rtl .marquee-item:nth-child(odd)  { transform: rotate(0.7deg)  translateY(3px); }
  .marquee-track--rtl .marquee-item:nth-child(even) { transform: rotate(-0.5deg) translateY(-4px); }

  .marquee-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Pause on hover so users can read the photos */
  .hero-marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  /* ── Scroll indicator (bottom-center) ───────────────── */
  .hero-scroll {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--color-muted);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    z-index: 3;
    transition: color 0.2s ease;
    opacity: 0.55;
  }

  .hero-scroll:hover { color: var(--color-accent); opacity: 1; }

  .hero-scroll-line {
    position: relative;
    width: 1px;
    height: 28px;
    background: rgba(165, 58, 4, 0.18);
    overflow: hidden;
  }

  .hero-scroll-line::before {
    content: "";
    position: absolute;
    top: -28px;
    left: 0;
    width: 100%;
    height: 28px;
    background: linear-gradient(to bottom, transparent, var(--color-accent));
    animation: heroScrollLine 2.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }

  @keyframes heroScrollLine {
    0%   { transform: translateY(0); }
    100% { transform: translateY(56px); }
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 768px) {
    .hero-stamp {
      top: calc(var(--nav-h) + 12px);
      right: 16px;
      padding: 6px 10px 6px 8px;
      gap: 8px;
    }
    .hero-stamp-mark { font-size: 1.15rem; }
    .hero-stamp-meta { font-size: 0.55rem; letter-spacing: 0.14em; }

    .hero-content {
      padding: 48px 20px 28px;
    }

    .hero-kicker {
      font-size: 0.66rem;
      letter-spacing: 0.18em;
      gap: 10px;
      margin-bottom: 20px;
    }

    .hero-kicker-line { width: 24px; }

    .hero-sub {
      font-size: 0.95rem;
      margin-bottom: 24px;
    }

    .hero-ctas { gap: 20px; margin-bottom: 22px; }

    .marquee-item {
      /* Scale items smaller on mobile via transform */
      transform: scale(0.7);
      transform-origin: center;
    }

    .marquee-row--top { margin-bottom: 4px; }

    .hero-marquee { padding: 16px 0 32px; }

    .hero-scroll { display: none; }
  }

  @media (max-width: 540px) {
    .hero-stamp {
      gap: 6px;
      padding: 5px 8px 5px 6px;
    }
    .hero-stamp-mark { font-size: 1rem; }
    .hero-stamp-meta { font-size: 0.5rem; }

    .hero-content { padding: 40px 16px 20px; }

    .marquee-item {
      transform: scale(0.55);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track--ltr,
    .marquee-track--rtl { animation: none; }
    .hero-scroll-line::before { animation: none; }
  }
</style>

<script>
  function initCounter() {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = document.querySelectorAll<HTMLElement>('.hero [data-count]');
    if (!els.length) return;

    const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);

    function run(el: HTMLElement) {
      const target = parseInt(el.dataset.count || '0', 10);
      const prefix = el.dataset.prefix || '';
      const suffix = el.dataset.suffix || '';

      if (reduced) {
        el.textContent = `${prefix}${target}${suffix}`;
        return;
      }

      const duration = Math.max(600, Math.min(1800, target * 6));
      const start = performance.now();
      function tick(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const value = Math.floor(easeOutCubic(t) * target);
        el.textContent = `${prefix}${value}${suffix}`;
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = `${prefix}${target}${suffix}`;
      }
      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          run(e.target as HTMLElement);
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.6 });

    els.forEach((el) => observer.observe(el));
  }

  initCounter();
  document.addEventListener('astro:page-load', initCounter);
</script>
