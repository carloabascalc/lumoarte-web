<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container hero-content">
    <p class="hero-eyebrow">Arte · Precisión · Diseño</p>
    <h1 class="hero-title">Corte láser con<br />alma artística</h1>
    <p class="hero-sub">
      Transformamos materiales en esculturas, estructuras, maquetas y objetos
      personalizados combinando tecnología de precisión con mano de obra artesanal.
    </p>
    <a href="#cotiza" class="btn btn-primary hero-cta">Solicita tu proyecto</a>
  </div>
  <div class="hero-scroll" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: #fff;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("/images/gallery/hero-bg.jpg");
    background-size: cover;
    background-position: center 20%;
    transform: scale(1.03);
    transition: transform 8s ease-out;
  }

  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      rgba(5, 3, 2, 0.88) 0%,
      rgba(10, 6, 3, 0.75) 55%,
      rgba(15, 8, 4, 0.60) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: var(--nav-h);
    padding-bottom: 48px;
    max-width: 720px;
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 20px;
  }

  .hero-title {
    font-size: clamp(3rem, 8.5vw, 6.5rem);
    font-weight: 700;
    line-height: 1.04;
    margin-bottom: 28px;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 540px;
    line-height: 1.75;
    margin-bottom: 40px;
    font-weight: 300;
  }

  .hero-cta {
    font-size: 1rem;
    padding: 16px 36px;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .hero-scroll span {
    display: block;
    width: 1.5px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.6), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { opacity: 0.6; transform: scaleY(1); transform-origin: top; }
    50% { opacity: 1; }
  }

  @media (max-width: 640px) {
    .hero-content {
      padding-top: calc(var(--nav-h) + 24px);
    }
  }
</style>

<script>
  const bg = document.querySelector(".hero-bg") as HTMLElement;
  if (bg) {
    setTimeout(() => { bg.style.transform = "scale(1)"; }, 100);
  }
</script>
