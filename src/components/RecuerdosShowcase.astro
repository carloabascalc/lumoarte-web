---
// Recuerdos hero showcase — 3 illustrated keychain variants (Ocean, Maya, Fiesta).
// Same visual language as TresDShowcase: cream gradient cards, terracotta product
// gradients, layered rotation, micro-hover separation.
---

<div class="hero-stack">
  {/* BACK — Maya design (top-right) */}
  <div class="hero-card hero-card--back" aria-hidden="true">
    <div class="specimen-card">
      <svg viewBox="0 0 200 250" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="rec-maya-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#d99570"/>
            <stop offset="45%" stop-color="#a85f2a"/>
            <stop offset="100%" stop-color="#5a2a08"/>
          </linearGradient>
          <linearGradient id="rec-ring-a" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#e0e0e0"/>
            <stop offset="100%" stop-color="#8a8a8a"/>
          </linearGradient>
          <linearGradient id="rec-plate-a" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        <ellipse cx="100" cy="222" rx="60" ry="4" fill="rgba(20, 10, 4, 0.20)"/>
        <rect x="18" y="218" width="164" height="6" rx="1" fill="url(#rec-plate-a)"/>
        <circle cx="100" cy="36" r="14" fill="none" stroke="url(#rec-ring-a)" stroke-width="3.5"/>
        <rect x="96" y="48" width="8" height="14" rx="2" fill="url(#rec-ring-a)"/>
        <rect x="48" y="60" width="104" height="148" rx="20" fill="url(#rec-maya-grad)"/>
        {/* Maya glyph band top */}
        <rect x="62" y="82" width="76" height="22" fill="none" stroke="rgba(255, 240, 220, 0.55)" stroke-width="1.2"/>
        <g stroke="rgba(255, 240, 220, 0.55)" stroke-width="1.2" fill="none">
          <path d="M 62 82 L 68 88 L 74 82 L 80 88 L 86 82 L 92 88 L 98 82 L 104 88 L 110 82 L 116 88 L 122 82 L 128 88 L 134 82 L 138 82"/>
          <path d="M 62 104 L 68 98 L 74 104 L 80 98 L 86 104 L 92 98 L 98 104 L 104 98 L 110 104 L 116 98 L 122 104 L 128 98 L 134 104 L 138 104"/>
        </g>
        {/* Name */}
        <text x="100" y="150" text-anchor="middle" font-family="Playfair Display, Georgia, serif"
              font-size="22" font-style="italic" font-weight="600"
              fill="rgba(20, 10, 4, 0.70)">Itzel</text>
        {/* Glyph band bottom */}
        <rect x="68" y="172" width="64" height="14" fill="none" stroke="rgba(255, 240, 220, 0.55)" stroke-width="1.2"/>
        <line x1="68" y1="179" x2="132" y2="179" stroke="rgba(255, 240, 220, 0.40)" stroke-width="0.8"/>
      </svg>
    </div>
  </div>

  {/* MAIN — Ocean keychain (dominant, NIRVANA / CANCUN) */}
  <div class="hero-card hero-card--main" aria-hidden="true">
    <div class="specimen-card">
      <svg viewBox="0 0 200 250" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="rec-ocean-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#e8946e"/>
            <stop offset="40%" stop-color="#c96b3a"/>
            <stop offset="100%" stop-color="#7a2a02"/>
          </linearGradient>
          <linearGradient id="rec-ring-b" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#e0e0e0"/>
            <stop offset="100%" stop-color="#8a8a8a"/>
          </linearGradient>
          <linearGradient id="rec-plate-b" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        <ellipse cx="100" cy="222" rx="60" ry="4" fill="rgba(20, 10, 4, 0.20)"/>
        <rect x="18" y="218" width="164" height="6" rx="1" fill="url(#rec-plate-b)"/>
        <circle cx="100" cy="36" r="14" fill="none" stroke="url(#rec-ring-b)" stroke-width="3.5"/>
        <circle cx="100" cy="36" r="14" fill="none" stroke="rgba(20, 10, 4, 0.25)" stroke-width="0.8"/>
        <rect x="96" y="48" width="8" height="14" rx="2" fill="url(#rec-ring-b)"/>
        <rect x="96" y="48" width="8" height="14" rx="2" fill="none" stroke="rgba(20, 10, 4, 0.20)" stroke-width="0.5"/>
        <rect x="48" y="60" width="104" height="148" rx="20" fill="url(#rec-ocean-grad)"/>
        {/* FDM layer lines hint */}
        <g stroke="rgba(255, 255, 255, 0.10)" stroke-width="0.5">
          <line x1="56" y1="78" x2="144" y2="78"/>
          <line x1="54" y1="94" x2="146" y2="94"/>
          <line x1="52" y1="110" x2="148" y2="110"/>
          <line x1="52" y1="128" x2="148" y2="128"/>
          <line x1="52" y1="146" x2="148" y2="146"/>
          <line x1="52" y1="164" x2="148" y2="164"/>
          <line x1="54" y1="182" x2="146" y2="182"/>
          <line x1="56" y1="198" x2="144" y2="198"/>
        </g>
        {/* Left-edge highlight */}
        <path d="M 48 80 Q 48 60 68 60 L 80 60 L 80 64 Q 56 64 56 84 L 56 192 Q 56 204 68 204 L 80 204 L 80 208 Q 48 208 48 188 Z"
              fill="rgba(255, 240, 220, 0.18)"/>
        {/* CANCUN small letters at top */}
        <text x="100" y="102" text-anchor="middle" font-family="Playfair Display, Georgia, serif"
              font-size="11" font-weight="700" letter-spacing="4"
              fill="rgba(255, 240, 220, 0.85)">CANCUN</text>
        <line x1="74" y1="112" x2="126" y2="112" stroke="rgba(255, 240, 220, 0.45)" stroke-width="0.7"/>
        {/* Name engraved big */}
        <text x="100" y="150" text-anchor="middle" font-family="Playfair Display, Georgia, serif"
              font-size="22" font-weight="600" letter-spacing="3"
              fill="rgba(20, 10, 4, 0.70)">NIRVANA</text>
        {/* Wave pattern below the name */}
        <g stroke="rgba(255, 240, 220, 0.55)" stroke-width="1.6" fill="none" stroke-linecap="round">
          <path d="M 62 178 Q 76 172 90 178 T 118 178 T 140 178"/>
          <path d="M 62 188 Q 76 182 90 188 T 118 188 T 140 188"/>
        </g>
      </svg>
    </div>
  </div>

  {/* FRONT — Fiesta keychain (bottom-right, overlapping main) */}
  <div class="hero-card hero-card--front" aria-hidden="true">
    <div class="specimen-card">
      <svg viewBox="0 0 200 250" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="rec-fiesta-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#f0a674"/>
            <stop offset="50%" stop-color="#b8501f"/>
            <stop offset="100%" stop-color="#5a2a08"/>
          </linearGradient>
          <linearGradient id="rec-ring-c" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#e0e0e0"/>
            <stop offset="100%" stop-color="#8a8a8a"/>
          </linearGradient>
          <linearGradient id="rec-plate-c" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        <ellipse cx="100" cy="222" rx="60" ry="4" fill="rgba(20, 10, 4, 0.20)"/>
        <rect x="18" y="218" width="164" height="6" rx="1" fill="url(#rec-plate-c)"/>
        <circle cx="100" cy="36" r="14" fill="none" stroke="url(#rec-ring-c)" stroke-width="3.5"/>
        <rect x="96" y="48" width="8" height="14" rx="2" fill="url(#rec-ring-c)"/>
        <rect x="48" y="60" width="104" height="148" rx="20" fill="url(#rec-fiesta-grad)"/>
        {/* Confetti dots */}
        <g fill="rgba(255, 240, 220, 0.85)">
          <circle cx="64" cy="86" r="2"/>
          <circle cx="78" cy="78" r="2.5"/>
          <circle cx="96" cy="84" r="2"/>
          <circle cx="118" cy="80" r="2.5"/>
          <circle cx="134" cy="88" r="2"/>
          <circle cx="70" cy="100" r="1.8"/>
          <circle cx="128" cy="102" r="2"/>
        </g>
        {/* Two names */}
        <text x="100" y="138" text-anchor="middle" font-family="Playfair Display, Georgia, serif"
              font-size="18" font-style="italic" font-weight="600"
              fill="rgba(20, 10, 4, 0.72)">Ana &amp; Luis</text>
        {/* Hairline */}
        <line x1="74" y1="150" x2="126" y2="150" stroke="rgba(255, 240, 220, 0.55)" stroke-width="0.7"/>
        {/* Date */}
        <text x="100" y="170" text-anchor="middle" font-family="DM Sans, sans-serif"
              font-size="9" font-weight="500" letter-spacing="2"
              fill="rgba(255, 240, 220, 0.85)">14 · 06 · 2026</text>
        {/* Bottom streamers */}
        <g stroke="rgba(255, 240, 220, 0.55)" stroke-width="1.4" fill="none" stroke-linecap="round">
          <path d="M 64 188 Q 72 184 80 190 T 96 188"/>
          <path d="M 104 192 Q 112 186 120 192 T 138 188"/>
        </g>
      </svg>
    </div>
  </div>
</div>

<style>
  .hero-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 24px 56px rgba(20, 10, 4, 0.22),
      0 0 0 1px rgba(165, 58, 4, 0.06);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .specimen-card {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 90% 70% at 50% 30%, rgba(255, 255, 255, 0.55), transparent 70%),
      radial-gradient(ellipse 100% 80% at 50% 110%, rgba(165, 58, 4, 0.10), transparent 70%),
      linear-gradient(180deg, #f8f1e2 0%, #e8ddc6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px;
  }

  .specimen-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 6px 14px rgba(20, 10, 4, 0.18));
  }

  .hero-card--main {
    width: 52%;
    aspect-ratio: 4 / 5;
    top: 6%;
    left: 4%;
    z-index: 3;
    transform: rotate(-5deg);
  }

  .hero-card--back {
    width: 46%;
    aspect-ratio: 4 / 5;
    top: 0;
    right: 0;
    z-index: 1;
    transform: rotate(6deg);
    opacity: 0.96;
  }

  .hero-card--front {
    width: 46%;
    aspect-ratio: 4 / 5;
    bottom: 0;
    right: 4%;
    z-index: 4;
    transform: rotate(-8deg);
  }

  .hero-stack:hover .hero-card--main  { transform: rotate(-4deg) translateY(-4px); }
  .hero-stack:hover .hero-card--back  { transform: rotate(8deg) translateX(4px); }
  .hero-stack:hover .hero-card--front { transform: rotate(-9deg) translate(-4px, 4px); }
</style>
