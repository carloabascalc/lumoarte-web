---
import { services, type ServiceId } from "../data/services";

interface Props {
  excludeId: ServiceId;
}

const { excludeId } = Astro.props;
const others = services.filter((s) => s.id !== excludeId);
---

<section class="cross-services section">
  <div class="container">
    <div class="cross-header">
      <p class="cross-eyebrow" data-reveal>Otros servicios</p>
      <h2 class="cross-title" data-reveal data-reveal-delay="0.06">
        ¿Tu proyecto necesita más de una técnica?
      </h2>
      <p class="cross-body" data-reveal data-reveal-delay="0.12">
        Muchos proyectos combinan dos o tres servicios — un letrero corporativo
        que mezcla corte láser y vinil, un stand para evento que une lona y
        piezas impresas en 3D. Cotizamos todo en una sola conversación.
      </p>
    </div>
    <ul class="cross-grid" role="list">
      {others.map((s, i) => (
        <li class="cross-card" data-reveal data-reveal-delay={`${0.04 + i * 0.06}`}>
          <a href={s.slug} class="cross-link">
            <span class="cross-icon" aria-hidden="true" set:html={s.icon} />
            <div class="cross-body-block">
              <h3 class="cross-name">{s.name}</h3>
              <p class="cross-blurb">{s.blurb}</p>
            </div>
            <span class="cross-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .cross-services {
    background: var(--color-bg);
  }

  .cross-header {
    margin-bottom: 48px;
    max-width: 720px;
  }

  .cross-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .cross-title {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 3vw, 2.25rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .cross-body {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .cross-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .cross-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    transition: border-color 0.2s, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cross-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .cross-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 20px;
    padding: 24px 28px;
    color: inherit;
  }

  .cross-icon {
    color: var(--color-accent);
    display: flex;
  }

  .cross-icon svg {
    width: 24px;
    height: 24px;
  }

  .cross-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .cross-blurb {
    color: var(--color-muted);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .cross-arrow {
    color: var(--color-accent);
    transition: transform 0.2s;
  }

  .cross-card:hover .cross-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .cross-grid {
      grid-template-columns: 1fr;
    }

    .cross-link {
      padding: 20px 24px;
      gap: 16px;
    }
  }
</style>
