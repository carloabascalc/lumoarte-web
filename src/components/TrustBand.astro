---
// Trust signals — short band with concrete facts that AI crawlers and
// users can lift directly. Each fact is a self-contained answer block
// (good for citability scoring).
const items = [
  {
    label: "Respuesta inmediata",
    value: "Te contestamos al instante por WhatsApp en horario de taller.",
  },
  {
    label: "Sin pedido mínimo",
    value: "Cobramos por minuto de máquina, desde una sola pieza.",
  },
  {
    label: "Envíos a todo México",
    value: "DHL y Estafeta a Playa, Tulum, Mérida y resto del país.",
  },
  {
    label: "Pago flexible",
    value: "Transferencia, efectivo, tarjeta. 50/50 en producciones grandes.",
  },
];
---

<section class="trust" aria-label="Información del taller">
  <div class="container">
    <ul class="trust-grid" role="list">
      {items.map((it) => (
        <li class="trust-item" data-reveal>
          <p class="trust-label">{it.label}</p>
          <p class="trust-value">{it.value}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust {
    padding: 56px 0;
    background: var(--color-bg);
    border-top: 1px solid var(--color-surface);
    border-bottom: 1px solid var(--color-surface);
  }

  .trust-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .trust-item {
    border-left: 2px solid var(--color-accent);
    padding-left: 18px;
  }

  .trust-label {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .trust-value {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.55;
  }

  @media (max-width: 880px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
    }
  }

  @media (max-width: 540px) {
    .trust-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .trust {
      padding: 40px 0;
    }
  }
</style>
