---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumb" aria-label="Migas de pan">
  <ol class="breadcrumb-list">
    {items.map((item, i) => (
      <li class="breadcrumb-item">
        {item.href ? (
          <a href={item.href} class="breadcrumb-link">{item.label}</a>
        ) : (
          <span class="breadcrumb-current" aria-current="page">{item.label}</span>
        )}
        {i < items.length - 1 && (
          <span class="breadcrumb-sep" aria-hidden="true">›</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb {
    padding: calc(var(--nav-h) + 28px) 0 0;
  }

  .breadcrumb-list {
    list-style: none;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 0.8125rem;
    color: var(--color-muted);
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .breadcrumb-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .breadcrumb-link {
    color: var(--color-muted);
    transition: color 0.2s;
  }

  .breadcrumb-link:hover {
    color: var(--color-accent);
  }

  .breadcrumb-current {
    color: var(--color-text);
    font-weight: 500;
  }

  .breadcrumb-sep {
    color: var(--color-muted);
    opacity: 0.6;
  }
</style>
