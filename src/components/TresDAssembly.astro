---
// 3D parallax — a piece printing layer by layer.
// Build plate stays anchored at the bottom; layers fade in bottom-up as the
// nozzle rises above them. End state: a complete vase-profile print.

const layers = [
  { w: 240, color: "#c96b3a" }, // base
  { w: 240, color: "#c96b3a" },
  { w: 220, color: "#b34000" },
  { w: 184, color: "#a53a04" },
  { w: 160, color: "#a53a04" }, // narrow waist
  { w: 168, color: "#b34000" },
  { w: 196, color: "#c96b3a" }, // mid bulge
  { w: 216, color: "#c96b3a" },
  { w: 200, color: "#b34000" }, // taper
  { w: 168, color: "#a53a04" },
  { w: 144, color: "#8a3508" }, // neck
  { w: 168, color: "#a53a04" }, // rim flare
];
---

<section class="tres-d-assembly assembly" aria-labelledby="tresd-assembly-title">
  <div class="assembly-wrap" id="tresd-assembly-wrap">
    <div class="assembly-stage">
      <div class="assembly-grid-bg" aria-hidden="true"></div>

      <div class="container assembly-header">
        <p class="assembly-eyebrow">Cómo se imprime</p>
        <h2 class="assembly-title section-title" id="tresd-assembly-title">
          Capa por capa,<br/>hasta la <em>pieza.</em>
        </h2>
        <p class="assembly-sub">
          La pieza crece en cientos de capas finas. Cada milímetro suma —
          y cuando termina, ya no hay vuelta atrás.
        </p>
      </div>

      <div class="tresd-canvas" aria-hidden="true">
        <div class="tresd-bed-glow"></div>

        <div class="tresd-nozzle" id="tresd-nozzle">
          <div class="tresd-nozzle-feed"></div>
          <div class="tresd-nozzle-mount"></div>
          <div class="tresd-nozzle-tip"></div>
        </div>

        <div class="tresd-stack">
          {layers.map((l, i) => (
            <span
              class="tresd-layer"
              data-layer
              data-idx={i}
              style={`width: ${l.w}px; bottom: ${i * 14}px; background: ${l.color};`}
            ></span>
          ))}
        </div>

        <div class="tresd-plate"></div>
      </div>

      <p class="assembly-hint" aria-hidden="true">
        <span id="tresd-hint-label">Modelo digital</span>
        <b id="tresd-hint-stage">01</b><span class="assembly-hint-of"> / 03</span>
      </p>
    </div>
  </div>
</section>

<style>
  .tres-d-assembly {
    background: var(--color-bg);
    position: relative;
  }

  .assembly-wrap {
    position: relative;
    height: 220vh;
  }

  .assembly-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    --canvas-scale: 1;
  }

  .assembly-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(rgba(20, 10, 4, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20, 10, 4, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0;
    will-change: opacity;
    pointer-events: none;
  }

  .assembly-header {
    position: relative;
    z-index: 4;
    text-align: center;
    margin-top: -22vh;
    pointer-events: none;
  }

  .assembly-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .assembly-title { margin-bottom: 18px; }
  .assembly-title em { font-style: italic; color: var(--color-accent); }

  .assembly-sub {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 540px;
    margin: 0 auto;
  }

  /* ── 3D printer canvas ────────────────────────────── */
  .tresd-canvas {
    position: absolute;
    left: 50%;
    bottom: 14vh;
    transform: translateX(-50%) scale(var(--canvas-scale));
    transform-origin: bottom center;
    z-index: 2;
    width: 320px;
    height: 280px;
    pointer-events: none;
  }

  .tresd-bed-glow {
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 360px;
    height: 28px;
    background: radial-gradient(ellipse at center,
      rgba(165, 58, 4, 0.32) 0%,
      rgba(165, 58, 4, 0.14) 35%,
      transparent 75%);
    filter: blur(5px);
    pointer-events: none;
    z-index: 0;
  }

  .tresd-plate {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 320px;
    height: 10px;
    background: linear-gradient(180deg, #2a2a2a 0%, #14110e 100%);
    border-radius: 2px;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.30);
    z-index: 1;
  }

  .tresd-plate::before {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 4%;
    right: 4%;
    height: 4px;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.10) 100%);
  }

  .tresd-stack {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: calc(100% - 10px);
  }

  .tresd-layer {
    position: absolute;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    height: 14px;
    border-radius: 1px;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.18);
    background-image:
      repeating-linear-gradient(90deg,
        rgba(255, 255, 255, 0.0) 0 6px,
        rgba(255, 255, 255, 0.05) 6px 7px);
  }

  .tresd-layer[data-on] {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .tresd-nozzle {
    position: absolute;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    width: 60px;
    height: 60px;
    will-change: transform;
    pointer-events: none;
  }

  .tresd-nozzle-feed {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    width: 2.6px;
    height: 28px;
    background: linear-gradient(180deg,
      rgba(165, 58, 4, 0) 0%,
      rgba(165, 58, 4, 0.4) 35%,
      var(--color-accent) 100%);
    border-radius: 1.3px;
    pointer-events: none;
  }

  .tresd-nozzle-mount {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 22px;
    background: linear-gradient(180deg, #2a2a2a 0%, #14110e 100%);
    border-radius: 4px 4px 2px 2px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
  }

  .tresd-nozzle-tip {
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 11px solid transparent;
    border-right: 11px solid transparent;
    border-top: 18px solid #14110e;
    filter: drop-shadow(0 3px 6px rgba(0, 0, 0, 0.30));
  }

  .tresd-nozzle-tip::after {
    content: "";
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translate(-50%, 100%);
    width: 3px;
    height: 9px;
    background: linear-gradient(180deg, #ffb060 0%, var(--color-accent) 55%, #5a1d00 100%);
    border-radius: 1.5px;
    box-shadow:
      0 0 6px rgba(255, 130, 50, 0.85),
      0 0 14px rgba(165, 58, 4, 0.5);
    opacity: var(--nozzle-active, 0);
    transition: opacity 0.15s ease;
  }

  .assembly-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    margin: 0;
  }

  .assembly-hint b {
    color: var(--color-accent);
    font-weight: 600;
    transition: color 0.3s ease;
    font-variant-numeric: tabular-nums;
  }

  .assembly-hint-of { color: var(--color-muted); opacity: 0.6; }

  @media (max-width: 980px) {
    .assembly-stage { --canvas-scale: 0.85; }
  }

  @media (max-width: 640px) {
    .assembly-wrap { height: 200vh; }
    .assembly-stage { --canvas-scale: 0.6; }
    .assembly-header { margin-top: -18vh; }
    .assembly-sub { font-size: 0.95rem; max-width: 320px; }
    .assembly-hint { white-space: nowrap; bottom: 24px; font-size: 0.66rem; letter-spacing: 0.14em; }
  }

  @media (prefers-reduced-motion: reduce) {
    .assembly-wrap { height: auto; }
    .assembly-stage { position: static; height: auto; padding: 100px 0; }
    .tresd-layer { opacity: 1 !important; transform: translateX(-50%) !important; }
    .tresd-nozzle { display: none; }
  }
</style>

<script>
  function initTresDAssembly() {
    const wrap = document.getElementById('tresd-assembly-wrap');
    const grid = wrap?.querySelector<HTMLElement>('.assembly-grid-bg');
    const hintLabel = document.getElementById('tresd-hint-label');
    const hintStage = document.getElementById('tresd-hint-stage');
    const nozzle = document.getElementById('tresd-nozzle');
    const layers = wrap ? Array.from(wrap.querySelectorAll<HTMLElement>('.tresd-layer')) : [];
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!wrap || !nozzle || !layers.length || reduced) return;

    const N = layers.length;
    const layerHeightPx = 14; // matches CSS

    const clamp = (v: number, lo = 0, hi = 1) => Math.max(lo, Math.min(hi, v));
    const ease = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

    let pending = false;

    function tick() {
      pending = false;
      const rect = wrap!.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      if (total <= 0) return;
      const scrolled = -rect.top;
      const rawP = clamp(scrolled / total);
      const p = ease(rawP);

      if (grid) {
        const o = rawP < 0.35 ? (rawP / 0.35) * 0.5
                : rawP < 0.92 ? 0.5 - ((rawP - 0.35) / 0.57) * 0.4
                : Math.max(0, 0.1 - ((rawP - 0.92) / 0.08) * 0.1);
        grid.style.opacity = String(o);
      }

      if (hintLabel && hintStage) {
        if (rawP < 0.12) { hintLabel.textContent = 'Modelo digital'; hintStage.textContent = '01'; }
        else if (rawP < 0.85) { hintLabel.textContent = 'Imprimiendo'; hintStage.textContent = '02'; }
        else { hintLabel.textContent = 'Pieza física'; hintStage.textContent = '03'; }
      }

      // Layers reveal bottom-up. Each layer i activates at p_i = (i+1)/(N+2).
      // The +2 leaves a small lead-in (no layer at p=0) and tail-out.
      const layerThreshold = 1 / (N + 2);
      let activeIdx = -1;
      layers.forEach((el, i) => {
        const start = (i + 1) * layerThreshold;
        if (rawP >= start) {
          el.setAttribute('data-on', '');
          activeIdx = i;
        } else {
          el.removeAttribute('data-on');
        }
      });

      // Nozzle hovers just above the top completed layer.
      // bottom = plateHeight (10px) + layers stacked + small gap (8px) so the tip sits above the print.
      const platePx = 10;
      const gapPx = 8;
      const nozzleBottom = 24 + (activeIdx >= 0 ? (activeIdx + 1) * layerHeightPx : 0) + gapPx - 24;
      nozzle!.style.transform = `translate(-50%, ${-nozzleBottom}px)`;

      // Active filament glow only while printing.
      const active = rawP > 0.05 && rawP < 0.92 ? 1 : 0;
      nozzle!.style.setProperty('--nozzle-active', String(active));
    }

    function onScroll() {
      if (pending) return;
      pending = true;
      requestAnimationFrame(tick);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    tick();
  }

  initTresDAssembly();
  document.addEventListener('astro:page-load', initTresDAssembly);
</script>
