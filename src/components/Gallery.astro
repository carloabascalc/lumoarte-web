---

<section class="gallery" id="galeria">
  <div class="container">
    <div class="gallery-header">
      <h2 class="section-title gallery-title" data-reveal>Nuestras obras</h2>
      <span class="gallery-accent" data-reveal data-reveal-delay="0.15" aria-hidden="true"></span>
    </div>
  </div>

  <div class="filmstrip-wrapper">
    <button class="arrow arrow--left" id="arrowLeft" aria-label="Anterior">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <div class="filmstrip" id="filmstrip">
      {images.map((img, i) => (
        <div class="film-item" data-index={i}>
          <img
            src={img.src}
            alt={img.alt}
            loading={i < 2 ? "eager" : "lazy"}
            draggable="false"
          />
          <div class="film-overlay" aria-hidden="true"></div>
        </div>
      ))}
    </div>

    <button class="arrow arrow--right" id="arrowRight" aria-label="Siguiente">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

  <div class="filmstrip-dots" id="filmstripDots" aria-hidden="true">
    {images.map((_, i) => (
      <button class={`dot${i === 0 ? " dot--active" : ""}`} data-dot={i} aria-label={`Imagen ${i + 1}`} />
    ))}
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Imagen ampliada" hidden>
  <button class="lightbox-close" id="lightboxClose" aria-label="Cerrar">✕</button>
  <img class="lightbox-img" id="lightboxImg" src="" alt="" />
</div>

<style>
  .gallery {
    background: #0d0d0d;
    padding: 120px 0 100px;
  }

  .gallery-header {
    margin-bottom: 48px;
    padding: 0 24px;
    max-width: var(--max-w);
    margin-left: auto;
    margin-right: auto;
  }

  .gallery-title {
    color: #ffffff;
    margin-bottom: 12px;
  }

  .gallery-accent {
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* ── Filmstrip ─────────────────────────────────────── */
  .filmstrip-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .filmstrip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 0 24px;
    cursor: grab;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filmstrip::-webkit-scrollbar {
    display: none;
  }

  .filmstrip.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    user-select: none;
  }

  .film-item {
    position: relative;
    flex: 0 0 auto;
    height: 520px;
    min-width: 300px;
    width: auto;
    scroll-snap-align: start;
    overflow: hidden;
    border-radius: 4px;
    background: #1a1a1a;
    opacity: 0;
    cursor: zoom-in;
  }

  .film-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .film-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .film-item:hover img {
    transform: scale(1.06);
  }

  .film-item:hover .film-overlay {
    opacity: 1;
  }

  /* ── Arrow buttons ─────────────────────────────────── */
  .arrow {
    position: absolute;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    cursor: pointer;
  }

  .arrow:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .arrow--left { left: 8px; }
  .arrow--right { right: 8px; }

  /* ── Lightbox ──────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6);
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* ── Progress dots ─────────────────────────────────── */
  .filmstrip-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    padding: 0 24px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    flex-shrink: 0;
  }

  .dot--active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 768px) {
    .gallery {
      padding: 80px 0 72px;
    }

    .film-item {
      height: 320px;
    }

    .arrow {
      display: none;
    }
  }
</style>

<script>
  const filmstrip = document.getElementById("filmstrip")!;
  const arrowLeft = document.getElementById("arrowLeft")!;
  const arrowRight = document.getElementById("arrowRight")!;
  const lightbox = document.getElementById("lightbox")!;
  const lightboxImg = document.getElementById("lightboxImg") as HTMLImageElement;
  const lightboxClose = document.getElementById("lightboxClose")!;

  // ── Arrow navigation ──────────────────────────────────
  arrowLeft.addEventListener("click", () => {
    filmstrip.scrollBy({ left: -400, behavior: "smooth" });
  });
  arrowRight.addEventListener("click", () => {
    filmstrip.scrollBy({ left: 400, behavior: "smooth" });
  });

  // ── Drag to scroll ────────────────────────────────────
  let isDragging = false;
  let didDrag = false;
  let startX = 0;
  let scrollStart = 0;

  filmstrip.addEventListener("mousedown", (e) => {
    isDragging = true;
    didDrag = false;
    startX = e.pageX;
    scrollStart = filmstrip.scrollLeft;
    filmstrip.classList.add("is-dragging");
  });

  window.addEventListener("mousemove", (e) => {
    if (!isDragging) return;
    const delta = e.pageX - startX;
    if (Math.abs(delta) > 4) didDrag = true;
    filmstrip.scrollLeft = scrollStart - delta;
  });

  window.addEventListener("mouseup", () => {
    isDragging = false;
    filmstrip.classList.remove("is-dragging");
  });

  // ── Lightbox ──────────────────────────────────────────
  const items = filmstrip.querySelectorAll<HTMLElement>(".film-item");

  items.forEach((item) => {
    item.addEventListener("click", () => {
      if (didDrag) { didDrag = false; return; }
      const img = item.querySelector("img")!;
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightbox.removeAttribute("hidden");
      document.body.style.overflow = "hidden";
    });
  });

  function closeLightbox() {
    lightbox.setAttribute("hidden", "");
    document.body.style.overflow = "";
    lightboxImg.src = "";
  }

  lightboxClose.addEventListener("click", closeLightbox);

  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !lightbox.hasAttribute("hidden")) {
      closeLightbox();
    }
  });

  // ── Progress dots ─────────────────────────────────────
  const dots = document.querySelectorAll<HTMLButtonElement>(".dot");

  function updateDots() {
    const itemWidth = filmstrip.querySelector<HTMLElement>(".film-item")?.offsetWidth ?? 0;
    const gap = 8;
    const index = Math.round(filmstrip.scrollLeft / (itemWidth + gap));
    dots.forEach((dot, i) => dot.classList.toggle("dot--active", i === index));
  }

  filmstrip.addEventListener("scroll", updateDots, { passive: true });

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      const itemWidth = filmstrip.querySelector<HTMLElement>(".film-item")?.offsetWidth ?? 0;
      filmstrip.scrollTo({ left: i * (itemWidth + 8), behavior: "smooth" });
    });
  });
</script>
