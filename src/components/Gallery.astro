---
import type { ServiceId } from "../data/services";
import { SITE } from "../data/services";

interface Props {
  filterService?: ServiceId;
  title?: string;
  subtitle?: string;
}

const {
  filterService,
  title = "Nuestras obras",
  subtitle,
} = Astro.props;

type GalleryImage = {
  src: string;
  alt: string;
  service: ServiceId;
};

const allImages: GalleryImage[] = [
  { src: "/images/gallery/gal-01.jpg", alt: "Logotipo GAIA grabado en mármol travertino", service: "corte-laser" },
  { src: "/images/gallery/gal-02.jpg", alt: "Cirio pascual en caja de madera con acrílico grabado", service: "corte-laser" },
  { src: "/images/gallery/gal-03.jpg", alt: "Paletas de madera corazón grabadas con logotipo L'Oreal", service: "corte-laser" },
  { src: "/images/gallery/gal-04.jpg", alt: "Caja de madera con acrílico dorado grabado", service: "corte-laser" },
  { src: "/images/gallery/gal-05.jpg", alt: "Caja de vino con corte láser de copos de nieve y palmeras", service: "corte-laser" },
  { src: "/images/gallery/gal-06.jpg", alt: "Caja de madera con acrílico rojo Te Amo", service: "corte-laser" },
  { src: "/images/gallery/gal-07.jpg", alt: "Caja de chocolates y marco de madera con corazones en jardín", service: "corte-laser" },
  { src: "/images/gallery/gal-08.jpg", alt: "Caja de madera con tapa de acrílico transparente", service: "corte-laser" },
  { src: "/images/gallery/gal-10.jpg", alt: "Cesta de madera con rosas y chocolates", service: "corte-laser" },
  { src: "/images/gallery/gal-11.jpg", alt: "Display navideño de vino y chocolates con paneles de copos de nieve iluminados", service: "corte-laser" },
  { src: "/images/gallery/gal-12.jpg", alt: "Llavero de acrílico negro grabado Club Hípico", service: "corte-laser" },
  { src: "/images/gallery/gal-13.jpg", alt: "Posavasos de madera grabados con oración sobre superficie de nogal", service: "corte-laser" },
  { src: "/images/gallery/gal-14.jpg", alt: "Grabado de logotipo en mármol travertino", service: "corte-laser" },
  { src: "/images/gallery/gal-15.jpg", alt: "Cuchara Caspian Soul Caviar con mango de madera grabado", service: "corte-laser" },
  { src: "/images/gallery/gal-16.jpg", alt: "Escultura decorativa en MDF con fondo tropical", service: "corte-laser" },
  { src: "/images/gallery/gal-17.jpg", alt: "Cajas de madera con oración grabada en cuatro tipos de madera", service: "corte-laser" },
  { src: "/images/gallery/gal-18.jpg", alt: "Cajas para vino con diseños en acrílico", service: "corte-laser" },
  { src: "/images/gallery/gal-19.jpg", alt: "Souvenirs de Cancún personalizados con nombres sobre madera", service: "corte-laser" },
  { src: "/images/gallery/gal-20.jpg", alt: "Caja corazón de MDF con iluminación cálida", service: "corte-laser" },
  { src: "/images/gallery/gal-21.jpg", alt: "Cesta de madera con ensamble de dedos cortada a láser", service: "corte-laser" },
  { src: "/images/gallery/gal-22.jpg", alt: "Cruz de madera grabada haz todo con amor", service: "corte-laser" },
  { src: "/images/gallery/gal-23.jpg", alt: "Fichas ovaladas de madera con oración grabada, producción en serie", service: "corte-laser" },
  { src: "/images/gallery/gal-24.jpg", alt: "Joyero de acrílico espejo con anillo de diamante", service: "corte-laser" },
  { src: "/images/gallery/gal-25.jpg", alt: "Placa circular de acrílico multicolor con diseño de loro", service: "corte-laser" },
  { src: "/images/gallery/gal-26.jpg", alt: "Escultura corazón de MDF contra cielo azul y palmeras", service: "corte-laser" },
  { src: "/images/gallery/gal-27.jpg", alt: "Caja larga de madera grabada Te Amo sobre mármol", service: "corte-laser" },
  { src: "/images/gallery/gal-28.jpg", alt: "Cajas corazón apiladas con plantas tropicales", service: "corte-laser" },
  { src: "/images/gallery/gal-29.jpg", alt: "Medallón de madera y acrílico negro grabado Hugo", service: "corte-laser" },
];

const images = filterService
  ? allImages.filter((img) => img.service === filterService)
  : allImages;

const isEmpty = images.length === 0;
---

<section class="gallery" id="galeria">
  <div class="container">
    <div class="gallery-header">
      <h2 class="section-title gallery-title" data-reveal>{title}</h2>
      {subtitle && <p class="gallery-subtitle" data-reveal data-reveal-delay="0.08">{subtitle}</p>}
      <span class="gallery-accent" data-reveal data-reveal-delay="0.15" aria-hidden="true"></span>
    </div>
  </div>

  {isEmpty ? (
    <div class="container">
      <div class="gallery-empty" data-reveal>
        <p class="gallery-empty-eyebrow">Galería en construcción</p>
        <h3 class="gallery-empty-title">Pronto: más trabajos de este servicio</h3>
        <p class="gallery-empty-body">
          Estamos documentando nuestros próximos proyectos. Mientras tanto, sigue
          el día a día del taller en Instagram — ahí publicamos primero todo lo
          que sale de las máquinas.
        </p>
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="gallery-empty-cta"
        >
          Ver en Instagram {SITE.instagramHandle}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  ) : (
    <>
      <div class="filmstrip-wrapper">
        <button class="arrow arrow--left" id="arrowLeft" aria-label="Anterior">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="filmstrip" id="filmstrip">
          {images.map((img, i) => (
            <div class="film-item" data-index={i}>
              <img
                src={img.src}
                alt={img.alt}
                loading={i < 2 ? "eager" : "lazy"}
                draggable="false"
              />
              <div class="film-overlay" aria-hidden="true"></div>
            </div>
          ))}
        </div>

        <button class="arrow arrow--right" id="arrowRight" aria-label="Siguiente">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <div class="filmstrip-dots" id="filmstripDots" aria-hidden="true">
        {images.map((_, i) => (
          <button class={`dot${i === 0 ? " dot--active" : ""}`} data-dot={i} aria-label={`Imagen ${i + 1}`} />
        ))}
      </div>
    </>
  )}
</section>

<!-- Lightbox -->
{!isEmpty && (
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Imagen ampliada" hidden>
    <button class="lightbox-close" id="lightboxClose" aria-label="Cerrar">✕</button>
    <img class="lightbox-img" id="lightboxImg" src="" alt="" />
  </div>
)}

<style>
  .gallery {
    background: #0d0d0d;
    padding: 120px 0 100px;
  }

  .gallery-header {
    margin-bottom: 48px;
    padding: 0 24px;
    max-width: var(--max-w);
    margin-left: auto;
    margin-right: auto;
  }

  .gallery-title {
    color: #ffffff;
    margin-bottom: 12px;
  }

  .gallery-subtitle {
    color: rgba(255, 255, 255, 0.65);
    font-size: 1.0625rem;
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 12px;
  }

  .gallery-accent {
    display: block;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* ── Filmstrip ─────────────────────────────────────── */
  .filmstrip-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .filmstrip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 0 24px;
    cursor: grab;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filmstrip::-webkit-scrollbar {
    display: none;
  }

  .filmstrip.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    user-select: none;
  }

  .film-item {
    position: relative;
    flex: 0 0 auto;
    height: 520px;
    min-width: 300px;
    width: auto;
    scroll-snap-align: start;
    overflow: hidden;
    border-radius: 4px;
    background: #1a1a1a;
    opacity: 0;
    cursor: zoom-in;
  }

  .film-item img {
    height: 100%;
    width: auto;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .film-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .film-item:hover img {
    transform: scale(1.06);
  }

  .film-item:hover .film-overlay {
    opacity: 1;
  }

  /* ── Empty state ───────────────────────────────────── */
  .gallery-empty {
    max-width: 640px;
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    padding: 56px 40px;
    text-align: center;
    margin: 0 auto;
  }

  .gallery-empty-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .gallery-empty-title {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .gallery-empty-body {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .gallery-empty-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border: 1.5px solid var(--color-accent);
    padding: 12px 24px;
    border-radius: 4px;
    transition: background 0.2s, color 0.2s;
  }

  .gallery-empty-cta:hover {
    background: var(--color-accent);
    color: #fff;
  }

  /* ── Arrow buttons ─────────────────────────────────── */
  .arrow {
    position: absolute;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    cursor: pointer;
  }

  .arrow:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .arrow--left { left: 8px; }
  .arrow--right { right: 8px; }

  /* ── Lightbox ──────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6);
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* ── Progress dots ─────────────────────────────────── */
  .filmstrip-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    padding: 0 24px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    flex-shrink: 0;
  }

  .dot--active {
    background: var(--color-accent);
    transform: scale(1.4);
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 768px) {
    .gallery {
      padding: 80px 0 72px;
    }

    .film-item {
      height: 320px;
    }

    .arrow {
      display: none;
    }

    .gallery-empty {
      padding: 40px 28px;
    }
  }
</style>

<script>
  const filmstrip = document.getElementById("filmstrip");
  const arrowLeft = document.getElementById("arrowLeft");
  const arrowRight = document.getElementById("arrowRight");
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightboxImg") as HTMLImageElement | null;
  const lightboxClose = document.getElementById("lightboxClose");

  if (filmstrip && arrowLeft && arrowRight && lightbox && lightboxImg && lightboxClose) {
    // ── Arrow navigation ──────────────────────────────────
    arrowLeft.addEventListener("click", () => {
      filmstrip.scrollBy({ left: -400, behavior: "smooth" });
    });
    arrowRight.addEventListener("click", () => {
      filmstrip.scrollBy({ left: 400, behavior: "smooth" });
    });

    // ── Drag to scroll ────────────────────────────────────
    let isDragging = false;
    let didDrag = false;
    let startX = 0;
    let scrollStart = 0;

    filmstrip.addEventListener("mousedown", (e) => {
      isDragging = true;
      didDrag = false;
      startX = (e as MouseEvent).pageX;
      scrollStart = filmstrip.scrollLeft;
      filmstrip.classList.add("is-dragging");
    });

    window.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      const delta = (e as MouseEvent).pageX - startX;
      if (Math.abs(delta) > 4) didDrag = true;
      filmstrip.scrollLeft = scrollStart - delta;
    });

    window.addEventListener("mouseup", () => {
      isDragging = false;
      filmstrip.classList.remove("is-dragging");
    });

    // ── Lightbox ──────────────────────────────────────────
    const items = filmstrip.querySelectorAll<HTMLElement>(".film-item");

    items.forEach((item) => {
      item.addEventListener("click", () => {
        if (didDrag) { didDrag = false; return; }
        const img = item.querySelector("img");
        if (!img) return;
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.removeAttribute("hidden");
        document.body.style.overflow = "hidden";
      });
    });

    function closeLightbox() {
      lightbox!.setAttribute("hidden", "");
      document.body.style.overflow = "";
      lightboxImg!.src = "";
    }

    lightboxClose.addEventListener("click", closeLightbox);

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lightbox.hasAttribute("hidden")) {
        closeLightbox();
      }
    });

    // ── Progress dots ─────────────────────────────────────
    const dots = document.querySelectorAll<HTMLButtonElement>(".dot");

    function updateDots() {
      const itemWidth = filmstrip!.querySelector<HTMLElement>(".film-item")?.offsetWidth ?? 0;
      const gap = 8;
      const index = Math.round(filmstrip!.scrollLeft / (itemWidth + gap));
      dots.forEach((dot, i) => dot.classList.toggle("dot--active", i === index));
    }

    filmstrip.addEventListener("scroll", updateDots, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        const itemWidth = filmstrip!.querySelector<HTMLElement>(".film-item")?.offsetWidth ?? 0;
        filmstrip!.scrollTo({ left: i * (itemWidth + 8), behavior: "smooth" });
      });
    });
  }
</script>
