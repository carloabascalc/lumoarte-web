---
const images = [
  { src: "/images/gallery/hero-bg.jpg", alt: "Biombo con patrón circular en madera" },
  { src: "/images/gallery/gal-01.jpg", alt: "Pieza artística en madera natural" },
  { src: "/images/gallery/gal-02.jpg", alt: "Proyecto de corte láser personalizado" },
  { src: "/images/gallery/gal-03.jpg", alt: "Obra artesanal en madera con corte láser" },
  { src: "/images/gallery/gal-04.jpg", alt: "Diseño decorativo con corte de precisión" },
  { src: "/images/gallery/gal-05.jpg", alt: "Escultura decorativa en madera" },
  { src: "/images/gallery/gal-06.jpg", alt: "Celosía decorativa artesanal" },
];
---

<section class="section gallery" id="galeria">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Nuestras obras</h2>
    </div>
    <div class="gallery-grid">
      {
        images.map((img, i) => (
          <div class="gallery-item">
            <img
              src={img.src}
              alt={img.alt}
              loading={i < 3 ? "eager" : "lazy"}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .gallery-item {
    overflow: hidden;
    border-radius: 6px;
    background: var(--color-surface);
    aspect-ratio: 4 / 3;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
