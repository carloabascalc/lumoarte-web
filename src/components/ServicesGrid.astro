---
import { Image } from "astro:assets";
import { services } from "../data/services";
import laserCover from "../assets/gallery/gal-01.jpg";
---

<section class="servicios" id="servicios">
  <div class="container">
    <div class="section-header">
      <p class="servicios-eyebrow" data-reveal>Tres servicios, un solo taller</p>
      <h2 class="section-title" data-reveal data-reveal-delay="0.06">
        Lo que hacemos
      </h2>
      <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
        Cubrimos todo el ciclo de la fabricación digital con corte láser,
        impresión 3D e impresión de gran formato — desde una pieza única hasta
        producción en serie.
      </p>
    </div>

    <ul class="servicios-grid" role="list">
      {services.map((s, i) => (
        <li class={`servicio-card servicio-card--${s.id}`} data-reveal data-reveal-delay={`${0.05 + i * 0.06}`}>
          <a href={s.slug} class="servicio-link">
            <div class="servicio-media" aria-hidden="true">
              {s.id === "corte-laser" ? (
                <Image
                  src={laserCover}
                  alt=""
                  widths={[400, 600, 900]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  quality={72}
                  loading="lazy"
                  decoding="async"
                  class="servicio-media-img"
                />
              ) : (
                <div class="servicio-media-tint">
                  <span class="servicio-media-icon" set:html={s.icon} />
                </div>
              )}
            </div>
            <div class="servicio-body">
              <h3 class="servicio-name">{s.name}</h3>
              <p class="servicio-blurb">{s.blurb}</p>
              <span class="servicio-cta">
                Ver servicio
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .servicios {
    background: var(--color-bg);
    padding: 120px 0;
  }

  .servicios-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    list-style: none;
  }

  .servicio-card {
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .servicio-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 18px 40px rgba(20, 10, 4, 0.08);
  }

  .servicio-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
  }

  /* ── Media (top) ───────────────────────────────────── */
  .servicio-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .servicio-media-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .servicio-card:hover .servicio-media-img {
    transform: scale(1.05);
  }

  .servicio-media-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1a1108 0%, #2a1605 50%, #5a2304 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .servicio-media-tint::before {
    content: "";
    position: absolute;
    top: -40%;
    right: -20%;
    width: 120%;
    height: 140%;
    background: radial-gradient(circle, rgba(255, 138, 74, 0.18) 0%, transparent 60%);
    pointer-events: none;
  }

  .servicio-media-icon {
    color: rgba(255, 200, 160, 0.85);
    position: relative;
    z-index: 1;
    transition: transform 0.4s ease, color 0.3s ease;
  }

  .servicio-card:hover .servicio-media-icon {
    color: #fff;
    transform: scale(1.08);
  }

  .servicio-media-icon :global(svg) {
    width: 64px !important;
    height: 64px !important;
    stroke-width: 1.2;
  }

  /* ── Body ──────────────────────────────────────────── */
  .servicio-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 28px 28px 32px;
  }

  .servicio-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .servicio-blurb {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .servicio-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    color: var(--color-accent);
    background: transparent;
    border: 1.5px solid var(--color-accent);
    border-radius: 999px;
    padding: 9px 20px;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .servicio-cta svg {
    transition: transform 0.25s ease;
  }

  .servicio-card:hover .servicio-cta {
    background: var(--color-accent);
    color: #fff;
  }

  .servicio-card:hover .servicio-cta svg {
    transform: translateX(3px);
  }

  @media (max-width: 980px) {
    .servicios-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .servicios {
      padding: 80px 0;
    }

    .servicios-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .servicio-body {
      padding: 24px 24px 28px;
    }

    .servicio-media {
      aspect-ratio: 16 / 10;
    }
  }
</style>
