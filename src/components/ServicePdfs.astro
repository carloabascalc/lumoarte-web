---
import type { Service } from "../data/services";

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<section class="service-pdfs" aria-label={`Documentos de ${service.name}`}>
  <div class="container service-pdfs-inner" data-reveal>
    <p class="service-pdfs-label">
      Todo sobre <strong>{service.name}</strong>: precios y cómo enviarnos tu proyecto.
    </p>
    <div class="service-pdfs-buttons">
      <a
        href={service.preciosPdf}
        target="_blank"
        rel="noopener noreferrer"
        class="service-pdf-btn service-pdf-btn--primary"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Lista de precios
      </a>
      <a
        href={service.manualPdf}
        target="_blank"
        rel="noopener noreferrer"
        class="service-pdf-btn"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
        ¿Cómo enviar tu proyecto?
      </a>
    </div>
  </div>
</section>

<style>
  .service-pdfs {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-surface);
  }

  .service-pdfs-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 22px;
    padding-bottom: 22px;
    flex-wrap: wrap;
  }

  .service-pdfs-label {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin: 0;
  }

  .service-pdfs-label strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .service-pdfs-buttons {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .service-pdf-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 11px 20px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 6px;
    border: 1.5px solid var(--page-accent, var(--color-accent));
    color: var(--page-accent, var(--color-accent));
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .service-pdf-btn svg {
    flex-shrink: 0;
  }

  .service-pdf-btn:hover {
    background: var(--page-accent, var(--color-accent));
    color: #fff;
  }

  .service-pdf-btn--primary {
    background: var(--page-accent, var(--color-accent));
    color: #fff;
  }

  .service-pdf-btn--primary:hover {
    background: var(--page-accent-dark, var(--color-accent-dark));
    border-color: var(--page-accent-dark, var(--color-accent-dark));
  }

  @media (max-width: 720px) {
    .service-pdfs-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .service-pdfs-buttons {
      width: 100%;
    }

    .service-pdf-btn {
      flex: 1 1 auto;
      justify-content: center;
    }
  }
</style>
