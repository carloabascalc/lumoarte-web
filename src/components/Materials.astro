---
const materials = [
  {
    label: "MDF y Triplay",
    name: "MDF y Triplay",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
    descripcion: "El material más versátil del taller. Corta, graba y marca con limpieza — desde piezas únicas hasta producción en serie. Acabados cálidos y económicos.",
    tecnica: "Corte, grabado y marcar",
    ejemplos: ["Cajas y empaque a medida", "Lámparas y luminarias", "Maquetas arquitectónicas", "Celosías y biombos", "Letreros y displays", "Souvenirs y regalos"],
  },
  {
    label: "Madera",
    name: "Madera (maciza y chapas)",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m17 14 3 3.3a1 1 0 0 1-.7 1.7H4.7a1 1 0 0 1-.7-1.7L7 14h-.3a1 1 0 0 1-.7-1.7L9 9h-.2A1 1 0 0 1 8 7.3L12 3l4 4.3a1 1 0 0 1-.8 1.7H15l3 3.3a1 1 0 0 1-.7 1.7H17Z"/><path d="M12 22v-3"/></svg>`,
    descripcion: "Grabamos sobre madera maciza y chapas finas. El láser realza la veta natural con detalle cálido. Ideal para piezas premium, regalos y memoriales.",
    tecnica: "Grabado",
    ejemplos: ["Letreros y rótulos grabados", "Placas conmemorativas", "Tablas para servir con logo", "Posavasos en madera fina", "Regalos premium personalizados", "Piezas decorativas grabadas"],
  },
  {
    label: "Acrílico",
    name: "Acrílico (gran gama de colores)",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 18 3 22 9 12 22 2 9"/><polyline points="2 9 12 14 22 9"/><line x1="12" y1="3" x2="12" y2="22"/><line x1="6" y1="3" x2="2" y2="9"/><line x1="18" y1="3" x2="22" y2="9"/></svg>`,
    descripcion: "Disponible en decenas de colores, transparencias y acabados. Genera cortes limpios con bordes pulidos. Ideal para piezas modernas y con iluminación.",
    tecnica: "Corte y grabado",
    ejemplos: ["Letreros luminosos", "Displays y señalética", "Separadores de ambiente", "Lámparas decorativas", "Portarretratos y marcos", "Llaveros y accesorios"],
  },
  {
    label: "Papeles",
    name: "Papeles (cualquier textura)",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21h12a2 2 0 0 0 2-2v-2H10v2a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h12v4"/><path d="M10 11h8M10 15h5"/></svg>`,
    descripcion: "Cortes muy delicados e intrincados en papeles de cualquier gramaje, con grabado para detalles sutiles. Ideal para piezas de papelería fina y arte en papel.",
    tecnica: "Corte y grabado",
    ejemplos: ["Invitaciones de boda", "Papelería personalizada", "Siluetas artísticas", "Tarjetas de presentación", "Decoraciones de eventos", "Cajas y empaque"],
  },
  {
    label: "Cuero",
    name: "Cuero",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
    descripcion: "Cortes precisos sin deformar el material y grabados que realzan la textura natural del cuero. Acabado artesanal en cada pieza.",
    tecnica: "Corte y grabado",
    ejemplos: ["Carteras y monederos", "Llaveros y dijes", "Etiquetas para ropa", "Parches y apliques", "Portadocumentos", "Accesorios personalizados"],
  },
  {
    label: "Tela",
    name: "Tela",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"/></svg>`,
    descripcion: "Cortes limpios sobre tela sin filete ni deformación. Ideal para apliques, patrones precisos y producción en serie de piezas textiles.",
    tecnica: "Corte",
    ejemplos: ["Apliques y patrones", "Plantillas para confección", "Recortes para parches", "Banderas y backdrops", "Etiquetas textiles", "Decoraciones de eventos"],
  },
  {
    label: "Vidrio",
    name: "Vidrio",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/></svg>`,
    descripcion: "Marcamos sobre vidrio plano y piezas terminadas creando un efecto esmerilado permanente y elegante. La pieza la trae el cliente o la conseguimos.",
    tecnica: "Marcar",
    ejemplos: ["Copas y cristalería", "Espejos decorativos", "Ventanas y cancel", "Placas conmemorativas", "Regalos corporativos", "Arte en vidrio"],
  },
  {
    label: "Piedra y Mármol",
    name: "Piedra y Mármol",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>`,
    descripcion: "Marcado de alta precisión sobre superficies duras. El resultado es permanente, con un contraste elegante entre la zona marcada y la piedra natural.",
    tecnica: "Marcar",
    ejemplos: ["Coasters y portavasos", "Placas y reconocimientos", "Detalles arquitectónicos", "Regalos de lujo", "Lápidas y memoriales", "Logos sobre piedra"],
  },
];
---

<section class="section materials" id="materiales">
  <div class="container">
    <div class="section-header">
      <p class="materials-eyebrow" data-reveal>Materiales para corte láser</p>
      <h2 class="section-title" data-reveal data-reveal-delay="0.06">La materia prima de la creatividad</h2>
      <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
        Cortamos, grabamos y marcamos sobre madera, acrílico, papel, cuero,
        tela, vidrio y mármol. Cada material tiene su técnica — toca una
        tarjeta para ver el detalle.
      </p>
    </div>
    <div class="materials-grid">
      {
        materials.map((m, i) => (
          <button class="material-card" data-index={i} type="button" aria-label={`Ver detalles de ${m.label}`}>
            <span class="material-icon" aria-hidden="true" set:html={m.svg} />
            <span class="material-name">{m.label}</span>
          </button>
        ))
      }
    </div>
  </div>
</section>

<!-- Material modal -->
<div class="mat-overlay" id="matOverlay" hidden aria-hidden="true">
  <div class="mat-modal" id="matModal" role="dialog" aria-modal="true" aria-labelledby="matModalTitle">
    <button class="mat-close" id="matClose" aria-label="Cerrar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="mat-modal-icon" id="matModalIcon" aria-hidden="true"></div>
    <h3 class="mat-modal-title" id="matModalTitle"></h3>
    <p class="mat-modal-desc" id="matModalDesc"></p>

    <div class="mat-modal-body">
      <div class="mat-info-block">
        <p class="mat-info-label">Técnica</p>
        <span class="mat-tag" id="matModalTag"></span>
      </div>
      <div class="mat-info-block">
        <p class="mat-info-label">Podemos hacer</p>
        <ul class="mat-examples" id="matModalExamples"></ul>
      </div>
    </div>
  </div>
</div>

<style>
  .materials {
    background: var(--color-bg-ink);
    color: var(--color-text-on-dark);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  /* Top + bottom soft fades — a thin warm-cream gradient that bleeds
     out of the section into the surrounding cream so the transition
     reads as a deliberate fade, not a hard cut. */
  .materials::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 80px;
    background: linear-gradient(to bottom, rgba(250, 247, 242, 0.06), transparent);
    pointer-events: none;
    z-index: 0;
  }

  .materials .container {
    position: relative;
    z-index: 1;
  }

  .materials :global(.section-title) {
    color: var(--color-text-on-dark);
  }

  .materials :global(.section-subtitle) {
    color: rgba(245, 233, 216, 0.72);
  }

  .materials-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-honey);
    margin-bottom: 16px;
  }

  .materials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    list-style: none;
  }

  .material-card {
    position: relative;
    background: linear-gradient(180deg, #241509 0%, #1d100707 100%);
    background-color: #221308;
    border: 1px solid rgba(200, 122, 42, 0.18);
    border-radius: 10px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
    font: inherit;
    color: inherit;
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    cursor: pointer;
    opacity: 0;
    overflow: hidden;
  }

  /* Subtle inset warm sheen on the top edge — feels like carved material */
  .material-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(200, 122, 42, 0.06) 0%, transparent 35%);
    pointer-events: none;
  }

  .material-card:hover {
    background-color: #2a1a0d;
    border-color: rgba(200, 122, 42, 0.5);
    box-shadow:
      0 16px 36px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(200, 122, 42, 0.10) inset;
    transform: translateY(-4px);
  }

  .material-card:hover .material-icon {
    transform: scale(1.08) rotate(-3deg);
  }

  .material-icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(200, 122, 42, 0.14);
    border: 1px solid rgba(200, 122, 42, 0.22);
    border-radius: 10px;
    flex-shrink: 0;
    color: var(--color-accent-honey);
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease, transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .material-card:hover .material-icon {
    background: rgba(200, 122, 42, 0.26);
    border-color: rgba(200, 122, 42, 0.55);
    color: #fde0bd;
  }

  .material-icon svg {
    width: 22px;
    height: 22px;
  }

  .material-name {
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-text-on-dark);
  }

  /* ── Overlay ───────────────────────────────────────── */
  .mat-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(10, 6, 3, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .mat-overlay[hidden] {
    display: none;
  }

  .mat-overlay.is-open {
    opacity: 1;
  }

  /* ── Modal card ────────────────────────────────────── */
  .mat-modal {
    position: relative;
    background: var(--color-bg);
    border-radius: 12px;
    padding: 40px;
    max-width: 520px;
    width: 100%;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
    border-top: 3px solid var(--color-accent);
    transform: scale(0.91) translateY(12px);
    opacity: 0;
    transition:
      transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.22s ease;
  }

  .mat-overlay.is-open .mat-modal {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .mat-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
  }

  .mat-close:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .mat-modal-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(165, 58, 4, 0.08);
    border-radius: 10px;
    color: var(--color-accent);
    margin-bottom: 20px;
  }

  .mat-modal-icon svg {
    width: 24px;
    height: 24px;
  }

  .mat-modal-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.3;
    padding-right: 24px;
  }

  .mat-modal-desc {
    font-size: 0.9375rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .mat-modal-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-top: 1px solid var(--color-surface);
    padding-top: 24px;
  }

  .mat-info-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 10px;
  }

  .mat-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 500;
    background: rgba(165, 58, 4, 0.08);
    color: var(--color-accent);
    border: 1px solid rgba(165, 58, 4, 0.2);
  }

  .mat-examples {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
  }

  .mat-examples li {
    font-size: 0.875rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mat-examples li::before {
    content: "";
    display: block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  @media (max-width: 540px) {
    .mat-modal {
      padding: 28px 24px;
    }

    .mat-examples {
      grid-template-columns: 1fr;
    }
  }
</style>

<script define:vars={{ materials }}>
  const overlay = document.getElementById("matOverlay");
  const modalIcon = document.getElementById("matModalIcon");
  const modalTitle = document.getElementById("matModalTitle");
  const modalDesc = document.getElementById("matModalDesc");
  const modalTag = document.getElementById("matModalTag");
  const modalExamples = document.getElementById("matModalExamples");
  const closeBtn = document.getElementById("matClose");

  function openModal(index) {
    const m = materials[index];
    modalIcon.innerHTML = m.svg;
    modalTitle.textContent = m.name;
    modalDesc.textContent = m.descripcion;
    modalTag.textContent = m.tecnica;
    modalExamples.innerHTML = m.ejemplos.map((e) => `<li>${e}</li>`).join("");
    overlay.removeAttribute("hidden");
    overlay.removeAttribute("aria-hidden");
    // Force reflow so the transition fires from the initial (closed) state
    overlay.offsetHeight;
    overlay.classList.add("is-open");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeModal() {
    overlay.classList.remove("is-open");
    document.body.style.overflow = "";
    overlay.addEventListener("transitionend", function handler() {
      overlay.setAttribute("hidden", "");
      overlay.setAttribute("aria-hidden", "true");
      overlay.removeEventListener("transitionend", handler);
    });
  }

  document.querySelectorAll(".material-card").forEach((card) => {
    card.addEventListener("click", () => openModal(Number(card.dataset.index)));
    card.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openModal(Number(card.dataset.index));
      }
    });
  });

  closeBtn.addEventListener("click", closeModal);

  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !overlay.hasAttribute("hidden")) closeModal();
  });
</script>
