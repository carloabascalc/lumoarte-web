---
// 3D printing hero showcase — 3 illustrated specimen cards.
// Each card mimics a printed product on a cream surface, with FDM-style
// layer lines suggesting the additive process. Same stack layout as laser.
---

<div class="hero-stack">
  {/* BACK card — small architectural model (stepped block) */}
  <div class="hero-card hero-card--back" aria-hidden="true">
    <div class="specimen-card specimen-card--arch">
      <svg viewBox="0 0 120 120" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="arch-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#c96b3a"/>
            <stop offset="55%" stop-color="#a53a04"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
          <linearGradient id="arch-base" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1a1a1a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        {/* Build plate */}
        <rect x="14" y="96" width="92" height="6" rx="1" fill="url(#arch-base)"/>
        {/* Stepped tower (3 tiers) */}
        <rect x="32" y="78" width="56" height="18" fill="url(#arch-grad)"/>
        <rect x="40" y="60" width="40" height="18" fill="url(#arch-grad)" opacity="0.92"/>
        <rect x="48" y="42" width="24" height="18" fill="url(#arch-grad)" opacity="0.84"/>
        {/* Layer lines */}
        <g stroke="rgba(255, 255, 255, 0.10)" stroke-width="0.5">
          <line x1="32" y1="84" x2="88" y2="84"/>
          <line x1="32" y1="90" x2="88" y2="90"/>
          <line x1="40" y1="66" x2="80" y2="66"/>
          <line x1="40" y1="72" x2="80" y2="72"/>
          <line x1="48" y1="48" x2="72" y2="48"/>
          <line x1="48" y1="54" x2="72" y2="54"/>
        </g>
      </svg>
      <span class="specimen-tag">FDM · Maqueta</span>
    </div>
  </div>

  {/* MAIN card — vase, the iconic FDM showcase piece */}
  <div class="hero-card hero-card--main" aria-hidden="true">
    <div class="specimen-card specimen-card--vase">
      <svg viewBox="0 0 120 160" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="vase-grad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#a53a04"/>
            <stop offset="50%" stop-color="#c96b3a"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
          <linearGradient id="vase-base" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1a1a1a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        {/* Build plate */}
        <rect x="14" y="138" width="92" height="6" rx="1" fill="url(#vase-base)"/>
        {/* Vase silhouette (curved flask shape) */}
        <path
          d="M 42 138
             L 78 138
             C 76 130, 74 122, 76 114
             C 80 100, 86 88, 84 76
             C 82 64, 70 58, 70 50
             C 70 42, 74 36, 80 32
             L 80 26
             L 40 26
             L 40 32
             C 46 36, 50 42, 50 50
             C 50 58, 38 64, 36 76
             C 34 88, 40 100, 44 114
             C 46 122, 44 130, 42 138
             Z"
          fill="url(#vase-grad)"
        />
        {/* Layer lines */}
        <g stroke="rgba(255, 255, 255, 0.13)" stroke-width="0.6">
          <line x1="40" y1="40" x2="80" y2="40"/>
          <line x1="36" y1="56" x2="84" y2="56"/>
          <line x1="36" y1="72" x2="84" y2="72"/>
          <line x1="38" y1="88" x2="82" y2="88"/>
          <line x1="40" y1="104" x2="80" y2="104"/>
          <line x1="42" y1="120" x2="78" y2="120"/>
          <line x1="42" y1="132" x2="78" y2="132"/>
        </g>
      </svg>
      <span class="specimen-tag">FDM · Vase</span>
    </div>
  </div>

  {/* FRONT card — gear, mechanical functional part */}
  <div class="hero-card hero-card--front" aria-hidden="true">
    <div class="specimen-card specimen-card--gear">
      <svg viewBox="0 0 120 120" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="gear-grad" cx="0.5" cy="0.5" r="0.6">
            <stop offset="0%" stop-color="#c96b3a"/>
            <stop offset="100%" stop-color="#a53a04"/>
          </radialGradient>
          <linearGradient id="gear-base" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#1a1a1a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        {/* Build plate */}
        <rect x="14" y="96" width="92" height="6" rx="1" fill="url(#gear-base)"/>
        {/* Gear (10 teeth) generated as star-like polygon */}
        <g transform="translate(60, 56)">
          <path
            d="M 0,-34 L 6,-32 L 9,-26 L 18,-29 L 22,-23 L 27,-21 L 26,-12 L 32,-9 L 32,-3 L 32,3 L 32,9 L 26,12 L 27,21 L 22,23 L 18,29 L 9,26 L 6,32 L 0,34 L -6,32 L -9,26 L -18,29 L -22,23 L -27,21 L -26,12 L -32,9 L -32,3 L -32,-3 L -32,-9 L -26,-12 L -27,-21 L -22,-23 L -18,-29 L -9,-26 L -6,-32 Z"
            fill="url(#gear-grad)"
          />
          {/* Center hole */}
          <circle r="9" fill="#0a0a0a"/>
          {/* Layer hints (concentric arcs) */}
          <circle r="20" fill="none" stroke="rgba(255, 255, 255, 0.12)" stroke-width="0.6"/>
          <circle r="14" fill="none" stroke="rgba(255, 255, 255, 0.10)" stroke-width="0.5"/>
        </g>
      </svg>
      <span class="specimen-tag">FDM · Pieza</span>
    </div>
  </div>
</div>

<style>
  .hero-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 24px 56px rgba(20, 10, 4, 0.18),
      0 0 0 1px rgba(165, 58, 4, 0.06);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .specimen-card {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 100% 80% at 50% 110%, rgba(165, 58, 4, 0.08), transparent 70%),
      linear-gradient(180deg, #f6efe1 0%, #e9dfca 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: 12px;
    position: relative;
  }

  .specimen-svg {
    flex: 1 1 auto;
    width: 100%;
    height: auto;
    max-height: 78%;
    filter: drop-shadow(0 6px 12px rgba(20, 10, 4, 0.16));
  }

  .specimen-tag {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(20, 10, 4, 0.55);
    margin-top: 6px;
    flex-shrink: 0;
  }

  .hero-card--main {
    width: 70%;
    aspect-ratio: 4 / 5;
    top: 10%;
    left: 14%;
    z-index: 3;
    transform: rotate(-2deg);
  }

  .hero-card--back {
    width: 52%;
    aspect-ratio: 1 / 1;
    top: 0;
    right: 0;
    z-index: 1;
    transform: rotate(6deg);
    opacity: 0.95;
  }

  .hero-card--front {
    width: 50%;
    aspect-ratio: 1 / 1;
    bottom: 4%;
    left: 0;
    z-index: 4;
    transform: rotate(-6deg);
  }

  .hero-stack:hover .hero-card--main { transform: rotate(-1deg) translateY(-4px); }
  .hero-stack:hover .hero-card--back { transform: rotate(8deg) translateX(4px); }
  .hero-stack:hover .hero-card--front { transform: rotate(-7deg) translate(-4px, 4px); }

  @media (max-width: 540px) {
    .specimen-tag { font-size: 0.56rem; }
  }
</style>
