---
// 3D printing hero showcase — 3 illustrated specimen cards.
// Polished with lighting gradients, ground shadows, layer-line texture.
---

<div class="hero-stack">
  {/* BACK — gear (mechanical/functional piece, top-right) */}
  <div class="hero-card hero-card--back" aria-hidden="true">
    <div class="specimen-card">
      <svg viewBox="0 0 200 200" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="gear-grad" cx="0.4" cy="0.35" r="0.7">
            <stop offset="0%" stop-color="#e89570"/>
            <stop offset="40%" stop-color="#c96b3a"/>
            <stop offset="100%" stop-color="#7a2a02"/>
          </radialGradient>
          <radialGradient id="gear-hub" cx="0.5" cy="0.5" r="0.6">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </radialGradient>
          <linearGradient id="gear-plate" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        {/* Ground shadow */}
        <ellipse cx="100" cy="170" rx="54" ry="4" fill="rgba(20, 10, 4, 0.18)"/>
        {/* Build plate */}
        <rect x="18" y="166" width="164" height="6" rx="1" fill="url(#gear-plate)"/>
        {/* Gear — 12 teeth, beveled */}
        <g transform="translate(100, 100)">
          {/* Outer teeth */}
          <path
            d="M 0,-58
               L 9,-56 L 13,-46
               L 27,-50 L 31,-40 L 39,-39
               L 41,-25 L 50,-21 L 50,-12
               L 56,-6 L 56,6 L 50,12 L 50,21
               L 41,25 L 39,39 L 31,40 L 27,50
               L 13,46 L 9,56 L 0,58
               L -9,56 L -13,46 L -27,50
               L -31,40 L -39,39 L -41,25
               L -50,21 L -50,12 L -56,6 L -56,-6
               L -50,-12 L -50,-21 L -41,-25
               L -39,-39 L -31,-40 L -27,-50
               L -13,-46 L -9,-56 Z"
            fill="url(#gear-grad)"
          />
          {/* Inner ring (bevel illusion) */}
          <circle r="36" fill="none" stroke="rgba(255, 255, 255, 0.12)" stroke-width="1"/>
          <circle r="34" fill="none" stroke="rgba(20, 10, 4, 0.20)" stroke-width="0.6"/>
          {/* Center hub */}
          <circle r="14" fill="url(#gear-hub)"/>
          <circle r="14" fill="none" stroke="rgba(255, 255, 255, 0.15)" stroke-width="0.6"/>
          {/* Spokes (4) */}
          <g stroke="rgba(20, 10, 4, 0.30)" stroke-width="2.5" stroke-linecap="round" fill="none">
            <line x1="0" y1="-32" x2="0" y2="-18"/>
            <line x1="32" y1="0" x2="18" y2="0"/>
            <line x1="0" y1="32" x2="0" y2="18"/>
            <line x1="-32" y1="0" x2="-18" y2="0"/>
          </g>
        </g>
      </svg>
    </div>
  </div>

  {/* MAIN — vase (decorative/iconic FDM piece, dominant left) */}
  <div class="hero-card hero-card--main" aria-hidden="true">
    <div class="specimen-card">
      <svg viewBox="0 0 200 250" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="vase-grad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#e8946e"/>
            <stop offset="22%" stop-color="#c96b3a"/>
            <stop offset="55%" stop-color="#a53a04"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
          <linearGradient id="vase-plate" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        {/* Ground shadow */}
        <ellipse cx="100" cy="222" rx="42" ry="3.5" fill="rgba(20, 10, 4, 0.20)"/>
        {/* Build plate */}
        <rect x="18" y="218" width="164" height="6" rx="1" fill="url(#vase-plate)"/>
        {/* Vase silhouette — flask shape with gentle curves */}
        <path
          d="M 78 218
             L 122 218
             C 120 208 118 198 120 188
             C 122 174 128 160 126 146
             C 124 134 112 124 112 112
             C 112 100 118 92 124 86
             L 124 56
             C 124 44 120 34 114 28
             C 110 24 108 20 108 16
             L 92 16
             C 92 20 90 24 86 28
             C 80 34 76 44 76 56
             L 76 86
             C 82 92 88 100 88 112
             C 88 124 76 134 74 146
             C 72 160 78 174 80 188
             C 82 198 80 208 78 218 Z"
          fill="url(#vase-grad)"
        />
        {/* FDM layer lines */}
        <g stroke="rgba(255, 255, 255, 0.10)" stroke-width="0.55">
          <line x1="80" y1="34" x2="120" y2="34"/>
          <line x1="79" y1="48" x2="121" y2="48"/>
          <line x1="78" y1="62" x2="122" y2="62"/>
          <line x1="84" y1="76" x2="116" y2="76"/>
          <line x1="86" y1="90" x2="114" y2="90"/>
          <line x1="84" y1="104" x2="116" y2="104"/>
          <line x1="80" y1="118" x2="120" y2="118"/>
          <line x1="76" y1="132" x2="124" y2="132"/>
          <line x1="74" y1="146" x2="126" y2="146"/>
          <line x1="74" y1="160" x2="126" y2="160"/>
          <line x1="76" y1="174" x2="124" y2="174"/>
          <line x1="78" y1="188" x2="122" y2="188"/>
          <line x1="79" y1="202" x2="121" y2="202"/>
        </g>
        {/* Left-side highlight (specular hint) */}
        <path
          d="M 78 218
             C 80 208 82 198 80 188
             C 78 174 72 160 74 146
             C 76 134 88 124 88 112
             C 88 100 82 92 76 86
             L 76 56
             C 76 44 80 34 86 28
             C 90 24 92 20 92 16
             L 86 16
             C 84 22 82 28 78 32
             C 74 38 72 48 72 56
             L 72 88
             C 78 94 82 100 82 112
             C 82 124 70 134 68 146
             C 66 160 72 174 74 188
             C 76 198 74 208 72 218 Z"
          fill="rgba(255, 240, 220, 0.20)"
        />
      </svg>
    </div>
  </div>

  {/* FRONT — architectural model (small house with windows, bottom-left) */}
  <div class="hero-card hero-card--front" aria-hidden="true">
    <div class="specimen-card">
      <svg viewBox="0 0 200 200" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="arch-grad" x1="0" y1="0" x2="1" y2="0.3">
            <stop offset="0%" stop-color="#d97a48"/>
            <stop offset="55%" stop-color="#a53a04"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
          <linearGradient id="arch-roof" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#7a2a02"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
          <linearGradient id="arch-plate" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#2a2a2a"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
        </defs>
        {/* Ground shadow */}
        <ellipse cx="100" cy="170" rx="64" ry="4" fill="rgba(20, 10, 4, 0.18)"/>
        {/* Build plate */}
        <rect x="14" y="166" width="172" height="6" rx="1" fill="url(#arch-plate)"/>
        {/* Building base */}
        <rect x="46" y="92" width="108" height="74" fill="url(#arch-grad)"/>
        {/* Roof (gabled) */}
        <path d="M 38 92 L 100 56 L 162 92 Z" fill="url(#arch-roof)"/>
        {/* Roof line */}
        <line x1="38" y1="92" x2="162" y2="92" stroke="rgba(20, 10, 4, 0.40)" stroke-width="0.8"/>
        {/* Door */}
        <rect x="92" y="128" width="16" height="38" fill="rgba(20, 10, 4, 0.55)" rx="1"/>
        {/* Windows row 1 */}
        <rect x="58" y="106" width="14" height="14" fill="rgba(244, 236, 216, 0.65)" rx="1"/>
        <rect x="128" y="106" width="14" height="14" fill="rgba(244, 236, 216, 0.65)" rx="1"/>
        {/* Windows row 2 */}
        <rect x="58" y="132" width="14" height="14" fill="rgba(244, 236, 216, 0.55)" rx="1"/>
        <rect x="128" y="132" width="14" height="14" fill="rgba(244, 236, 216, 0.55)" rx="1"/>
        {/* Window cross-bars */}
        <g stroke="rgba(20, 10, 4, 0.40)" stroke-width="0.6">
          <line x1="58" y1="113" x2="72" y2="113"/>
          <line x1="65" y1="106" x2="65" y2="120"/>
          <line x1="128" y1="113" x2="142" y2="113"/>
          <line x1="135" y1="106" x2="135" y2="120"/>
          <line x1="58" y1="139" x2="72" y2="139"/>
          <line x1="65" y1="132" x2="65" y2="146"/>
          <line x1="128" y1="139" x2="142" y2="139"/>
          <line x1="135" y1="132" x2="135" y2="146"/>
        </g>
        {/* Layer lines */}
        <g stroke="rgba(255, 255, 255, 0.08)" stroke-width="0.5">
          <line x1="46" y1="106" x2="154" y2="106"/>
          <line x1="46" y1="124" x2="154" y2="124"/>
          <line x1="46" y1="142" x2="154" y2="142"/>
          <line x1="46" y1="160" x2="154" y2="160"/>
        </g>
      </svg>
    </div>
  </div>
</div>

<style>
  .hero-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 24px 56px rgba(20, 10, 4, 0.22),
      0 0 0 1px rgba(165, 58, 4, 0.06);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .specimen-card {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 90% 70% at 50% 30%, rgba(255, 255, 255, 0.55), transparent 70%),
      radial-gradient(ellipse 100% 80% at 50% 110%, rgba(165, 58, 4, 0.10), transparent 70%),
      linear-gradient(180deg, #f8f1e2 0%, #e8ddc6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px;
  }

  .specimen-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 6px 14px rgba(20, 10, 4, 0.18));
  }

  .hero-card--main {
    width: 60%;
    aspect-ratio: 4 / 5;
    top: 8%;
    left: 4%;
    z-index: 3;
    transform: rotate(-2deg);
  }

  .hero-card--back {
    width: 46%;
    aspect-ratio: 1 / 1;
    top: 0;
    right: 0;
    z-index: 1;
    transform: rotate(6deg);
    opacity: 0.96;
  }

  .hero-card--front {
    width: 50%;
    aspect-ratio: 1 / 1;
    bottom: 0;
    left: 22%;
    z-index: 4;
    transform: rotate(-5deg);
  }

  .hero-stack:hover .hero-card--main { transform: rotate(-1deg) translateY(-4px); }
  .hero-stack:hover .hero-card--back { transform: rotate(8deg) translateX(4px); }
  .hero-stack:hover .hero-card--front { transform: rotate(-6deg) translate(-4px, 4px); }
</style>
