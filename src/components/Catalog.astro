---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { SITE } from "../data/services";
import { CATALOG, CATALOG_CATEGORIES } from "../data/catalog";

interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = "Catálogo",
  subtitle = "Piezas que ya fabricamos, listas para pedir y personalizar. Cajas, huacales, dijes y más — hechos en Cancún. Agregamos cosas nuevas cada semana.",
} = Astro.props;

// Imágenes del catálogo (src/assets/catalogo/<id>.jpg)
const files = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/catalogo/*.jpg",
  { eager: true },
);
function img(id: string): ImageMetadata {
  const mod = files[`../assets/catalogo/${id}.jpg`];
  if (!mod) throw new Error(`Falta imagen de catálogo: ${id}.jpg`);
  return mod.default;
}

const fmt = (n: number) => n.toLocaleString("es-MX");
---

<section class="catalog" id="catalogo">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow" data-reveal>Pídelo hoy</p>
      <h2 class="section-title" data-reveal data-reveal-delay="0.06">{title}</h2>
      <p class="section-subtitle" data-reveal data-reveal-delay="0.12">{subtitle}</p>
    </div>

    <div class="catalog-filters" data-reveal data-reveal-delay="0.16" role="tablist" aria-label="Categorías">
      {CATALOG_CATEGORIES.map((c, i) => (
        <button
          type="button"
          class={`catalog-chip${i === 0 ? " active" : ""}`}
          data-filter={c.id}
        >
          {c.label}
        </button>
      ))}
    </div>

    <ul class="catalog-grid" role="list">
      {CATALOG.map((p, i) => (
        <li class="catalog-item" data-category={p.category} data-reveal data-reveal-delay={`${0.04 + (i % 4) * 0.05}`}>
          <article class="prod-card" data-tilt>
            <span class="prod-glare" aria-hidden="true"></span>
            <div class="prod-media">
              <Image
                src={img(p.id)}
                alt={p.name}
                widths={[280, 420, 560]}
                sizes="(max-width: 640px) 90vw, (max-width: 980px) 45vw, 280px"
                class="prod-img"
                loading={i < 4 ? "eager" : "lazy"}
              />
              <span class="prod-cat">{CATALOG_CATEGORIES.find((c) => c.id === p.category)?.label}</span>
            </div>
            <div class="prod-body">
              <h3 class="prod-name">{p.name}</h3>
              <p class="prod-desc">{p.desc}</p>
              <div class="prod-foot">
                <span class="prod-price">
                  {p.from && <span class="prod-from">Desde</span>}
                  <span class="prod-amount">${fmt(p.price)}</span>
                  <span class="prod-cur">MXN{p.unit ? ` ${p.unit}` : ""}</span>
                </span>
                <button
                  type="button"
                  class="prod-cta"
                  data-order={p.name}
                  data-price={p.price}
                  data-from={p.from ? "1" : ""}
                  data-unit={p.unit || ""}
                  aria-label={`Pedir ${p.name} por WhatsApp`}
                >
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
                  Pedir
                </button>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>

    <p class="catalog-note" data-reveal>
      Precios base. La personalización (nombre, logo, color) y los pedidos por volumen se cotizan al confirmar.
      ¿Buscas algo que no está aquí? <a href="#cotiza">Pídelo a la medida</a>.
    </p>
  </div>
</section>

<style>
  .catalog {
    background: var(--color-bg-alt);
    padding: 120px 0;
  }
  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 40px;
  }
  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 16px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 16px;
  }
  .section-subtitle {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── FILTROS ── */
  .catalog-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: 40px;
  }
  .catalog-chip {
    border: 1.5px solid var(--color-surface);
    background: var(--color-bg);
    color: var(--color-muted);
    border-radius: 999px;
    padding: 9px 18px;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .catalog-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .catalog-chip.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* ── GRID ── */
  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    list-style: none;
    perspective: 1400px;
  }
  .catalog-item.is-hidden { display: none; }

  .prod-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 16px;
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
    transform-style: preserve-3d;
    isolation: isolate;
    transition: border-color 0.3s ease, box-shadow 0.3s ease,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .prod-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 22px 48px rgba(20, 10, 4, 0.12);
  }
  .prod-glare {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: radial-gradient(circle 280px at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 240, 220, 0.30) 0%, rgba(255, 240, 220, 0.10) 25%, transparent 60%);
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
    border-radius: inherit;
  }
  .prod-card:hover .prod-glare { opacity: 1; }
  .prod-card > *:not(.prod-glare) { position: relative; z-index: 2; }

  .prod-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-tint);
  }
  .prod-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .prod-card:hover .prod-img { transform: scale(1.05); }
  .prod-cat {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(26, 15, 6, 0.72);
    color: var(--color-text-on-dark);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 4px 10px;
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }

  .prod-body {
    flex-grow: 1;
    padding: 18px 18px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .prod-name {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
  }
  .prod-desc {
    color: var(--color-muted);
    font-size: 0.8125rem;
    line-height: 1.55;
    flex-grow: 1;
  }
  .prod-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 10px;
    margin-top: 6px;
    padding-top: 14px;
    border-top: 1px solid var(--color-surface);
  }
  .prod-price { display: flex; flex-direction: column; line-height: 1.1; }
  .prod-from { font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); }
  .prod-amount { font-family: var(--font-display); font-size: 1.375rem; font-weight: 700; color: var(--color-accent); }
  .prod-cur { font-size: 0.625rem; color: var(--color-muted); letter-spacing: 0.04em; }

  .prod-cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: #25D366;
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 9px 15px;
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .prod-cta:hover { background: #1faa54; }
  .prod-cta:active { transform: scale(0.97); }

  .catalog-note {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.875rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 44px auto 0;
  }
  .catalog-note a { color: var(--color-accent); font-weight: 600; }

  @media (hover: none), (prefers-reduced-motion: reduce) {
    .prod-card { transform-style: flat; }
    .prod-glare { display: none; }
  }
  @media (max-width: 980px) {
    .catalog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .catalog { padding: 72px 0; }
    .catalog-grid { grid-template-columns: 1fr; perspective: none; gap: 16px; }
  }
</style>

<script>
  import { initCardTilt } from "../scripts/cardTilt";

  const WA_NUMBER = "529981888048";

  function init() {
    const section = document.getElementById("catalogo");
    if (!section || (section as any)._catInit) return;
    (section as any)._catInit = true;

    // Filtros por categoría
    const chips = section.querySelectorAll<HTMLElement>(".catalog-chip");
    const items = section.querySelectorAll<HTMLElement>(".catalog-item");
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const f = chip.dataset.filter || "todos";
        chips.forEach((c) => c.classList.toggle("active", c === chip));
        items.forEach((it) => {
          const show = f === "todos" || it.dataset.category === f;
          it.classList.toggle("is-hidden", !show);
        });
      });
    });

    // Pedir por WhatsApp
    section.querySelectorAll<HTMLElement>(".prod-cta").forEach((btn) => {
      btn.addEventListener("click", () => {
        const name = btn.dataset.order || "";
        const price = btn.dataset.price || "";
        const from = btn.dataset.from === "1";
        const unit = btn.dataset.unit || "";
        const priceStr = price
          ? ` (${from ? "desde " : ""}$${Number(price).toLocaleString("es-MX")} MXN${unit ? " " + unit : ""})`
          : "";
        const msg = encodeURIComponent(
          `Hola Lumo 👋 Me interesa este producto del catálogo:\n\n• ${name}${priceStr}\n\n¿Me pasas disponibilidad y opciones de personalización?`,
        );
        window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, "_blank");
      });
    });

    initCardTilt(".prod-card[data-tilt]");
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
