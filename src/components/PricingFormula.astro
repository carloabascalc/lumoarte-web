---
// "¿Cómo calculamos tu precio?" — sección de transparencia de precios.
// El contenido viene de src/data/pricing.ts según el servicio. Láser trae
// cifras reales (de la Fórmula de Adriano); 3D y gran formato describen el
// modelo sin cifras exactas hasta que Adriano las confirme.
import { PRICING } from "../data/pricing";

interface Props {
  /** id del servicio (clave en PRICING). */
  serviceId: string;
  /** PDF de la lista de precios — solo se usa si el contenido lo permite. */
  preciosPdf?: string;
}

const { serviceId, preciosPdf } = Astro.props;
const content = PRICING[serviceId];
if (!content) throw new Error(`Sin contenido de precios para: ${serviceId}`);

const { intro, tipos, flow, componentes, tarifas, hasPriceList, formulaPdf } = content;
const showPriceList = !!(hasPriceList && preciosPdf);
---

<section class="pricing-formula section" id="como-cotizamos">
  <div class="container">
    <div class="section-header">
      <p class="pf-eyebrow" data-reveal>Precios transparentes</p>
      <h2 class="section-title" data-reveal data-reveal-delay="0.06">
        ¿Cómo calculamos tu precio?
      </h2>
      <p class="section-subtitle" data-reveal data-reveal-delay="0.12">{intro}</p>
    </div>

    <!-- Tipos de trabajo -->
    <div class="pf-tipos" data-reveal data-reveal-delay="0.06">
      {tipos.map((t) => (
        <div class="pf-tipo" style={`--tip-accent:${t.accent}`}>
          <span class="pf-tipo-n">{t.n}</span>
          <h3 class="pf-tipo-title">{t.title}</h3>
          <p class="pf-tipo-desc">{t.desc}</p>
          <span class="pf-tipo-tag">{t.tag}</span>
        </div>
      ))}
    </div>

    <!-- Fórmula -->
    <div class="pf-flow" data-reveal data-reveal-delay="0.06" role="list" aria-label="Componentes del precio">
      {flow.map((f, i) => (
        <>
          <span class="pf-chip" role="listitem">{f}</span>
          <span class="pf-op" aria-hidden="true">+</span>
        </>
      ))}
      <span class="pf-op pf-op--eq" aria-hidden="true">=</span>
      <span class="pf-chip pf-chip--final" role="listitem">Precio final</span>
    </div>

    <!-- Detalle -->
    <div class="pf-grid">
      {componentes.map((c, i) => (
        <div class="pf-card" data-reveal data-reveal-delay={`${0.04 + i * 0.05}`}>
          <h4 class="pf-card-name">{c.name}</h4>
          <ul class="pf-card-list" role="list">
            {c.points.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      ))}
    </div>

    <!-- Tarifas (solo cuando hay cifras reales) -->
    {tarifas && (
      <div class="pf-tarifas" data-reveal data-reveal-delay="0.1">
        <span class="pf-tarifas-label">Tarifas</span>
        <p class="pf-tarifas-body" set:html={tarifas} />
      </div>
    )}

    <div class="pf-actions" data-reveal data-reveal-delay="0.12">
      {showPriceList ? (
        <a class="pf-btn pf-btn--primary" href={preciosPdf} target="_blank" rel="noopener noreferrer">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Lista de precios por material
        </a>
      ) : (
        <a class="pf-btn pf-btn--primary" href="#cotiza">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          Solicita tu cotización
        </a>
      )}
      {formulaPdf && (
        <a class="pf-btn" href={formulaPdf} target="_blank" rel="noopener noreferrer">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Guía de precios (PDF)
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .pricing-formula {
    background: var(--color-bg);
  }

  .pf-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  /* ── Tipos de trabajo ── */
  .pf-tipos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 56px;
  }

  .pf-tipo {
    position: relative;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-radius: 10px;
    padding: 26px 24px 24px;
    overflow: hidden;
  }

  .pf-tipo::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--tip-accent);
  }

  .pf-tipo-n {
    display: block;
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--tip-accent);
    margin-bottom: 14px;
  }

  .pf-tipo-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .pf-tipo-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 16px;
  }

  .pf-tipo-tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--tip-accent);
    padding: 5px 11px;
    border-radius: 999px;
  }

  /* ── Fórmula (flow) ── */
  .pf-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 40px;
  }

  .pf-chip {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    background: var(--color-bg-alt);
    border: 1.5px solid var(--color-surface);
    border-radius: 8px;
    padding: 13px 20px;
  }

  .pf-chip--final {
    color: #fff;
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .pf-op {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .pf-op--eq {
    color: var(--color-accent);
  }

  /* ── Detalle ── */
  .pf-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }

  .pf-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-radius: 10px;
    padding: 24px 22px;
  }

  .pf-card-name {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-surface);
  }

  .pf-card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pf-card-list li {
    position: relative;
    padding-left: 18px;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .pf-card-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* ── Tarifas ── */
  .pf-tarifas {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    background: var(--color-bg-clay);
    border-radius: 10px;
    padding: 20px 26px;
    margin-bottom: 32px;
  }

  .pf-tarifas-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent-honey);
    flex-shrink: 0;
  }

  .pf-tarifas-body {
    font-size: 0.9375rem;
    color: var(--color-text-on-dark);
    margin: 0;
  }

  .pf-tarifas-body strong {
    color: #fff;
    font-weight: 600;
  }

  .pf-tarifas-note {
    color: var(--color-accent-honey);
    font-size: 0.8125rem;
  }

  /* ── Acciones ── */
  .pf-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .pf-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 22px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 7px;
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .pf-btn:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .pf-btn--primary {
    background: var(--color-accent);
    color: #fff;
  }

  .pf-btn--primary:hover {
    background: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
  }

  /* ── Responsive ── */
  @media (max-width: 880px) {
    .pf-tipos {
      grid-template-columns: 1fr;
    }
    .pf-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .pf-grid {
      grid-template-columns: 1fr;
    }
    .pf-chip,
    .pf-op {
      font-size: 0.8125rem;
      padding: 10px 14px;
    }
    .pf-btn {
      flex: 1 1 auto;
      justify-content: center;
    }
  }
</style>
