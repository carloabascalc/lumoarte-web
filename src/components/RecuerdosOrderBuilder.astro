  }
</style>

<!-- Estilos para nodos generados por JS (bundles, nombres, add-ons). El CSS
     scoped de Astro no alcanza el DOM inyectado por script, así que estos van
     globales pero namespaced bajo .ob-card para no filtrarse a otros componentes. -->
<style is:global>
  /* nombres */
  .ob-card .name-input-row { display: flex; flex-direction: column; gap: 7px; position: relative; }
  .ob-card .name-input-row label { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); }
  .ob-card .name-input-row input { width: 100%; padding: 12px 48px 12px 14px; border: 2px solid var(--color-surface); border-radius: 10px; background: var(--color-bg); color: var(--color-text); font-size: 1rem; font-weight: 700; font-family: inherit; outline: none; text-transform: uppercase; transition: border-color 0.15s ease; }
  .ob-card .name-input-row input:focus { border-color: var(--color-accent); }
  .ob-card .name-input-row .char-count { position: absolute; right: 14px; bottom: 13px; font-size: 0.6875rem; color: var(--color-muted); }

  /* bundles */
  .ob-card .bundle-option { width: 100%; border: 2px solid var(--color-surface); border-radius: 12px; background: var(--color-bg); padding: 13px 16px; cursor: pointer; font-family: inherit; display: flex; align-items: center; justify-content: space-between; text-align: left; transition: border-color 0.2s ease; }
  .ob-card .bundle-option:hover { border-color: var(--color-accent); }
  .ob-card .bundle-option.selected { border-color: var(--color-accent); background: rgba(165, 58, 4, 0.10); }
  .ob-card .b-left { display: flex; flex-direction: column; gap: 2px; }
  .ob-card .b-qty { font-weight: 700; font-size: 0.9375rem; color: var(--color-text); }
  .ob-card .b-save { font-size: 0.75rem; color: #1f9d55; font-weight: 600; }
  .ob-card .b-right { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 1px; }
  .ob-card .b-price { font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; color: var(--color-accent); }
  .ob-card .b-unit { font-size: 0.6875rem; color: var(--color-muted); }
  .ob-card .b-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: 0.625rem; font-weight: 700; padding: 2px 7px; border-radius: 8px; margin-top: 2px; }

  /* add-ons */
  .ob-card .addon-card { border: 1px solid var(--color-surface); border-radius: 14px; overflow: hidden; margin-bottom: 14px; background: var(--color-bg); }
  .ob-card .addon-head { background: linear-gradient(150deg, var(--color-bg-ink), var(--color-bg-clay)); padding: 12px 16px; display: flex; align-items: center; gap: 12px; }
  .ob-card .addon-emoji { font-size: 1.5rem; }
  .ob-card .addon-head-label { color: rgba(245, 233, 216, 0.45); font-size: 0.625rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .ob-card .addon-head-name { color: var(--color-text-on-dark); font-weight: 800; font-size: 1.125rem; letter-spacing: 0.08em; }
  .ob-card .addon-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-top: 1px solid var(--color-surface); cursor: pointer; transition: background 0.15s ease; }
  .ob-card .addon-row:hover { background: rgba(165, 58, 4, 0.06); }
  .ob-card .addon-row.sel { background: rgba(165, 58, 4, 0.10); }
  .ob-card .addon-row-left { display: flex; align-items: center; gap: 12px; }
  .ob-card .addon-row-emoji { font-size: 1.35rem; }
  .ob-card .addon-row-name { font-weight: 600; font-size: 0.875rem; color: var(--color-text); }
  .ob-card .addon-row-desc { font-size: 0.75rem; color: var(--color-muted); }
  .ob-card .addon-row-right { display: flex; align-items: center; gap: 10px; }
  .ob-card .addon-price { font-weight: 700; font-size: 0.875rem; color: var(--color-accent); }
  .ob-card .addon-check { width: 24px; height: 24px; border-radius: 50%; border: 2px solid var(--color-surface); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.7rem; font-weight: 700; flex-shrink: 0; transition: all 0.2s ease; }
  .ob-card .addon-row.sel .addon-check { background: var(--color-accent); border-color: var(--color-accent); }
</style>

<script>
  const WA_NUMBER = "529981888048";

  type Addon = { opener: boolean; airtag: boolean };
  type Lang = "es" | "en";
  interface State {
    product: string | null;
    bundle: number;
    names: string[];
    addons: Addon[];
    termo: { withCancun: boolean; withName: boolean; name: string };
    delivery: string;
    currentPanel: string;
    lang: Lang;
  }

  const BUNDLE_PRICES: Record<number, number> = { 1: 11, 2: 20, 3: 29, 4: 35, 5: 40 };
  const SAVINGS: Record<number, number> = { 1: 0, 2: 2, 3: 4, 4: 9, 5: 15 };
  const DESIGN_NAMES: Record<Lang, Record<string, string>> = {
    es: { mar: "Mar 🌊", tropical: "Tropical 🦜", maya: "Maya 🏛️", fiesta: "Fiesta 🌮" },
    en: { mar: "Ocean 🌊", tropical: "Tropical 🦜", maya: "Maya 🏛️", fiesta: "Fiesta 🌮" },
  };
  const DESIGN_EMOJI: Record<string, string> = { mar: "🌊", tropical: "🦜", maya: "🏛️", fiesta: "🌮" };

  // Diccionario para el contenido que genera el JS (el HTML estático usa data-es/data-en).
  const T = {
    es: {
      keychain: (n: number) => `${n} ${n === 1 ? "Llavero" : "Llaveros"}`,
      save: (v: number) => `Ahorras $${v}`,
      each: (v: string) => `$${v} c/u`,
      bestDeal: "1 GRATIS + Ahorras $4",
      bestPrice: "Mejor precio",
      nameLabel: (n: number) => `Llavero ${n} — nombre`,
      namePh: "ej. CARLOS",
      kcLabel: (n: number) => `Llavero ${n}`,
      opener: "Destapador", openerDesc: "Integrado en el llavero",
      airtag: "Soporte AirTag", airtagDesc: "Nunca pierdas tus llaves",
      coasters: "Set de 5 portavasos",
      cup: "Termo 20oz",
      delHotel: "Gratis 🏨", delPickup: "Recoger 🏪", delShip: "FedEx 📦",
      saved: (v: number) => `🎉 ¡Ahorraste $${v} USD!`,
      alertProduct: "Por favor elige un producto.",
      alertNames: "Por favor ingresa todos los nombres.",
      alertZone: "Por favor selecciona tu zona de entrega.",
      alertOutside: 'La entrega a hotel solo cubre Cancún y Riviera Maya. Elige “Envío a casa” para otras zonas.',
      alertHotel: "Por favor escribe tu hotel.",
      alertContact: "Por favor ingresa tu nombre y WhatsApp.",
    },
    en: {
      keychain: (n: number) => `${n} ${n === 1 ? "Keychain" : "Keychains"}`,
      save: (v: number) => `Save $${v}`,
      each: (v: string) => `$${v} each`,
      bestDeal: "1 FREE + Save $4",
      bestPrice: "Best deal",
      nameLabel: (n: number) => `Keychain ${n} — name`,
      namePh: "e.g. CARLOS",
      kcLabel: (n: number) => `Keychain ${n}`,
      opener: "Bottle opener", openerDesc: "Built into the keychain",
      airtag: "AirTag holder", airtagDesc: "Never lose your keys",
      coasters: "Set of 5 coasters",
      cup: "Thermal cup 20oz",
      delHotel: "Free 🏨", delPickup: "Pickup 🏪", delShip: "FedEx 📦",
      saved: (v: number) => `🎉 You saved $${v} USD!`,
      alertProduct: "Please choose a product.",
      alertNames: "Please enter all names.",
      alertZone: "Please select your delivery zone.",
      alertOutside: 'Hotel delivery only covers Cancún and the Riviera Maya. Choose “Ship home” for other areas.',
      alertHotel: "Please type your hotel.",
      alertContact: "Please enter your name and WhatsApp number.",
    },
  };

  const FLOWS: Record<string, string[]> = {
    keychain: ["panel-product", "panel-names", "panel-addons", "panel-delivery", "panel-summary"],
    termo: ["panel-product", "panel-termo", "panel-delivery", "panel-summary"],
    portavasos: ["panel-product", "panel-delivery", "panel-summary"],
  };

  function init() {
    const root = document.getElementById("pedido");
    if (!root || (root as any)._obInit) return;
    (root as any)._obInit = true;

    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T | null;

    const state: State = {
      product: null,
      bundle: 1,
      names: [""],
      addons: [{ opener: false, airtag: false }],
      termo: { withCancun: false, withName: false, name: "" },
      delivery: "hotel",
      currentPanel: "panel-product",
      lang: "es",
    };
    const tr = () => T[state.lang];

    const getFlow = () =>
      state.product === "termo" ? FLOWS.termo :
      state.product === "portavasos" ? FLOWS.portavasos :
      FLOWS.keychain;
    const flowIndex = () => getFlow().indexOf(state.currentPanel);

    function calcTotal(): number {
      if (!state.product) return 11;
      if (state.product === "portavasos") return 15;
      if (state.product === "termo") {
        const both = state.termo.withCancun && state.termo.withName;
        const one = state.termo.withCancun || state.termo.withName;
        return both ? 20 : one ? 18 : 15;
      }
      let total = BUNDLE_PRICES[state.bundle] || 11;
      state.addons.forEach((a) => { if (a.opener) total += 1; if (a.airtag) total += 4; });
      return total;
    }

    // ── steps dots ──
    function renderDots() {
      const cont = $("obSteps");
      if (!cont) return;
      const flow = getFlow();
      const idx = flowIndex();
      cont.innerHTML = flow
        .map((_, i) => `<span class="ob-dot${i < idx ? " done" : i === idx ? " active" : ""}"></span>`)
        .join("");
    }

    function showPanel(id: string) {
      document.querySelectorAll(".ob-panel").forEach((p) => p.classList.remove("ob-visible"));
      $(id)?.classList.add("ob-visible");
      state.currentPanel = id;
      renderDots();
      updateFooter();
      root!.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function updateFooter() {
      const isFirst = flowIndex() === 0;
      const isLast = flowIndex() === getFlow().length - 1;
      $("btnBack")?.classList.toggle("ob-hidden", isFirst);
      const fp = $("footerPrice");
      if (fp) fp.textContent = "$" + calcTotal() + " USD";
      const next = $<HTMLButtonElement>("btnNext");
      if (next) {
        next.classList.toggle("ob-hidden", isLast);
        next.disabled = !state.product && state.currentPanel === "panel-product";
      }
    }

    // ── validation ──
    function validateCurrent(): boolean {
      const p = state.currentPanel;
      const L = tr();
      if (p === "panel-product" && !state.product) { alert(L.alertProduct); return false; }
      if (p === "panel-names") {
        const filled = state.names.slice(0, state.bundle).filter((n) => n.trim().length > 0);
        if (filled.length < state.bundle) { alert(L.alertNames); return false; }
      }
      if (p === "panel-delivery" && state.delivery === "hotel") {
        const zone = $<HTMLSelectElement>("hotelZone")?.value || "";
        if (!zone) { alert(L.alertZone); return false; }
        if (zone === "outside") { alert(L.alertOutside); return false; }
        if (!($("hotelName") as HTMLInputElement)?.value.trim()) { alert(L.alertHotel); return false; }
      }
      return true;
    }

    function nextStep() {
      if (!validateCurrent()) return;
      const flow = getFlow();
      const idx = flowIndex();
      if (idx < flow.length - 1) {
        const next = flow[idx + 1];
        if (next === "panel-addons") renderAddons();
        if (next === "panel-summary") buildSummary();
        showPanel(next);
      }
    }
    function prevStep() {
      const flow = getFlow();
      const idx = flowIndex();
      if (idx > 0) showPanel(flow[idx - 1]);
    }

    // ── product select ──
    function selectProduct(p: string) {
      state.product = p;
      document.querySelectorAll(".design-card, .wide-card").forEach((c) => c.classList.remove("selected"));
      $("cat-" + p)?.classList.add("selected");
      state.bundle = 1;
      state.names = [""];
      state.addons = [{ opener: false, airtag: false }];
      state.termo = { withCancun: false, withName: false, name: "" };
      // reset name UI for keychains
      if (FLOWS.keychain.includes("panel-names")) { renderBundles(); syncNameInputs(); }
      renderDots();
      updateFooter();
    }

    // ── bundles + names ──
    function renderBundles() {
      const cont = $("bundleRow");
      if (!cont) return;
      const L = tr();
      const defs = [
        { n: 1, label: L.keychain(1), save: "", price: 11, unit: "USD", badge: "" },
        { n: 2, label: L.keychain(2), save: L.save(2), price: 20, unit: L.each("10"), badge: "" },
        { n: 3, label: L.keychain(3), save: L.save(4), price: 29, unit: L.each("9.67"), badge: "" },
        { n: 4, label: L.keychain(4), save: L.save(9), price: 35, unit: L.each("8.75"), badge: "" },
        { n: 5, label: L.keychain(5) + " 🔥", save: L.bestDeal, price: 40, unit: L.bestPrice, badge: "TOP" },
      ];
      cont.innerHTML = defs
        .map(
          (d) => `
        <button type="button" class="bundle-option${d.n === state.bundle ? " selected" : ""}" data-bundle="${d.n}">
          <span class="b-left">
            <span class="b-qty">${d.label}</span>
            ${d.save ? `<span class="b-save">${d.save}</span>` : ""}
          </span>
          <span class="b-right">
            <span class="b-price">$${d.price}</span>
            <span class="b-unit">${d.unit}</span>
            ${d.badge ? `<span class="b-badge">${d.badge}</span>` : ""}
          </span>
        </button>`
        )
        .join("");
      cont.querySelectorAll<HTMLElement>(".bundle-option").forEach((b) =>
        b.addEventListener("click", () => selectBundle(Number(b.dataset.bundle)))
      );
    }

    function selectBundle(n: number) {
      state.bundle = n;
      document.querySelectorAll(".bundle-option").forEach((b) => b.classList.remove("selected"));
      document.querySelector(`.bundle-option[data-bundle="${n}"]`)?.classList.add("selected");
      syncNameInputs();
      updateFooter();
    }

    function syncNameInputs() {
      const cont = $("nameInputs");
      if (!cont) return;
      while (state.names.length < state.bundle) state.names.push("");
      while (state.names.length > state.bundle) state.names.pop();
      while (state.addons.length < state.bundle) state.addons.push({ opener: false, airtag: false });
      while (state.addons.length > state.bundle) state.addons.pop();
      cont.innerHTML = "";
      for (let i = 0; i < state.bundle; i++) {
        const L = tr();
        const row = document.createElement("div");
        row.className = "name-input-row";
        row.innerHTML = `
          <label>${L.nameLabel(i + 1)}</label>
          <input type="text" maxlength="15" placeholder="${L.namePh}" value="${state.names[i] || ""}" />
          <span class="char-count">${(state.names[i] || "").length}/15</span>`;
        const input = row.querySelector("input")!;
        const count = row.querySelector(".char-count")!;
        input.addEventListener("input", () => {
          input.value = input.value.toUpperCase();
          state.names[i] = input.value;
          count.textContent = input.value.length + "/15";
          if (i === 0) updatePreview();
        });
        cont.appendChild(row);
      }
      updatePreview();
    }

    function updatePreview() {
      const el = $("previewName");
      if (el) el.textContent = state.names[0] || "—";
    }

    // ── add-ons ──
    function renderAddons() {
      const cont = $("addonsList");
      if (!cont) return;
      const emoji = DESIGN_EMOJI[state.product || ""] || "🔑";
      const L = tr();
      cont.innerHTML = "";
      for (let i = 0; i < state.bundle; i++) {
        const a = state.addons[i];
        const name = state.names[i] || "—";
        const card = document.createElement("div");
        card.className = "addon-card";
        card.innerHTML = `
          <div class="addon-head">
            <span class="addon-emoji">${emoji}</span>
            <span>
              <span class="addon-head-label">${L.kcLabel(i + 1)}</span>
              <span class="addon-head-name" style="display:block">${name}</span>
            </span>
          </div>
          <div class="addon-row${a.opener ? " sel" : ""}" data-i="${i}" data-key="opener">
            <span class="addon-row-left">
              <span class="addon-row-emoji">🍺</span>
              <span><span class="addon-row-name" style="display:block">${L.opener}</span><span class="addon-row-desc">${L.openerDesc}</span></span>
            </span>
            <span class="addon-row-right"><span class="addon-price">+$1</span><span class="addon-check">${a.opener ? "✓" : ""}</span></span>
          </div>
          <div class="addon-row${a.airtag ? " sel" : ""}" data-i="${i}" data-key="airtag">
            <span class="addon-row-left">
              <span class="addon-row-emoji">📍</span>
              <span><span class="addon-row-name" style="display:block">${L.airtag}</span><span class="addon-row-desc">${L.airtagDesc}</span></span>
            </span>
            <span class="addon-row-right"><span class="addon-price">+$4</span><span class="addon-check">${a.airtag ? "✓" : ""}</span></span>
          </div>`;
        cont.appendChild(card);
      }
      cont.querySelectorAll<HTMLElement>(".addon-row").forEach((row) =>
        row.addEventListener("click", () => {
          const i = Number(row.dataset.i);
          const key = row.dataset.key as "opener" | "airtag";
          state.addons[i][key] = !state.addons[i][key];
          const on = state.addons[i][key];
          row.classList.toggle("sel", on);
          const chk = row.querySelector(".addon-check")!;
          chk.textContent = on ? "✓" : "";
          updateFooter();
        })
      );
    }

    // ── termo ──
    function toggleTermo(key: "cancun" | "name") {
      const prop = key === "cancun" ? "withCancun" : "withName";
      state.termo[prop] = !state.termo[prop];
      const on = state.termo[prop];
      $("topt-" + key)?.classList.toggle("selected", on);
      if (key === "name") {
        $("termoNameWrap")?.classList.toggle("ob-hidden", !on);
        if (!on) state.termo.name = "";
      }
      updateTermoPreview();
      updateFooter();
    }
    function updateTermoPreview() {
      $("tep-cancun")?.classList.toggle("dim", !state.termo.withCancun);
      const nameEl = $("tep-name");
      nameEl?.classList.toggle("dim", !state.termo.withName);
      if (nameEl) nameEl.textContent = state.termo.name || (state.termo.withName ? "…" : "—");
      const tag = $("termoPriceTag");
      if (tag) tag.textContent = "$" + calcTotal() + " USD";
    }

    // ── delivery ──
    function selectDelivery(type: string) {
      state.delivery = type;
      document.querySelectorAll(".delivery-opt").forEach((d) => d.classList.remove("selected"));
      $("del-" + type)?.classList.add("selected");
      $("hotelFields")?.classList.toggle("ob-hidden", type !== "hotel");
      $("addressFields")?.classList.toggle("ob-hidden", type !== "address");
      $("pickupFields")?.classList.toggle("ob-hidden", type !== "pickup");
    }

    function checkZone() {
      const zone = $<HTMLSelectElement>("hotelZone")?.value || "";
      $("zoneWarning")?.classList.toggle("ob-hidden", zone !== "outside");
    }
    function validateHotel() {
      const input = $<HTMLInputElement>("hotelName");
      if (!input) return;
      const val = input.value.trim();
      if (!val) { input.style.borderColor = ""; $("hotelError")?.classList.add("ob-hidden"); return; }
      const opts = Array.from(document.querySelectorAll("#hotelList option")).map((o) => (o as HTMLOptionElement).value.toLowerCase());
      const ok = opts.includes(val.toLowerCase());
      input.style.borderColor = ok ? "#1f9d55" : "#e0a000";
      $("hotelError")?.classList.toggle("ob-hidden", ok || val.length < 3);
    }

    // ── summary ──
    function buildSummary() {
      const total = calcTotal();
      const L = tr();
      let productLabel = "", basePrice = total;

      if (state.product === "portavasos") {
        productLabel = L.coasters;
      } else if (state.product === "termo") {
        const eng: string[] = [];
        if (state.termo.withCancun) eng.push("CANCUN");
        if (state.termo.withName && state.termo.name) eng.push(state.termo.name);
        productLabel = L.cup + (eng.length ? " · " + eng.join(" + ") : "");
      } else {
        const names = state.names.slice(0, state.bundle).filter(Boolean).join(", ");
        productLabel = `${state.bundle}× ${DESIGN_NAMES[state.lang][state.product || ""]} · ${names}`;
        basePrice = BUNDLE_PRICES[state.bundle];
      }
      ($("sumProduct") as HTMLElement).textContent = productLabel;
      ($("sumBasePrice") as HTMLElement).textContent = "$" + basePrice + " USD";

      // add-ons
      const lines: string[] = [];
      let addonCost = 0;
      state.addons.slice(0, state.bundle).forEach((a, i) => {
        const parts: string[] = [];
        if (a.opener) { parts.push(L.opener); addonCost += 1; }
        if (a.airtag) { parts.push("AirTag"); addonCost += 4; }
        if (parts.length) lines.push(`#${i + 1} ${state.names[i] || ""}: ${parts.join(" + ")}`);
      });
      const addonRow = $("sumAddonRow");
      if (lines.length && state.product !== "termo" && state.product !== "portavasos") {
        addonRow?.classList.remove("ob-hidden");
        ($("sumAddonLabel") as HTMLElement).textContent = lines.join(" · ");
        ($("sumAddonPrice") as HTMLElement).textContent = "+$" + addonCost + " USD";
      } else {
        addonRow?.classList.add("ob-hidden");
      }

      const delLabel = state.delivery === "hotel" ? L.delHotel : state.delivery === "pickup" ? L.delPickup : L.delShip;
      ($("sumDelivery") as HTMLElement).textContent = delLabel;
      ($("sumTotal") as HTMLElement).textContent = "$" + total + " USD";

      const savings = SAVINGS[state.bundle] || 0;
      const note = $("savingsNote");
      if (savings > 0 && state.product !== "termo" && state.product !== "portavasos") {
        note?.classList.remove("ob-hidden");
        if (note) note.textContent = L.saved(savings);
      } else {
        note?.classList.add("ob-hidden");
      }
    }

    // ── submit → WhatsApp ──
    function submitOrder() {
      const name = ($("clientName") as HTMLInputElement)?.value.trim() || "";
      const phone = ($("clientPhone") as HTMLInputElement)?.value.trim() || "";
      const email = ($("clientEmail") as HTMLInputElement)?.value.trim() || "";
      if (!name || !phone) { alert(tr().alertContact); return; }

      const total = calcTotal();
      const hotel = ($("hotelName") as HTMLInputElement)?.value.trim() || "";
      const room = ($("roomNumber") as HTMLInputElement)?.value.trim() || "";
      const zone = ($("hotelZone") as HTMLSelectElement)?.value || "";
      const country = ($("addrCountry") as HTMLInputElement)?.value.trim() || "";
      const street = ($("addrStreet") as HTMLInputElement)?.value.trim() || "";

      let deliveryLine = "";
      if (state.delivery === "hotel") deliveryLine = `Hotel: ${hotel}${room ? " · Hab " + room : ""}${zone ? " (" + zone + ")" : ""}`;
      else if (state.delivery === "pickup") deliveryLine = "Recoge en el taller";
      else deliveryLine = `Envío a casa: ${country}${street ? " — " + street : ""}`;

      let productLine = "";
      if (state.product === "portavasos") {
        productLine = "🥂 Set de 5 portavasos";
      } else if (state.product === "termo") {
        const eng: string[] = [];
        if (state.termo.withCancun) eng.push("CANCUN");
        if (state.termo.withName && state.termo.name) eng.push(state.termo.name);
        productLine = `☕ Termo 20oz${eng.length ? " | Grabado: " + eng.join(" + ") : " | Sin grabado"}`;
      } else {
        const addonDetail = state.addons.slice(0, state.bundle).map((a, i) => {
          const p = [a.opener ? "Destapador" : "", a.airtag ? "AirTag" : ""].filter(Boolean);
          return p.length ? `#${i + 1}${state.names[i] ? " " + state.names[i] : ""}: ${p.join("+")}` : null;
        }).filter(Boolean).join(", ") || "Ninguno";
        productLine = `🔑 ${state.bundle}× ${DESIGN_NAMES.es[state.product || ""]} llavero\n👤 Nombres: ${state.names.slice(0, state.bundle).join(", ")}\n➕ Extras: ${addonDetail}`;
      }

      const msg = encodeURIComponent(
        [
          "🌊 NUEVO PEDIDO LUMO",
          "━━━━━━━━━━━━━━━",
          productLine,
          "━━━━━━━━━━━━━━━",
          `🚚 ${deliveryLine}`,
          "━━━━━━━━━━━━━━━",
          `👤 ${name}`,
          `📱 ${phone}`,
          `📧 ${email || "—"}`,
          "━━━━━━━━━━━━━━━",
          `💰 TOTAL: $${total} USD`,
        ].join("\n")
      );
      window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, "_blank");
    }

    // ── language ──
    function setLang(lang: Lang) {
      state.lang = lang;
      // texto estático
      root!.querySelectorAll<HTMLElement>("[data-es]").forEach((el) => {
        const v = el.getAttribute("data-" + lang);
        if (v != null) el.innerHTML = v;
      });
      // placeholders
      root!.querySelectorAll<HTMLInputElement>("[data-es-ph]").forEach((el) => {
        const v = el.getAttribute("data-" + lang + "-ph");
        if (v != null) el.placeholder = v;
      });
      const lbl = $("obLangLabel");
      if (lbl) lbl.textContent = lang === "es" ? "EN" : "ES";
      // contenido dinámico (lo genera el JS, no lo cubren los data-*)
      if (state.product && state.product !== "termo" && state.product !== "portavasos") {
        renderBundles();
        syncNameInputs();
      }
      if (state.currentPanel === "panel-addons") renderAddons();
      if (state.currentPanel === "panel-summary") buildSummary();
      updateTermoPreview();
    }

    // ── wire static elements ──
    $("obLang")?.addEventListener("click", () => setLang(state.lang === "es" ? "en" : "es"));
    document.querySelectorAll<HTMLElement>("[data-product]").forEach((el) =>
      el.addEventListener("click", () => selectProduct(el.dataset.product!))
    );
    document.querySelectorAll<HTMLElement>("[data-termo]").forEach((el) =>
      el.addEventListener("click", () => toggleTermo(el.dataset.termo as "cancun" | "name"))
    );
    document.querySelectorAll<HTMLElement>("[data-delivery]").forEach((el) =>
      el.addEventListener("click", () => selectDelivery(el.dataset.delivery!))
    );
    $("hotelZone")?.addEventListener("change", checkZone);
    $("hotelName")?.addEventListener("input", validateHotel);
    $("hotelName")?.addEventListener("blur", validateHotel);
    const termoField = $<HTMLInputElement>("termoNameField");
    termoField?.addEventListener("input", () => {
      termoField.value = termoField.value.toUpperCase();
      state.termo.name = termoField.value;
      const c = $("termoNameCount");
      if (c) c.textContent = termoField.value.length + "/15";
      updateTermoPreview();
    });
    $("btnNext")?.addEventListener("click", nextStep);
    $("btnBack")?.addEventListener("click", prevStep);
    $("btnSubmit")?.addEventListener("click", submitOrder);

    renderDots();
    updateFooter();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
