---
// RecuerdosOrderBuilder — constructor de pedidos multi-paso para llaveros y
// recuerdos de Cancún. Adaptado de la lógica del flujo de Adriano (producto →
// personalización → entrega → contacto) al sistema de diseño de Lumo.
// Cierra el pedido por WhatsApp (sin pago en línea por ahora).
import { SITE } from "../data/services";

// Diseños de llavero (impresión 3D). El motivo es un SVG on-brand; cuando
// haya fotos reales se cambia .design-art por <Image>.
const designs = [
  {
    id: "mar",
    name: "Mar",
    nameEn: "Ocean",
    desc: "Olas y caribe",
    descEn: "Beach vibes",
    art: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 26q7-7 13 0t13 0 13 0 13 0"/><path d="M6 38q7-7 13 0t13 0 13 0 13 0"/><path d="M6 50q7-7 13 0t13 0 13 0 13 0"/></svg>`,
  },
  {
    id: "tropical",
    name: "Tropical",
    nameEn: "Tropical",
    desc: "Palmas y selva",
    descEn: "Palms & jungle",
    art: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M32 54V28"/><path d="M32 28q-2-12-16-12 8 2 12 12"/><path d="M32 28q2-12 16-12-8 2-12 12"/><path d="M32 28q-10-6-10-18 6 6 10 18"/><path d="M32 28q10-6 10-18-6 6-10 18"/></svg>`,
  },
  {
    id: "maya",
    name: "Maya",
    nameEn: "Maya",
    desc: "Cultura ancestral",
    descEn: "Ancient culture",
    art: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 52h48"/><path d="M16 52V40h8V28h8V16h8v12h8v12h8v12"/><path d="M28 52v-8h8v8"/></svg>`,
  },
  {
    id: "fiesta",
    name: "Fiesta",
    nameEn: "Fiesta",
    desc: "Color y sabor",
    descEn: "Color & flavor",
    art: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="32" r="9"/><path d="M32 6v8M32 50v8M6 32h8M50 32h8M14 14l6 6M44 44l6 6M50 14l-6 6M20 44l-6 6"/></svg>`,
  },
];
---

<section class="builder" id="pedido">
  <div class="container">
    <div class="section-header">
      <p class="eyebrow" data-reveal data-es="Arma tu pedido" data-en="Build your order">Arma tu pedido</p>
      <h2 class="section-title" data-reveal data-reveal-delay="0.06" data-es="Tu recuerdo, paso a paso" data-en="Your souvenir, step by step">
        Tu recuerdo, paso a paso
      </h2>
      <p class="section-subtitle" data-reveal data-reveal-delay="0.12" data-es="Elige qué te llevas, personalízalo y nosotros lo hacemos en Cancún. Al final te abrimos WhatsApp con el resumen para confirmar." data-en="Choose what you'd like, personalize it and we make it in Cancún. At the end we open WhatsApp with your summary to confirm.">
        Elige qué te llevas, personalízalo y nosotros lo hacemos en Cancún.
        Al final te abrimos WhatsApp con el resumen para confirmar.
      </p>
    </div>

    <div class="ob-card" data-reveal data-reveal-delay="0.16">
      <!-- progreso + idioma -->
      <div class="ob-topbar">
        <div class="ob-steps" id="obSteps"></div>
        <button type="button" class="ob-lang" id="obLang" aria-label="Cambiar idioma / Switch language">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
          <span id="obLangLabel">EN</span>
        </button>
      </div>

      <div class="ob-body">
        <!-- ══ PASO 0: PRODUCTO ══ -->
        <div class="ob-panel ob-visible" id="panel-product">
          <h3 class="ob-title" data-es="¿Qué te llevas?" data-en="What would you like?">¿Qué te llevas?</h3>
          <p class="ob-sub" data-es="Todo personalizado y hecho en Cancún 🇲🇽" data-en="All personalized & made in Cancún 🇲🇽">Todo personalizado y hecho en Cancún 🇲🇽</p>

          <p class="ob-label" data-es="Llaveros impresos en 3D · desde $11 USD" data-en="3D printed keychains · from $11 USD">Llaveros impresos en 3D · desde $11 USD</p>
          <div class="design-grid">
            {designs.map((d) => (
              <button type="button" class="design-card" data-product={d.id} id={`cat-${d.id}`}>
                <span class="design-art" aria-hidden="true" set:html={d.art} />
                <span class="design-name" data-es={d.name} data-en={d.nameEn}>{d.name}</span>
                <span class="design-desc" data-es={d.desc} data-en={d.descEn}>{d.desc}</span>
              </button>
            ))}
          </div>

          <p class="ob-label" data-es="Termo grabado · desde $15 USD" data-en="Engraved thermal cup · from $15 USD">Termo grabado · desde $15 USD</p>
          <button type="button" class="wide-card" data-product="termo" id="cat-termo">
            <span class="wide-art" aria-hidden="true">
              <svg viewBox="0 0 40 64" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="11" y="2" width="18" height="6" rx="3"/><rect x="8" y="10" width="24" height="44" rx="5"/><path d="M8 50h24"/><rect x="14" y="54" width="12" height="6" rx="3"/></svg>
            </span>
            <span class="wide-text">
              <span class="wide-name" data-es="Termo de acero" data-en="Stainless steel cup">Termo de acero</span>
              <span class="wide-desc" data-es="Acero inoxidable 20oz · grabado láser con tu nombre + CANCUN" data-en="Stainless steel 20oz · laser engraved name + CANCUN">Acero inoxidable 20oz · grabado láser con tu nombre + CANCUN</span>
            </span>
            <span class="wide-price">$15+</span>
          </button>

          <p class="ob-label" data-es="Otros" data-en="Other">Otros</p>
          <button type="button" class="wide-card" data-product="portavasos" id="cat-portavasos">
            <span class="wide-art" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="20" cy="20" r="13"/><circle cx="20" cy="20" r="7"/><path d="M33 28l8 8M30 33l8 5"/></svg>
            </span>
            <span class="wide-text">
              <span class="wide-name" data-es="Set de 5 portavasos" data-en="Set of 5 coasters">Set de 5 portavasos</span>
              <span class="wide-desc" data-es="5 portavasos personalizados · hechos en Cancún" data-en="5 personalized coasters · made in Cancún">5 portavasos personalizados · hechos en Cancún</span>
            </span>
            <span class="wide-price">$15</span>
          </button>
        </div>

        <!-- ══ PASO 1K: NOMBRES + CANTIDAD ══ -->
        <div class="ob-panel" id="panel-names">
          <h3 class="ob-title" data-es="Tu(s) nombre(s)" data-en="Your name(s)">Tu(s) nombre(s)</h3>
          <p class="ob-sub" data-es="Máx 15 caracteres · cualquier alfabeto 🌍" data-en="Max 15 characters · any alphabet 🌍">Máx 15 caracteres · cualquier alfabeto 🌍</p>

          <div class="kc-preview">
            <span class="kc-preview-label" data-es="Previsualización" data-en="Preview">Previsualización</span>
            <span class="kc-preview-cancun">CANCUN</span>
            <span class="kc-preview-name" id="previewName">—</span>
          </div>

          <div class="name-inputs" id="nameInputs"></div>

          <p class="ob-label ob-label--mt" data-es="¿Cuántos?" data-en="How many?">¿Cuántos?</p>
          <div class="bundle-row" id="bundleRow"></div>
        </div>

        <!-- ══ PASO 2K: EXTRAS ══ -->
        <div class="ob-panel" id="panel-addons">
          <h3 class="ob-title" data-es="¿Agregar extras?" data-en="Add extras?">¿Agregar extras?</h3>
          <p class="ob-sub" data-es="Opcionales por llavero · salta para continuar" data-en="Optional per keychain · skip to continue">Opcionales por llavero · salta para continuar</p>
          <div id="addonsList"></div>
        </div>

        <!-- ══ PASO T: TERMO ══ -->
        <div class="ob-panel" id="panel-termo">
          <h3 class="ob-title" data-es="Personaliza tu termo" data-en="Customize your cup">Personaliza tu termo</h3>
          <p class="ob-sub" data-es="Acero inoxidable 20oz · elige qué grabamos" data-en="Stainless steel 20oz · choose what to engrave">Acero inoxidable 20oz · elige qué grabamos</p>

          <div class="termo-stage">
            <div class="termo-stage-top">
              <span class="termo-cup" aria-hidden="true">
                <svg viewBox="0 0 56 96" fill="none"><rect x="16" y="2" width="24" height="9" rx="4.5" fill="#5a4a39"/><rect x="9" y="11" width="38" height="70" rx="7" fill="#2a1605"/><rect x="13" y="15" width="6" height="60" rx="3" fill="#ffffff" opacity="0.07"/><rect x="14" y="78" width="28" height="11" rx="5" fill="#3a2410"/></svg>
              </span>
              <div class="termo-engrave">
                <span class="termo-engrave-label" data-es="Grabado" data-en="Engraving">Grabado</span>
                <span class="termo-engrave-cancun dim" id="tep-cancun">CANCUN</span>
                <span class="termo-engrave-name dim" id="tep-name">—</span>
              </div>
            </div>

            <button type="button" class="termo-opt" data-termo="cancun" id="topt-cancun">
              <span class="termo-opt-icon">✏️</span>
              <span class="termo-opt-info">
                <span class="termo-opt-name" data-es="Letras CANCUN" data-en="CANCUN lettering">Letras CANCUN</span>
                <span class="termo-opt-desc" data-es="Grabadas en el termo" data-en="Engraved on the cup">Grabadas en el termo</span>
              </span>
              <span class="termo-check" aria-hidden="true"></span>
            </button>

            <button type="button" class="termo-opt" data-termo="name" id="topt-name">
              <span class="termo-opt-icon">👤</span>
              <span class="termo-opt-info">
                <span class="termo-opt-name" data-es="Grabado con tu nombre" data-en="Custom name engraving">Grabado con tu nombre</span>
                <span class="termo-opt-desc" data-es="Tu nombre en el termo" data-en="Your name on the cup">Tu nombre en el termo</span>
              </span>
              <span class="termo-check" aria-hidden="true"></span>
            </button>

            <div class="termo-name-wrap ob-hidden" id="termoNameWrap">
              <input type="text" maxlength="15" id="termoNameField" placeholder="ej. NIRVANA" data-es-ph="ej. NIRVANA" data-en-ph="e.g. NIRVANA" />
              <span class="char-count" id="termoNameCount">0/15</span>
            </div>

            <div class="termo-price">
              <span data-es="Precio" data-en="Price">Precio</span>
              <span class="termo-price-val" id="termoPriceTag">$15 USD</span>
            </div>
          </div>
        </div>

        <!-- ══ PASO 3: ENTREGA ══ -->
        <div class="ob-panel" id="panel-delivery">
          <h3 class="ob-title" data-es="¿Dónde lo entregamos?" data-en="Where to deliver?">¿Dónde lo entregamos?</h3>
          <p class="ob-sub" data-es="Elige tu método de entrega" data-en="Choose your delivery method">Elige tu método de entrega</p>

          <div class="delivery-toggle">
            <button type="button" class="delivery-opt selected" data-delivery="hotel" id="del-hotel">
              <span class="delivery-icon">🏨</span>
              <span class="delivery-name" data-es="Hotel" data-en="Hotel">Hotel</span>
              <span class="delivery-info" data-es="Gratis · 72 h" data-en="Free · 72 h">Gratis · 72 h</span>
            </button>
            <button type="button" class="delivery-opt" data-delivery="address" id="del-address">
              <span class="delivery-icon">📦</span>
              <span class="delivery-name" data-es="Envío a casa" data-en="Ship home">Envío a casa</span>
              <span class="delivery-info" data-es="Tarifa FedEx" data-en="FedEx rates">Tarifa FedEx</span>
            </button>
            <button type="button" class="delivery-opt" data-delivery="pickup" id="del-pickup">
              <span class="delivery-icon">🏪</span>
              <span class="delivery-name" data-es="Recoger" data-en="Pickup">Recoger</span>
              <span class="delivery-info" data-es="Sin costo · taller" data-en="Free · workshop">Sin costo · taller</span>
            </button>
          </div>

          <!-- hotel -->
          <div id="hotelFields">
            <div class="ob-field">
              <label for="hotelZone" data-es="Zona de entrega" data-en="Delivery zone">Zona de entrega</label>
              <select id="hotelZone">
                <option value="" data-es="— Selecciona tu zona —" data-en="— Select your zone —">— Selecciona tu zona —</option>
                <option value="zona-hotelera" data-es="Zona Hotelera de Cancún" data-en="Cancún Hotel Zone">Zona Hotelera de Cancún</option>
                <option value="playa-mujeres" data-es="Playa Mujeres / Costa Mujeres" data-en="Playa Mujeres / Costa Mujeres">Playa Mujeres / Costa Mujeres</option>
                <option value="puerto-morelos" data-es="Puerto Morelos" data-en="Puerto Morelos">Puerto Morelos</option>
                <option value="playa-carmen" data-es="Playa del Carmen / Riviera Maya" data-en="Playa del Carmen / Riviera Maya">Playa del Carmen / Riviera Maya</option>
                <option value="centro" data-es="Centro de Cancún" data-en="Downtown Cancún">Centro de Cancún</option>
                <option value="outside" data-es="Otra / fuera del área" data-en="Other / outside area">Otra / fuera del área</option>
              </select>
            </div>

            <div id="zoneWarning" class="ob-warning ob-hidden" data-es="⚠️ Por ahora la entrega a hotel solo cubre Cancún y Riviera Maya. Elige otra zona o selecciona “Envío a casa”." data-en="⚠️ Hotel delivery currently covers only Cancún and the Riviera Maya. Choose another zone or select “Ship home”.">
              ⚠️ Por ahora la entrega a hotel solo cubre Cancún y Riviera Maya. Elige otra zona o selecciona “Envío a casa”.
            </div>

            <div id="hotelNameWrap">
              <div class="ob-field">
                <label for="hotelName" data-es="Hotel" data-en="Hotel">Hotel</label>
                <input type="text" id="hotelName" list="hotelList" autocomplete="off" placeholder="Escribe para buscar tu hotel…" data-es-ph="Escribe para buscar tu hotel…" data-en-ph="Type to search your hotel…" />
                <datalist id="hotelList">
                  <option value="Hyatt Ziva Cancun"></option>
                  <option value="Hyatt Zilara Cancun"></option>
                  <option value="Le Blanc Spa Resort Cancun"></option>
                  <option value="JW Marriott Cancun Resort & Spa"></option>
                  <option value="The Westin Lagunamar Cancun"></option>
                  <option value="The Ritz-Carlton Cancun"></option>
                  <option value="Live Aqua Beach Resort Cancun"></option>
                  <option value="Hilton Cancun All-Inclusive Resort"></option>
                  <option value="Grand Fiesta Americana Coral Beach"></option>
                  <option value="Fiesta Americana Condesa Cancun"></option>
                  <option value="Omni Cancun Hotel & Villas"></option>
                  <option value="Nizuc Resort & Spa"></option>
                  <option value="ME Cancun"></option>
                  <option value="Secrets The Vine Cancun"></option>
                  <option value="Dreams Sands Cancun Resort & Spa"></option>
                  <option value="Dreams Vista Cancun Resort & Spa"></option>
                  <option value="Breathless Cancun Soul Resort"></option>
                  <option value="Iberostar Selection Cancun"></option>
                  <option value="Riu Palace Las Americas"></option>
                  <option value="Riu Palace Peninsula"></option>
                  <option value="Riu Cancun"></option>
                  <option value="Moon Palace Cancun"></option>
                  <option value="Grand Park Royal Cancun"></option>
                  <option value="Crown Paradise Club Cancun"></option>
                  <option value="Temptation Cancun Resort"></option>
                  <option value="Oasis Palm Cancun"></option>
                  <option value="Beach Palace Cancun"></option>
                  <option value="Sun Palace Cancun"></option>
                  <option value="Club Med Cancun Yucatan"></option>
                  <option value="Villa del Palmar Cancun"></option>
                  <option value="Excellence Playa Mujeres"></option>
                  <option value="Finest Playa Mujeres"></option>
                  <option value="Paradisus Playa Mujeres"></option>
                  <option value="Grand Palladium Costa Mujeres"></option>
                  <option value="Now Jade Riviera Cancun"></option>
                  <option value="Excellence Riviera Cancun"></option>
                  <option value="Hotel Xcaret Mexico"></option>
                  <option value="Xcaret Arte Hotel"></option>
                  <option value="Paradisus Playa del Carmen"></option>
                  <option value="Royal Hideaway Playacar"></option>
                  <option value="Barcelo Maya Riviera"></option>
                  <option value="Hard Rock Hotel Riviera Maya"></option>
                </datalist>
                <div id="hotelError" class="ob-inline-error ob-hidden" data-es="⚠️ Ese hotel no está en la lista. Si no aparece, lo acordamos por WhatsApp." data-en="⚠️ That hotel isn't in our list. If it's missing, we'll sort it out on WhatsApp.">
                  ⚠️ Ese hotel no está en la lista. Si no aparece, lo acordamos por WhatsApp.
                </div>
              </div>
              <div class="ob-field">
                <label for="roomNumber" data-es="Número de habitación" data-en="Room number">Número de habitación</label>
                <input type="text" id="roomNumber" placeholder="ej. 412" data-es-ph="ej. 412" data-en-ph="e.g. 412" />
              </div>
            </div>
          </div>

          <!-- envío a casa -->
          <div id="addressFields" class="ob-hidden">
            <div class="ob-field">
              <label for="addrCountry" data-es="País" data-en="Country">País</label>
              <input type="text" id="addrCountry" placeholder="ej. México / USA" data-es-ph="ej. México / USA" data-en-ph="e.g. Mexico / USA" />
              <span class="ob-hint" data-es="Envíos por FedEx o Estafeta, costo agregado a la cotización." data-en="Shipping via FedEx or Estafeta, cost added to the quote.">Envíos por FedEx o Estafeta, costo agregado a la cotización.</span>
            </div>
            <div class="ob-field">
              <label for="addrStreet" data-es="Dirección completa" data-en="Full address">Dirección completa</label>
              <input type="text" id="addrStreet" placeholder="Calle, ciudad, código postal" data-es-ph="Calle, ciudad, código postal" data-en-ph="Street, city, ZIP code" />
            </div>
          </div>

          <!-- recoger -->
          <div id="pickupFields" class="ob-hidden">
            <div class="ob-info-box" data-es="📍 Recoges sin costo en el taller — Retorno Tejón, SM 20, Mz 3, Lt 2, Cancún 77500. Lun–sáb 9–18 h. Te avisamos por WhatsApp en cuanto esté listo." data-en="📍 Free pickup at the workshop — Retorno Tejón, SM 20, Mz 3, Lt 2, Cancún 77500. Mon–Sat 9am–6pm. We'll message you on WhatsApp when it's ready.">
              📍 Recoges sin costo en el taller — Retorno Tejón, SM 20, Mz 3, Lt 2, Cancún 77500.
              Lun–sáb 9–18 h. Te avisamos por WhatsApp en cuanto esté listo.
            </div>
          </div>
        </div>

        <!-- ══ PASO 4: CONTACTO + RESUMEN ══ -->
        <div class="ob-panel" id="panel-summary">
          <h3 class="ob-title" data-es="¡Casi listo!" data-en="Almost done!">¡Casi listo!</h3>
          <p class="ob-sub" data-es="Confirmamos tu pedido por WhatsApp" data-en="We'll confirm your order on WhatsApp">Confirmamos tu pedido por WhatsApp</p>

          <div class="ob-field">
            <label for="clientName" data-es="Tu nombre" data-en="Your name">Tu nombre</label>
            <input type="text" id="clientName" placeholder="Nombre completo" data-es-ph="Nombre completo" data-en-ph="Full name" />
          </div>
          <div class="ob-field">
            <label for="clientPhone" data-es="WhatsApp / teléfono" data-en="WhatsApp / phone">WhatsApp / teléfono</label>
            <input type="tel" id="clientPhone" placeholder="+52 998 000 0000" />
          </div>
          <div class="ob-field">
            <label for="clientEmail" data-es="Correo (opcional)" data-en="Email (optional)">Correo (opcional)</label>
            <input type="email" id="clientEmail" placeholder="tu@correo.com" data-es-ph="tu@correo.com" data-en-ph="you@email.com" />
          </div>

          <p class="ob-label ob-label--mt" data-es="Resumen del pedido" data-en="Order summary">Resumen del pedido</p>
          <div class="summary-box">
            <div class="summary-line">
              <span class="s-label" id="sumProduct">—</span>
              <span class="s-value" id="sumBasePrice">—</span>
            </div>
            <div class="summary-line ob-hidden" id="sumAddonRow">
              <span class="s-label" id="sumAddonLabel">—</span>
              <span class="s-value" id="sumAddonPrice">—</span>
            </div>
            <div class="summary-line">
              <span class="s-label" data-es="Entrega" data-en="Delivery">Entrega</span>
              <span class="s-value" id="sumDelivery">Gratis 🏨</span>
            </div>
            <div class="summary-total">
              <span data-es="Total" data-en="Total">Total</span>
              <span class="t-value" id="sumTotal">$0 USD</span>
            </div>
          </div>

          <p class="savings-note ob-hidden" id="savingsNote"></p>

          <button type="button" class="btn-wa" id="btnSubmit">
