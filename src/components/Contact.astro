<section class="contact" id="contacto">
  <div class="container contact-inner">
    <div class="contact-header">
      <h2 class="section-title">Contáctanos</h2>
      <p class="contact-tagline">
        Estamos en Cancún, listos para convertir tu idea en realidad.
      </p>
    </div>

    <div class="contact-grid">
      <a
        href="https://wa.me/528138913891"
        class="contact-item"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp"
      >
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.12.553 4.109 1.52 5.838L0 24l6.335-1.502A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.794 9.794 0 0 1-5.003-1.373l-.36-.213-3.76.891.946-3.658-.234-.376A9.79 9.79 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
          </svg>
        </span>
        <div>
          <p class="contact-label">WhatsApp</p>
          <p class="contact-value">+52 813 891 3891</p>
        </div>
      </a>

      <a
        href="mailto:contacto@lumoarte.com"
        class="contact-item"
        aria-label="Correo electrónico"
      >
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </span>
        <div>
          <p class="contact-label">Correo</p>
          <p class="contact-value">contacto@lumoarte.com</p>
        </div>
      </a>

      <div class="contact-item contact-item--address">
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </span>
        <div>
          <p class="contact-label">Dirección</p>
          <p class="contact-value">
            Ave 20 de Noviembre #125, Lt 9, Mz 30,<br />
            Sm 76, L1, Cancún, Q. Roo
          </p>
        </div>
      </div>
    </div>

    <div class="contact-social">
      <a
        href="https://www.instagram.com/_lumoarte"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
        aria-label="Instagram"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
        </svg>
        Instagram
      </a>
    </div>

    <div class="contact-about-row">
      <button class="about-trigger" id="aboutTrigger" aria-haspopup="dialog">
        Quiénes somos
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- About Us modal -->
<div class="about-overlay" id="aboutOverlay" hidden aria-hidden="true">
  <div class="about-modal" id="aboutModal" role="dialog" aria-modal="true" aria-labelledby="aboutModalTitle">
    <button class="about-close" id="aboutClose" aria-label="Cerrar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <h3 class="about-title" id="aboutModalTitle">Quiénes somos</h3>

    <!-- Content goes here -->
    <div class="about-body">
      <p class="about-placeholder">Contenido próximamente.</p>
    </div>
  </div>
</div>

<style>
  .contact {
    background: var(--color-dark);
    color: #fff;
    padding: 96px 0;
  }

  .contact-header {
    margin-bottom: 56px;
  }

  .contact-header .section-title {
    color: #fff;
    margin-bottom: 12px;
  }

  .contact-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.0625rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 32px;
    margin-bottom: 56px;
  }

  .contact-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    color: #fff;
    transition: opacity 0.2s;
  }

  a.contact-item:hover {
    opacity: 0.8;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 4px;
  }

  .contact-value {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
  }

  .contact-social {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 40px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    padding: 10px 20px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    transition: color 0.2s, border-color 0.2s;
  }

  .social-link:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  .contact-about-row {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .about-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.875rem;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition: color 0.2s;
    background: none;
    border: none;
    padding: 0;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.2);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .about-trigger:hover {
    color: #fff;
    text-decoration-color: rgba(255, 255, 255, 0.5);
  }

  .about-trigger svg {
    transition: transform 0.2s;
  }

  .about-trigger:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 640px) {
    .contact {
      padding: 64px 0;
    }
  }

  /* ── About overlay ─────────────────────────────────── */
  .about-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(10, 6, 3, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .about-overlay[hidden] {
    display: none;
  }

  .about-overlay.is-open {
    opacity: 1;
  }

  /* ── About modal card ──────────────────────────────── */
  .about-modal {
    position: relative;
    background: var(--color-bg);
    border-radius: 12px;
    padding: 40px;
    max-width: 560px;
    width: 100%;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
    border-top: 3px solid var(--color-accent);
    transform: scale(0.91) translateY(12px);
    opacity: 0;
    transition:
      transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.22s ease;
  }

  .about-overlay.is-open .about-modal {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .about-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    background: none;
    border: none;
  }

  .about-close:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .about-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 24px;
    padding-right: 32px;
  }

  .about-body {
    min-height: 120px;
  }

  .about-placeholder {
    color: var(--color-muted);
    font-size: 0.9375rem;
  }
</style>

<script>
  const overlay = document.getElementById("aboutOverlay")!;
  const trigger = document.getElementById("aboutTrigger")!;
  const closeBtn = document.getElementById("aboutClose")!;

  function openAbout() {
    overlay.removeAttribute("hidden");
    overlay.removeAttribute("aria-hidden");
    overlay.offsetHeight; // force reflow
    overlay.classList.add("is-open");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeAbout() {
    overlay.classList.remove("is-open");
    document.body.style.overflow = "";
    overlay.addEventListener("transitionend", function handler() {
      overlay.setAttribute("hidden", "");
      overlay.setAttribute("aria-hidden", "true");
      overlay.removeEventListener("transitionend", handler);
    });
  }

  trigger.addEventListener("click", openAbout);
  closeBtn.addEventListener("click", closeAbout);

  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) closeAbout();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !overlay.hasAttribute("hidden")) closeAbout();
  });
</script>
