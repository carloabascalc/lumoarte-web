---

<section class="contact" id="contacto">
  <div class="container contact-inner">
    <div class="contact-header">
      <h2 class="section-title" data-reveal>Contáctanos</h2>
      <p class="contact-tagline" data-reveal data-reveal-delay="0.08">
        Estamos en Cancún, listos para convertir tu idea en realidad.
      </p>
    </div>

    <div class="contact-grid" data-reveal data-reveal-delay="0.15">
      <a
        href="https://wa.me/528138913891"
        class="contact-item"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp"
      >
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.12.553 4.109 1.52 5.838L0 24l6.335-1.502A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.794 9.794 0 0 1-5.003-1.373l-.36-.213-3.76.891.946-3.658-.234-.376A9.79 9.79 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
          </svg>
        </span>
        <div>
          <p class="contact-label">WhatsApp</p>
          <p class="contact-value">+52 813 891 3891</p>
        </div>
      </a>

      <a
        href="mailto:contacto@lumoarte.com"
        class="contact-item"
        aria-label="Correo electrónico"
      >
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </span>
        <div>
          <p class="contact-label">Correo</p>
          <p class="contact-value">contacto@lumoarte.com</p>
        </div>
      </a>

      <div class="contact-item contact-item--address">
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </span>
        <div>
          <p class="contact-label">Dirección</p>
          <p class="contact-value">
            Ave 20 de Noviembre #125, Lt 9, Mz 30,<br />
            Sm 76, L1, Cancún, Q. Roo
          </p>
        </div>
      </div>
    </div>

    <div class="contact-social">
      <a
        href="https://www.instagram.com/_lumoarte"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
        aria-label="Instagram"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
        </svg>
        Instagram
      </a>
    </div>
  </div>
</section>


<style>
  .contact {
    background: var(--color-dark);
    color: #fff;
    padding: 96px 0;
  }

  .contact-header {
    margin-bottom: 56px;
  }

  .contact-header .section-title {
    color: #fff;
    margin-bottom: 12px;
  }

  .contact-tagline {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1.0625rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 32px;
    margin-bottom: 56px;
  }

  .contact-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    color: #fff;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  a.contact-item:hover {
    transform: translateY(-3px);
  }

  a.contact-item:hover .contact-icon {
    background: rgba(165, 58, 4, 0.22);
    color: #fff;
  }

  .contact-icon {
    transition: background 0.25s ease, color 0.25s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  a.contact-item:hover .contact-icon {
    transform: scale(1.08);
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 4px;
  }

  .contact-value {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.5;
  }

  .contact-social {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 40px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    padding: 10px 20px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    transition: color 0.2s, border-color 0.2s;
  }

  .social-link:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 640px) {
    .contact {
      padding: 64px 0;
    }
  }

</style>
