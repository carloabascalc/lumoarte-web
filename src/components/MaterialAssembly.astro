---
// 6 raw materials scatter, then converge into a tight cluster at center where
// the finished laser-cut box "assembles" and fades in over them — telling the
// story literally: de materiales sueltos → a la pieza terminada.
const materials = [
  { cls: "mdf",         fx: -34, fy: -30, fr: -14, tx: -3, ty: -2 },
  { cls: "acril-terra", fx:  36, fy: -26, fr:  16, tx:  3, ty: -3 },
  { cls: "papel",       fx: -40, fy:  20, fr:  12, tx: -4, ty:  2 },
  { cls: "pla",         fx:  42, fy:  16, fr: -18, tx:  4, ty:  1 },
  { cls: "lona",        fx: -22, fy:  36, fr:  14, tx:  0, ty:  3 },
  { cls: "vinil",       fx:  26, fy: -34, fr: -12, tx:  1, ty: -1 },
];
---

<section class="assembly" aria-labelledby="assembly-title">
  <div class="assembly-wrap" id="assembly-wrap">
    <div class="assembly-stage">
      <div class="container assembly-header">
        <p class="assembly-eyebrow">Del taller</p>
        <h2 class="sr-only" id="assembly-title">Fabricamos tu producto.</h2>
        <p class="assembly-title section-title" aria-hidden="true">
          Fabricamos tu <em>producto.</em>
        </p>
        <p class="assembly-sub">
          Madera, acrílico, filamento, lona y vinil.
        </p>
      </div>

      <div class="assembly-canvas" aria-hidden="true">
        {materials.map((m) => (
          <span
            class={`mat mat--${m.cls}`}
            data-mat
            data-fx={m.fx}
            data-fy={m.fy}
            data-fr={m.fr}
            data-tx={m.tx}
            data-ty={m.ty}
          ></span>
        ))}
      </div>

      {/* finished piece — fades/scales in as the materials converge */}
      <div class="assembly-piece" id="assembly-piece" aria-hidden="true">
        <svg viewBox="0 0 200 176" role="img">
          <defs>
            <linearGradient id="ap-top" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#dcae74" /><stop offset="1" stop-color="#cf9f63" />
            </linearGradient>
          </defs>
          {/* drop shadow */}
          <ellipse cx="100" cy="162" rx="64" ry="9" fill="#2b1d12" fill-opacity="0.12" />

          {/* right face */}
          <path d="M100 104 L174 66 L174 116 L100 154 Z" fill="#a87a3f" stroke="#2b1d12" stroke-width="2.5" stroke-linejoin="round" />
          {/* left face */}
          <path d="M26 66 L100 104 L100 154 L26 116 Z" fill="#c2914f" stroke="#2b1d12" stroke-width="2.5" stroke-linejoin="round" />
          {/* top / lid */}
          <path d="M100 28 L174 66 L100 104 L26 66 Z" fill="url(#ap-top)" stroke="#2b1d12" stroke-width="2.5" stroke-linejoin="round" />
          {/* lid sheen */}
          <path d="M100 34 L150 60 L100 86 L50 60 Z" fill="#ffffff" fill-opacity="0.12" />
          {/* lid seam */}
          <path d="M100 40 L162 72 L100 104 L38 72 Z" fill="none" stroke="#2b1d12" stroke-opacity="0.32" stroke-width="1.5" stroke-linejoin="round" />

          {/* finger joints — the laser-cut signature, on the visible corners */}
          <g stroke="#2b1d12" stroke-opacity="0.5" stroke-width="2" stroke-linecap="round">
            <line x1="100" y1="112" x2="100" y2="120" />
            <line x1="100" y1="128" x2="100" y2="136" />
            <line x1="100" y1="144" x2="100" y2="150" />
            <line x1="26" y1="80" x2="26" y2="88" />
            <line x1="26" y1="98" x2="26" y2="106" />
            <line x1="174" y1="80" x2="174" y2="88" />
            <line x1="174" y1="98" x2="174" y2="106" />
          </g>

          {/* engraved sun on the lid (brand touch) */}
          <g stroke="#b34000" stroke-width="2" stroke-linecap="round">
            <circle cx="100" cy="66" r="7" fill="#b34000" fill-opacity="0.18" />
            <g class="ap-rays">
              <line x1="100" y1="52" x2="100" y2="56" />
              <line x1="100" y1="76" x2="100" y2="80" />
              <line x1="82" y1="66" x2="86" y2="66" />
              <line x1="114" y1="66" x2="118" y2="66" />
            </g>
          </g>
        </svg>
      </div>

      <p class="assembly-hint" aria-hidden="true">
        <span id="assembly-hint-label">Materiales sueltos</span>
        <b id="assembly-hint-stage">01</b><span class="assembly-hint-of"> / 03</span>
      </p>
    </div>
  </div>
</section>

<style>
  .assembly {
    background: var(--color-bg);
    position: relative;
  }

  .assembly-wrap {
    position: relative;
    height: 200vh;
    contain: layout paint;
  }

  .assembly-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-alt) 100%);
    --mat-scale: 1;
    --mat-spread: 1;
    --mat-y-spread: 1;
    --mat-y-shift: 0vh;
  }

  .assembly-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(rgba(20, 10, 4, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(20, 10, 4, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0;
    will-change: opacity;
    pointer-events: none;
  }

  .assembly-header {
    position: relative;
    z-index: 4;
    text-align: center;
    margin-top: -28vh;
    pointer-events: none;
  }

  .assembly-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .assembly-title {
    margin-bottom: 18px;
  }

  .assembly-title em {
    font-style: italic;
    color: var(--color-accent);
  }

  .assembly-sub {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  .assembly-canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  /* Finished piece — sits where the materials converge, revealed on scroll. */
  .assembly-piece {
    position: absolute;
    left: 50%;
    top: 68%;
    z-index: 2;
    width: clamp(150px, 22vw, 248px);
    transform: translate(-50%, -50%) scale(0.84);
    opacity: 0;
    pointer-events: none;
    filter: drop-shadow(0 18px 30px rgba(20, 10, 4, 0.16));
    will-change: transform, opacity;
  }
  .assembly-piece svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .mat {
    position: absolute;
    left: 50%;
    top: 70%;
    transform-origin: center;
    will-change: transform;
    border-radius: 6px;
  }

  /* ── Material variants ─────────────────────────────── */
  .mat--mdf {
    width: 86px; height: 60px;
    background: linear-gradient(135deg, #c89669 0%, #b9885d 100%);
    box-shadow: 0 6px 16px rgba(140, 90, 40, 0.14);
  }

  .mat--acril-clear {
    width: 78px; height: 78px;
    background: linear-gradient(135deg, rgba(220, 230, 235, 0.55), rgba(255, 255, 255, 0.85));
    border: 1px solid rgba(120, 140, 160, 0.35);
    box-shadow:
      0 6px 18px rgba(60, 90, 120, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(2px);
  }

  .mat--acril-terra {
    width: 82px; height: 70px;
    background: var(--color-accent);
    box-shadow: 0 6px 22px rgba(165, 58, 4, 0.30);
  }

  .mat--cuero {
    width: 92px; height: 64px;
    background: linear-gradient(150deg, #6e4a2e 0%, #5a3c25 100%);
    box-shadow:
      0 6px 18px rgba(40, 25, 12, 0.30),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .mat--papel {
    width: 70px; height: 90px;
    background: #fdfaf3;
    border: 1px solid rgba(20, 10, 4, 0.06);
    box-shadow: 0 8px 22px rgba(20, 10, 4, 0.10);
  }

  .mat--vidrio {
    width: 76px; height: 76px;
    background: linear-gradient(140deg, rgba(150, 200, 220, 0.45) 0%, rgba(220, 235, 240, 0.85) 100%);
    border: 1px solid rgba(100, 140, 160, 0.30);
    border-radius: 4px;
    box-shadow: 0 6px 18px rgba(60, 100, 130, 0.15);
  }

  .mat--marmol {
    width: 82px; height: 70px;
    background:
      radial-gradient(ellipse 60% 30% at 30% 40%, rgba(180, 170, 160, 0.4), transparent 70%),
      radial-gradient(ellipse 50% 25% at 70% 70%, rgba(160, 150, 140, 0.35), transparent 70%),
      #f4eee4;
    box-shadow: 0 6px 18px rgba(20, 10, 4, 0.10);
  }

  .mat--pla {
    width: 64px; height: 64px;
    background:
      linear-gradient(135deg, #d97a3e 0%, #b34000 50%, #802d00 100%);
    border-radius: 4px;
    box-shadow:
      0 6px 22px rgba(165, 58, 4, 0.40),
      inset 0 -3px 0 rgba(0, 0, 0, 0.12);
  }

  .mat--tela {
    width: 88px; height: 64px;
    background:
      repeating-linear-gradient(45deg, #b8a691 0 3px, #a89682 3px 6px),
      #b8a691;
    border-radius: 4px;
    box-shadow: 0 6px 18px rgba(20, 10, 4, 0.12);
  }

  .mat--lona {
    width: 110px; height: 22px;
    background: linear-gradient(180deg, #f0e8d8 0%, #e6dcc8 100%);
    border: 1px solid rgba(20, 10, 4, 0.10);
    border-radius: 3px;
    box-shadow: 0 4px 14px rgba(20, 10, 4, 0.08);
  }

  .mat--vinil {
    width: 72px; height: 72px;
    background:
      radial-gradient(circle at 30% 30%, #1a1a1a, #0a0a0a);
    border-radius: 4px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.30);
  }

  .mat--subli {
    width: 80px; height: 80px;
    background:
      conic-gradient(from 90deg at 50% 50%, #e89b5c 0deg 90deg, #b34000 90deg 180deg, #6e4a2e 180deg 270deg, #c8966b 270deg 360deg);
    opacity: 0.9;
    border-radius: 4px;
    box-shadow: 0 6px 18px rgba(165, 58, 4, 0.22);
  }

  .assembly-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    margin: 0;
  }

  .assembly-hint b {
    color: var(--color-accent);
    font-weight: 600;
    transition: color 0.3s ease;
    font-variant-numeric: tabular-nums;
  }

  .assembly-hint-of {
    color: var(--color-muted);
    opacity: 0.6;
  }

  @media (max-width: 980px) {
    .assembly-wrap { height: 185vh; }
    .assembly-stage { --mat-scale: 0.82; --mat-spread: 0.95; --mat-y-spread: 0.85; --mat-y-shift: 4vh; }
  }

  @media (max-width: 640px) {
    .assembly-wrap { height: 175vh; }
    .assembly-stage { --mat-scale: 0.5; --mat-spread: 1.05; --mat-y-spread: 0.55; --mat-y-shift: 2vh; }
    .assembly-header { margin-top: -22vh; }
    .assembly-sub { font-size: 0.95rem; max-width: 320px; }
    .assembly-hint { white-space: nowrap; bottom: 24px; font-size: 0.66rem; letter-spacing: 0.14em; }
  }

  @media (prefers-reduced-motion: reduce) {
    .assembly-wrap { height: auto; }
    .assembly-stage { position: static; height: auto; padding: 100px 0; }
    .assembly-canvas { display: none; }
    .assembly-hint { display: none; }
    .assembly-piece {
      position: static;
      opacity: 1;
      transform: none;
      margin: 28px auto 0;
    }
  }
</style>

<script>
  function initAssembly() {
    const wrap = document.getElementById('assembly-wrap');
    const grid = document.querySelector<HTMLElement>('.assembly-grid-bg');
    const hintLabel = document.getElementById('assembly-hint-label');
    const hintStage = document.getElementById('assembly-hint-stage');
    const mats = Array.from(document.querySelectorAll<HTMLElement>('[data-mat]'));
    const piece = document.getElementById('assembly-piece');
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!wrap || !mats.length || reduced) return;

    type MatData = { el: HTMLElement; fx: number; fy: number; fr: number; tx: number; ty: number };
    const data: MatData[] = mats.map((el) => ({
      el,
      fx: parseFloat(el.dataset.fx || '0'),
      fy: parseFloat(el.dataset.fy || '0'),
      fr: parseFloat(el.dataset.fr || '0'),
      tx: parseFloat(el.dataset.tx || '0'),
      ty: parseFloat(el.dataset.ty || '0'),
    }));

    const clamp = (v: number, lo = 0, hi = 1) => Math.max(lo, Math.min(hi, v));
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
    const ease = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

    let pending = false;

    const stage = wrap!.querySelector<HTMLElement>('.assembly-stage');

    function tick() {
      pending = false;
      const rect = wrap!.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      if (total <= 0) return;
      const scrolled = -rect.top;
      const rawP = clamp(scrolled / total);
      const p = ease(rawP);

      const cs = stage ? getComputedStyle(stage) : null;
      const scale = parseFloat(cs?.getPropertyValue('--mat-scale') || '1') || 1;
      const spread = parseFloat(cs?.getPropertyValue('--mat-spread') || '1') || 1;
      const ySpread = parseFloat(cs?.getPropertyValue('--mat-y-spread') || '1') || 1;
      const yShiftStr = cs?.getPropertyValue('--mat-y-shift').trim() || '0vh';
      const yShift = parseFloat(yShiftStr) || 0;

      if (grid) {
        const o = rawP < 0.35 ? (rawP / 0.35) * 0.5
                : rawP < 0.92 ? 0.5 - ((rawP - 0.35) / 0.57) * 0.4
                : Math.max(0, 0.1 - ((rawP - 0.92) / 0.08) * 0.1);
        grid.style.opacity = String(o);
      }

      if (hintLabel && hintStage) {
        if (rawP < 0.4) { hintLabel.textContent = 'Materiales sueltos'; hintStage.textContent = '01'; }
        else if (rawP < 0.72) { hintLabel.textContent = 'Ensamblando'; hintStage.textContent = '02'; }
        else { hintLabel.textContent = 'Pieza terminada'; hintStage.textContent = '03'; }
      }

      // Materials converge, shrink and get "absorbed" as the finished piece
      // assembles and pops into place.
      const pieceP = clamp((rawP - 0.52) / 0.34);
      const chipFade = 1 - clamp((rawP - 0.55) / 0.3) * 0.95;
      const chipScale = scale * (0.5 + 0.5 * chipFade);
      const easeBack = (t: number) => {
        const c1 = 1.70158, c3 = c1 + 1, u = t - 1;
        return 1 + c3 * u * u * u + c1 * u * u;
      };

      data.forEach((d) => {
        const x = lerp(d.fx, d.tx * spread, p);
        const y = lerp(d.fy, d.ty * ySpread, p) + yShift * p;
        const r = lerp(d.fr, 0, p);
        d.el.style.transform = `translate(calc(-50% + ${x}vw), calc(-50% + ${y}vh)) rotate(${r}deg) scale(${chipScale})`;
        d.el.style.opacity = String(chipFade);
      });

      if (piece) {
        piece.style.opacity = String(clamp(pieceP * 1.3));
        const ps = (0.82 + 0.18 * easeBack(pieceP)) * scale;
        piece.style.transform = `translate(-50%, -50%) scale(${ps})`;
      }
    }

    function onScroll() {
      if (pending) return;
      pending = true;
      requestAnimationFrame(tick);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    tick();
  }

  initAssembly();
  document.addEventListener('astro:page-load', initAssembly);
</script>
