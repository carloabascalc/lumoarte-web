---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  items: FaqItem[];
  injectSchema?: boolean;
  /** Botón de descarga prominente bajo la lista (ej. "¿Cómo te cobramos?"). */
  downloadCta?: { href: string; label: string };
}

const {
  title = "Preguntas frecuentes",
  subtitle,
  items,
  injectSchema = true,
  downloadCta,
} = Astro.props;

const faqSchema = injectSchema
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: items.map((it) => ({
        "@type": "Question",
        name: it.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: it.answer,
        },
      })),
    }
  : null;
---

<section class="faq section" id="faq">
  <div class="container">
    <div class="section-header">
      <p class="faq-eyebrow" data-reveal>Antes de cotizar</p>
      <h2 class="section-title" data-reveal data-reveal-delay="0.06">{title}</h2>
      {subtitle && <p class="section-subtitle" data-reveal data-reveal-delay="0.12">{subtitle}</p>}
    </div>

    <ul class="faq-list" role="list" data-reveal data-reveal-delay="0.16">
      {items.map((it, i) => (
        <li class="faq-item">
          <details>
            <summary>
              <span class="faq-q">{it.question}</span>
              <span class="faq-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </summary>
            <div class="faq-a" set:html={it.answer.replace(/\n/g, "<br />")} />
          </details>
        </li>
      ))}
    </ul>

    {downloadCta && (
      <div class="faq-download" data-reveal data-reveal-delay="0.2">
        <span class="faq-download-text">¿Quieres ver cómo calculamos cada cotización?</span>
        <a
          class="faq-download-btn"
          href={downloadCta.href}
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          {downloadCta.label}
        </a>
      </div>
    )}
  </div>
</section>

{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

<style>
  .faq {
    background: var(--color-bg);
  }

  .faq-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .faq-list {
    list-style: none;
    border-top: 1px solid var(--color-surface);
    max-width: 820px;
  }

  /* ── Descarga prominente bajo el FAQ ── */
  .faq-download {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 18px;
    max-width: 820px;
    margin-top: 32px;
    padding: 22px 26px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-radius: 10px;
  }

  .faq-download-text {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .faq-download-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 22px;
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 7px;
    background: var(--page-accent, var(--color-accent));
    color: #fff;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .faq-download-btn:hover {
    background: var(--page-accent-dark, var(--color-accent-dark));
  }

  @media (max-width: 560px) {
    .faq-download-btn {
      width: 100%;
      justify-content: center;
    }
  }

  .faq-item {
    border-bottom: 1px solid var(--color-surface);
  }

  .faq-item details {
    transition: background 0.2s;
  }

  .faq-item details[open] {
    background: var(--color-bg-alt);
  }

  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 22px 24px;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary:hover {
    color: var(--color-accent);
  }

  .faq-q {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
  }

  .faq-icon {
    flex-shrink: 0;
    color: var(--color-muted);
    transition: transform 0.25s ease, color 0.2s;
  }

  .faq-item summary:hover .faq-icon {
    color: var(--color-accent);
  }

  .faq-item details[open] .faq-icon {
    transform: rotate(180deg);
    color: var(--color-accent);
  }

  .faq-a {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.75;
    padding: 0 24px 24px;
    max-width: 720px;
  }

  @media (max-width: 640px) {
    .faq-item summary {
      padding: 18px 16px;
    }

    .faq-a {
      padding: 0 16px 20px;
    }
  }
</style>
