---
// Plotter / gran formato hero showcase — 3 illustrated mockup cards.
// One per service: banner (lona), vinil wrap (decal), sublimación (textil).
---

<div class="hero-stack">
  {/* BACK card — vinyl decal sample with star/geometric pattern */}
  <div class="hero-card hero-card--back" aria-hidden="true">
    <div class="specimen-card specimen-card--vinyl">
      <svg viewBox="0 0 120 120" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="vinyl-bg" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#0f0f0f"/>
            <stop offset="100%" stop-color="#1c1c1c"/>
          </linearGradient>
        </defs>
        {/* Substrate (dark, suggesting car door) */}
        <rect x="6" y="14" width="108" height="92" rx="6" fill="url(#vinyl-bg)"/>
        {/* Vinyl decal — bold terracotta logotype on dark */}
        <g transform="translate(60, 60)">
          <text
            x="0" y="0"
            text-anchor="middle"
            dominant-baseline="central"
            font-family="serif"
            font-style="italic"
            font-weight="700"
            font-size="44"
            fill="#c96b3a"
            letter-spacing="-1"
          >lm</text>
        </g>
        {/* Decal corner registration marks */}
        <g stroke="rgba(201, 107, 58, 0.5)" stroke-width="1" fill="none">
          <path d="M 14 22 L 14 28 M 14 22 L 20 22"/>
          <path d="M 106 22 L 100 22 M 106 22 L 106 28"/>
          <path d="M 14 98 L 14 92 M 14 98 L 20 98"/>
          <path d="M 106 98 L 100 98 M 106 98 L 106 92"/>
        </g>
      </svg>
      <span class="specimen-tag">Vinil</span>
    </div>
  </div>

  {/* MAIN card — large banner, the iconic plotter output */}
  <div class="hero-card hero-card--main" aria-hidden="true">
    <div class="specimen-card specimen-card--banner">
      <svg viewBox="0 0 120 150" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="banner-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#c96b3a"/>
            <stop offset="50%" stop-color="#a53a04"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
        </defs>
        {/* Eyelets */}
        <circle cx="20" cy="14" r="2.4" fill="#0a0a0a"/>
        <circle cx="60" cy="14" r="2.4" fill="#0a0a0a"/>
        <circle cx="100" cy="14" r="2.4" fill="#0a0a0a"/>
        {/* Banner body */}
        <rect x="10" y="18" width="100" height="120" rx="2" fill="url(#banner-grad)"/>
        {/* lm wordmark */}
        <text
          x="22" y="78"
          font-family="serif"
          font-style="italic"
          font-weight="700"
          font-size="44"
          fill="#f4ecd8"
          letter-spacing="-2"
        >lm</text>
        {/* Tag line */}
        <text
          x="22" y="92"
          font-family="sans-serif"
          font-size="4.6"
          fill="rgba(244, 236, 216, 0.8)"
          letter-spacing="1"
        >FABRICACIÓN DIGITAL</text>
        <text
          x="22" y="100"
          font-family="sans-serif"
          font-size="4.6"
          fill="rgba(244, 236, 216, 0.8)"
          letter-spacing="1"
        >· CANCÚN ·</text>
        {/* CMYK stripe */}
        <g>
          <rect x="92" y="36" width="6" height="22" rx="1.5" fill="#2a9bb0"/>
          <rect x="92" y="60" width="6" height="22" rx="1.5" fill="#b03088"/>
          <rect x="92" y="84" width="6" height="22" rx="1.5" fill="#d4b020"/>
          <rect x="92" y="108" width="6" height="22" rx="1.5" fill="#0f0f0f"/>
        </g>
      </svg>
      <span class="specimen-tag">Lona</span>
    </div>
  </div>

  {/* FRONT card — sublimated tee silhouette */}
  <div class="hero-card hero-card--front" aria-hidden="true">
    <div class="specimen-card specimen-card--tee">
      <svg viewBox="0 0 120 120" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="tee-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#c96b3a"/>
            <stop offset="100%" stop-color="#a53a04"/>
          </linearGradient>
          <pattern id="tee-pattern" patternUnits="userSpaceOnUse" width="8" height="8" patternTransform="rotate(45)">
            <line x1="0" y1="0" x2="0" y2="8" stroke="rgba(255, 255, 255, 0.16)" stroke-width="0.8"/>
          </pattern>
        </defs>
        {/* T-shirt silhouette */}
        <path
          d="M 30 30
             L 40 22
             L 50 26
             C 54 22, 66 22, 70 26
             L 80 22
             L 90 30
             L 100 38
             L 92 46
             L 86 42
             L 86 102
             C 86 104, 84 106, 82 106
             L 38 106
             C 36 106, 34 104, 34 102
             L 34 42
             L 28 46
             L 20 38
             Z"
          fill="url(#tee-grad)"
        />
        {/* Sublimated pattern overlay */}
        <path
          d="M 30 30 L 40 22 L 50 26 C 54 22, 66 22, 70 26 L 80 22 L 90 30 L 100 38 L 92 46 L 86 42 L 86 102 C 86 104, 84 106, 82 106 L 38 106 C 36 106, 34 104, 34 102 L 34 42 L 28 46 L 20 38 Z"
          fill="url(#tee-pattern)"
        />
        {/* Collar */}
        <path
          d="M 50 26 C 54 32, 66 32, 70 26"
          fill="none"
          stroke="rgba(20, 10, 4, 0.4)"
          stroke-width="1.5"
        />
      </svg>
      <span class="specimen-tag">Sublimación</span>
    </div>
  </div>
</div>

<style>
  .hero-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 24px 56px rgba(20, 10, 4, 0.18),
      0 0 0 1px rgba(165, 58, 4, 0.06);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .specimen-card {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 100% 80% at 50% 110%, rgba(165, 58, 4, 0.08), transparent 70%),
      linear-gradient(180deg, #f6efe1 0%, #e9dfca 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: 12px;
    position: relative;
  }

  .specimen-svg {
    flex: 1 1 auto;
    width: 100%;
    height: auto;
    max-height: 78%;
    filter: drop-shadow(0 6px 12px rgba(20, 10, 4, 0.16));
  }

  .specimen-tag {
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(20, 10, 4, 0.55);
    margin-top: 6px;
    flex-shrink: 0;
  }

  .hero-card--main {
    width: 70%;
    aspect-ratio: 4 / 5;
    top: 10%;
    left: 14%;
    z-index: 3;
    transform: rotate(-2deg);
  }

  .hero-card--back {
    width: 52%;
    aspect-ratio: 1 / 1;
    top: 0;
    right: 0;
    z-index: 1;
    transform: rotate(6deg);
    opacity: 0.95;
  }

  .hero-card--front {
    width: 50%;
    aspect-ratio: 1 / 1;
    bottom: 4%;
    left: 0;
    z-index: 4;
    transform: rotate(-6deg);
  }

  .hero-stack:hover .hero-card--main { transform: rotate(-1deg) translateY(-4px); }
  .hero-stack:hover .hero-card--back { transform: rotate(8deg) translateX(4px); }
  .hero-stack:hover .hero-card--front { transform: rotate(-7deg) translate(-4px, 4px); }

  @media (max-width: 540px) {
    .specimen-tag { font-size: 0.56rem; }
  }
</style>
