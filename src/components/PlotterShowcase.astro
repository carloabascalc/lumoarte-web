---
// Plotter / gran formato hero showcase — 3 illustrated mockup cards.
// Polished with cleaner gradients, drop shadows, edge-to-edge content.
// One card per service: lona (banner), vinil (decal).
---

<div class="hero-stack">
  {/* BACK — vinyl decal sample (top-right, fully filled with brand color) */}
  <div class="hero-card hero-card--back" aria-hidden="true">
    <div class="specimen-card specimen-card--vinyl">
      <svg viewBox="0 0 200 200" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="vinyl-bg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#1c1c1c"/>
            <stop offset="100%" stop-color="#0a0a0a"/>
          </linearGradient>
          <linearGradient id="vinyl-accent" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#e8946e"/>
            <stop offset="60%" stop-color="#c96b3a"/>
            <stop offset="100%" stop-color="#a53a04"/>
          </linearGradient>
        </defs>
        {/* Dark substrate */}
        <rect x="0" y="0" width="200" height="200" fill="url(#vinyl-bg)"/>
        {/* Diagonal terracotta vinyl stripe — bold edge-to-edge graphic */}
        <path d="M -10 130 L 210 50 L 210 90 L -10 170 Z" fill="url(#vinyl-accent)"/>
        {/* lm wordmark on the stripe */}
        <text
          x="100" y="115"
          text-anchor="middle"
          dominant-baseline="central"
          font-family="serif"
          font-style="italic"
          font-weight="700"
          font-size="56"
          fill="#f4ecd8"
          letter-spacing="-2"
        >lm</text>
        {/* Corner registration marks (vinyl bleed crosses) */}
        <g stroke="rgba(232, 148, 110, 0.6)" stroke-width="1" fill="none">
          <path d="M 10 10 L 10 22 M 10 10 L 22 10"/>
          <path d="M 190 10 L 178 10 M 190 10 L 190 22"/>
          <path d="M 10 190 L 10 178 M 10 190 L 22 190"/>
          <path d="M 190 190 L 178 190 M 190 190 L 190 178"/>
        </g>
      </svg>
    </div>
  </div>

  {/* MAIN — banner with wordmark + CMYK stripe (left, dominant) */}
  <div class="hero-card hero-card--main" aria-hidden="true">
    <div class="specimen-card specimen-card--banner">
      <svg viewBox="0 0 200 250" class="specimen-svg" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id="banner-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#e8946e"/>
            <stop offset="35%" stop-color="#c96b3a"/>
            <stop offset="75%" stop-color="#a53a04"/>
            <stop offset="100%" stop-color="#5a1d00"/>
          </linearGradient>
          <linearGradient id="banner-shadow" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(0, 0, 0, 0)"/>
            <stop offset="100%" stop-color="rgba(0, 0, 0, 0.18)"/>
          </linearGradient>
        </defs>
        {/* Eyelets bar (suspension points) */}
        <g fill="#0f0f0f">
          <circle cx="40" cy="22" r="3"/>
          <circle cx="100" cy="22" r="3"/>
          <circle cx="160" cy="22" r="3"/>
        </g>
        {/* Banner body — slightly wider at top to suggest hanging */}
        <path d="M 22 30
                 Q 100 24, 178 30
                 L 178 232
                 Q 100 238, 22 232 Z"
              fill="url(#banner-grad)"/>
        {/* Subtle lower fade for cloth depth */}
        <rect x="22" y="180" width="156" height="52" fill="url(#banner-shadow)" opacity="0.7"/>
        {/* lm wordmark — large, italic, brand serif */}
        <text
          x="42" y="130"
          font-family="serif"
          font-style="italic"
          font-weight="700"
          font-size="88"
          fill="#f4ecd8"
          letter-spacing="-4"
        >lm</text>
        {/* Tag line */}
        <text
          x="42" y="158"
          font-family="sans-serif"
          font-size="9"
          font-weight="500"
          fill="rgba(244, 236, 216, 0.85)"
          letter-spacing="2.5"
        >FABRICACIÓN DIGITAL</text>
        <text
          x="42" y="172"
          font-family="sans-serif"
          font-size="9"
          font-weight="400"
          fill="rgba(244, 236, 216, 0.75)"
          letter-spacing="2.5"
        >· CANCÚN ·</text>
        {/* CMYK stripe — vertical column on the right */}
        <g>
          <rect x="148" y="60" width="14" height="34" rx="2" fill="#2a9bb0"/>
          <rect x="148" y="98" width="14" height="34" rx="2" fill="#b03088"/>
          <rect x="148" y="136" width="14" height="34" rx="2" fill="#d4b020"/>
          <rect x="148" y="174" width="14" height="34" rx="2" fill="#0f0f0f"/>
        </g>
      </svg>
    </div>
  </div>

</div>

<style>
  .hero-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .hero-card {
    position: absolute;
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 24px 56px rgba(20, 10, 4, 0.22),
      0 0 0 1px rgba(165, 58, 4, 0.06);
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .specimen-card {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px;
  }

  .specimen-card--banner {
    background:
      radial-gradient(ellipse 90% 70% at 50% 30%, rgba(255, 255, 255, 0.55), transparent 70%),
      linear-gradient(180deg, #f8f1e2 0%, #e8ddc6 100%);
  }

  /* Vinyl card has its own dark substrate baked into the SVG — no card bg */
  .specimen-card--vinyl {
    padding: 0;
  }

  .specimen-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 6px 14px rgba(20, 10, 4, 0.18));
  }

  .specimen-card--vinyl .specimen-svg {
    filter: none;
  }

  .hero-card--main {
    width: 62%;
    aspect-ratio: 4 / 5;
    top: 6%;
    left: 6%;
    z-index: 3;
    transform: rotate(-2deg);
  }

  .hero-card--back {
    width: 50%;
    aspect-ratio: 1 / 1;
    bottom: 4%;
    right: 0;
    z-index: 1;
    transform: rotate(6deg);
    opacity: 0.96;
  }

  .hero-stack:hover .hero-card--main { transform: rotate(-1deg) translateY(-4px); }
  .hero-stack:hover .hero-card--back { transform: rotate(8deg) translateX(4px); }
</style>
