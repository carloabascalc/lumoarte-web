---
const affiliates = [
  { name: "The Line Laser Print", url: "https://thelinelaserprint.com/" },
  { name: "Abascal Arquitectos", url: "https://abascalarquitectos.com/" },
  { name: "Prospective Vision", url: "https://www.prospective-vision.org/" },
];
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" aria-label="Lumo Arte">
        <img
          src="/images/logo-footer.png"
          alt="Lumo Arte"
          width="80"
          height="96"
          loading="lazy"
        />
      </a>
      <p class="footer-tagline">
        No solo cortamos: diseñamos, transformamos y damos vida a las ideas.
      </p>
      <button class="about-trigger" id="aboutTrigger" aria-haspopup="dialog">
        Quiénes somos
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <div class="footer-affiliates">
      <p class="footer-affiliate-label">Empresas afiliadas</p>
      <ul role="list">
        {
          affiliates.map((a) => (
            <li>
              <a
                href={a.url}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-affiliate-link"
              >
                {a.name}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© 2026 Lumo Arte Impression — Cancún, México</p>
    </div>
  </div>
</footer>

<!-- About Us modal -->
<div class="about-overlay" id="aboutOverlay" hidden aria-hidden="true">
  <div class="about-modal" role="dialog" aria-modal="true" aria-labelledby="aboutModalTitle">
    <button class="about-close" id="aboutClose" aria-label="Cerrar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <h3 class="about-title" id="aboutModalTitle">Quiénes somos</h3>
    <div class="about-body">
      <p class="about-placeholder">Contenido próximamente.</p>
    </div>
  </div>
</div>

<style>
  .footer {
    background: var(--color-dark);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    padding-top: 56px;
    padding-bottom: 48px;
    flex-wrap: wrap;
  }

  .footer-brand {
    max-width: 320px;
  }

  .footer-brand img {
    height: 64px;
    width: auto;
    filter: brightness(0) invert(0.85);
    margin-bottom: 20px;
  }

  .footer-tagline {
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-affiliates {
    min-width: 200px;
  }

  .footer-affiliate-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 16px;
  }

  .footer-affiliates ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-affiliate-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
  }

  .footer-affiliate-link:hover {
    color: #fff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 20px 0;
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.3);
    font-size: 0.8125rem;
  }

  .about-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 20px;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
  }

  .about-trigger:hover {
    color: #fff;
  }

  .about-trigger svg {
    transition: transform 0.2s;
  }

  .about-trigger:hover svg {
    transform: translateX(3px);
  }

  /* ── About overlay ─────────────────────────────────── */
  .about-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(10, 6, 3, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .about-overlay[hidden] { display: none; }
  .about-overlay.is-open { opacity: 1; }

  .about-modal {
    position: relative;
    background: var(--color-bg);
    border-radius: 12px;
    padding: 40px;
    max-width: 560px;
    width: 100%;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
    border-top: 3px solid var(--color-accent);
    transform: scale(0.91) translateY(12px);
    opacity: 0;
    transition:
      transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.22s ease;
  }

  .about-overlay.is-open .about-modal {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .about-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    cursor: pointer;
    background: none;
    border: none;
    transition: background 0.2s, color 0.2s;
  }

  .about-close:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .about-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 24px;
    padding-right: 32px;
  }

  .about-body { min-height: 120px; }

  .about-placeholder {
    color: var(--color-muted);
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: 40px;
    }
  }
</style>

<script>
  const overlay = document.getElementById("aboutOverlay")!;
  const trigger = document.getElementById("aboutTrigger")!;
  const closeBtn = document.getElementById("aboutClose")!;

  function openAbout() {
    overlay.removeAttribute("hidden");
    overlay.removeAttribute("aria-hidden");
    overlay.offsetHeight;
    overlay.classList.add("is-open");
    document.body.style.overflow = "hidden";
    closeBtn.focus();
  }

  function closeAbout() {
    overlay.classList.remove("is-open");
    document.body.style.overflow = "";
    overlay.addEventListener("transitionend", function handler() {
      overlay.setAttribute("hidden", "");
      overlay.setAttribute("aria-hidden", "true");
      overlay.removeEventListener("transitionend", handler);
    });
  }

  trigger.addEventListener("click", openAbout);
  closeBtn.addEventListener("click", closeAbout);
  overlay.addEventListener("click", (e) => { if (e.target === overlay) closeAbout(); });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !overlay.hasAttribute("hidden")) closeAbout();
  });
</script>
