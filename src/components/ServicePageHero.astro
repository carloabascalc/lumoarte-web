---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  service?: "laser" | "3d" | "plotter";
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta = { label: "Solicita tu cotización", href: "#cotiza" },
  secondaryCta,
  service = "laser",
} = Astro.props;
---

<section class={`service-hero service-hero--${service}`}>
  <div class="container service-hero-grid">
    <div class="service-hero-text">
      <p class="service-hero-eyebrow" data-reveal>
        <span class="service-hero-dash" aria-hidden="true"></span>
        {eyebrow}
      </p>
      <h1 class="service-hero-title" data-reveal data-reveal-delay="0.06">{title}</h1>
      <p class="service-hero-sub" data-reveal data-reveal-delay="0.12">{subtitle}</p>
      <div class="service-hero-ctas" data-reveal data-reveal-delay="0.18">
        <a href={primaryCta.href} class="btn btn-primary">{primaryCta.label}</a>
        {secondaryCta && (
          <a href={secondaryCta.href} class="service-hero-cta-secondary">
            {secondaryCta.label}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        )}
      </div>
    </div>

    <div class="service-hero-showcase" data-reveal data-reveal-delay="0.10">
      <slot name="showcase" />
    </div>
  </div>
</section>

<style>
  .service-hero {
    padding: calc(var(--nav-h) + 28px) 0 88px;
    position: relative;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  /* Per-service warm tints, kept subtle so the showcase carries the visual weight */
  .service-hero--laser   { background: var(--color-bg-alt); }
  .service-hero--3d      { background: var(--service-3d-bg, #f3ece2); }
  .service-hero--plotter { background: var(--service-plotter-bg, #efe8db); }

  /* Soft accent glow top-right of the section */
  .service-hero::before {
    content: "";
    position: absolute;
    top: -260px;
    right: -180px;
    width: 680px;
    height: 680px;
    background: radial-gradient(circle, var(--page-accent-soft, rgba(165, 58, 4, 0.18)) 0%, transparent 65%);
    pointer-events: none;
  }

  /* Hairline divider at the bottom — same accent treatment as before */
  .service-hero::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 1.5px;
    background: linear-gradient(to right, transparent, var(--page-accent, var(--color-accent)), transparent);
    opacity: 0.40;
  }

  .service-hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* ── Text column ───────────────────────────────────── */
  .service-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--page-accent, var(--color-accent));
    margin-bottom: 24px;
  }

  .service-hero-dash {
    display: inline-block;
    width: 28px;
    height: 1.5px;
    background: currentColor;
    flex-shrink: 0;
  }

  .service-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.6vw, 3.75rem);
    font-weight: 600;
    line-height: 1.06;
    letter-spacing: -0.018em;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .service-hero-title em {
    font-style: italic;
    color: var(--page-accent, var(--color-accent));
  }

  .service-hero-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 520px;
    margin-bottom: 36px;
  }

  .service-hero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .service-hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
    font-size: 0.9375rem;
    font-weight: 500;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .service-hero-cta-secondary:hover {
    gap: 12px;
    color: var(--page-accent, var(--color-accent));
  }

  /* ── Showcase column ──────────────────────────────── */
  .service-hero-showcase {
    position: relative;
    aspect-ratio: 1 / 1;
    max-width: 520px;
    width: 100%;
    justify-self: end;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 960px) {
    .service-hero-grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }

    .service-hero-showcase {
      max-width: 420px;
      justify-self: center;
    }
  }

  @media (max-width: 540px) {
    .service-hero {
      padding: calc(var(--nav-h) + 12px) 0 64px;
    }

    .service-hero-showcase {
      max-width: 320px;
    }
  }
</style>
