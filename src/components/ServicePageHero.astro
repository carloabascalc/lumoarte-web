---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta = { label: "Solicita tu cotización", href: "#cotiza" },
  secondaryCta,
} = Astro.props;
---

<section class="service-hero">
  <div class="container">
    <p class="service-hero-eyebrow" data-reveal>{eyebrow}</p>
    <h1 class="service-hero-title" data-reveal data-reveal-delay="0.06">{title}</h1>
    <p class="service-hero-sub" data-reveal data-reveal-delay="0.12">{subtitle}</p>
    <div class="service-hero-ctas" data-reveal data-reveal-delay="0.18">
      <a href={primaryCta.href} class="btn btn-primary">{primaryCta.label}</a>
      {secondaryCta && (
        <a href={secondaryCta.href} class="service-hero-cta-secondary">
          {secondaryCta.label}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .service-hero {
    padding: 56px 0 80px;
    background: var(--color-bg);
  }

  .service-hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 20px;
  }

  .service-hero-title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin-bottom: 28px;
    max-width: 880px;
  }

  .service-hero-sub {
    font-size: clamp(1rem, 1.6vw, 1.1875rem);
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 680px;
    margin-bottom: 40px;
  }

  .service-hero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .service-hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-accent);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: gap 0.2s ease;
  }

  .service-hero-cta-secondary:hover {
    gap: 10px;
  }

  @media (max-width: 768px) {
    .service-hero {
      padding: 40px 0 56px;
    }
  }
</style>
