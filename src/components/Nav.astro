---

<header class="nav" id="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="Lumo Arte">
      <img src="/images/logo-nav.png" alt="Lumo Arte" width="80" height="48" />
    </a>
    <nav>
      <a href="#cotiza" class="btn btn-primary nav-cta">Solicita tu proyecto</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .nav.scrolled {
    background: #fff;
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.07);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: filter 0.3s ease;
  }

  .nav.scrolled .nav-logo img {
    filter: none;
  }

  .nav-cta {
    padding: 10px 24px;
    font-size: 0.875rem;
  }
</style>

<script>
  const nav = document.getElementById("nav")!;
  const threshold = 80;

  function update() {
    nav.classList.toggle("scrolled", window.scrollY > threshold);
  }

  update();
  window.addEventListener("scroll", update, { passive: true });
</script>
