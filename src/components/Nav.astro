---
import { Image } from "astro:assets";
import logoNav from "../assets/logos/logo-nav.png";
import { SITE, services, getServiceUrl, isExternalService } from "../data/services";
import type { ServiceId } from "../data/services";

interface Props {
  variant?: "overlay" | "solid" | "emd";
  /** Required when variant === "emd": which service this EMD page belongs to. */
  emdService?: ServiceId;
}

const { variant = "overlay", emdService } = Astro.props;
const isEmd = variant === "emd";

// EMD nav uses absolute lumocancun.com URLs so the umbrella link works
// from any domain. Service-specific PDFs are picked from services.ts.
const emd = isEmd && emdService
  ? services.find((s) => s.id === emdService)
  : null;
const homeHref = isEmd ? `${SITE.url}/` : "/";
const serviciosHref = isEmd ? `${SITE.url}/#servicios` : "/#servicios";
const preciosHref = emd?.preciosPdf ?? "/precios-lumoarte.pdf";
const manualHref = emd?.manualPdf ?? "/manual-lumoarte.pdf";
const waHref = `https://wa.me/${SITE.whatsapp}`;
// EMD always renders on a solid surface (no overlay over hero photo)
const navClass = isEmd ? "nav nav--solid nav--emd" : `nav nav--${variant}`;
---

<header class={navClass} id="nav" data-variant={isEmd ? "solid" : variant}>
  <div class="nav-inner container">
    <a href={homeHref} class="nav-logo" aria-label={SITE.name}>
      <Image src={logoNav} alt={SITE.name} width={80} height={48} loading="eager" />
    </a>
    <nav class="nav-actions" aria-label="Navegación principal">
      <a href={serviciosHref} class="nav-link nav-link--desktop">Servicios</a>
      {!isEmd && (
        <a
          href="#cotiza"
          class="btn btn-primary nav-cta nav-cta--desktop"
        >Solicita tu cotización</a>
      )}
      {isEmd && (
        <a
          href={preciosHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn nav-pdf nav-pdf--primary"
        >Lista de precios ↓</a>
      )}
      {isEmd && (
        <a
          href={manualHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn nav-pdf nav-pdf--secondary nav-pdf--emd-manual"
        >Manual ↓</a>
      )}
      {isEmd && (
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn nav-wa"
          aria-label="WhatsApp"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.413c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        </a>
      )}
      {!isEmd && (
        <button
          class="nav-burger"
          id="navBurger"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="navDrawer"
          type="button"
        >
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      )}
    </nav>
  </div>
  {!isEmd && (
    <div class="nav-drawer" id="navDrawer" hidden>
      <a href="/#servicios" class="nav-drawer-link nav-drawer-link--head">Servicios</a>
      {services.map((s) => {
        const external = isExternalService(s);
        return (
          <a
            href={getServiceUrl(s)}
            class="nav-drawer-link nav-drawer-sub"
            {...(external ? { target: "_blank", rel: "noopener" } : {})}
          >{s.name}</a>
        );
      })}
      <a href="#cotiza" class="btn btn-primary nav-drawer-cta">Solicita tu cotización</a>
    </div>
  )}
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .nav.scrolled,
  .nav--solid {
    background: #fff;
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.07);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo img {
    height: 40px;
    width: auto;
    object-fit: contain;
    transition: filter 0.3s ease;
  }

  .nav--overlay:not(.scrolled) .nav-logo img {
    filter: brightness(0) invert(1);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text);
    padding: 10px 8px;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav--overlay:not(.scrolled) .nav-link {
    color: rgba(255, 255, 255, 0.9);
  }

  .nav--overlay:not(.scrolled) .nav-link:hover {
    color: #fff;
  }

  .nav-cta {
    padding: 11px 22px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .nav-pdf {
    padding: 10px 20px;
    font-size: 0.875rem;
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
    transition: background 0.2s, color 0.2s;
  }

  .nav-pdf:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .nav--overlay:not(.scrolled) .nav-pdf {
    border-color: rgba(255, 255, 255, 0.7);
    color: rgba(255, 255, 255, 0.9);
  }

  .nav--overlay:not(.scrolled) .nav-pdf:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border-color: #fff;
  }

  /* ── EMD WhatsApp button ───────────────────────────── */
  .nav-wa {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border-radius: 999px;
    background: #25D366;
    color: #fff;
    transition: background 0.2s, transform 0.1s;
  }

  .nav-wa:hover {
    background: #1ebd5b;
    transform: translateY(-1px);
  }

  /* ── Hamburger ─────────────────────────────────────── */
  .nav-burger {
    display: none;
    width: 44px;
    height: 44px;
    border-radius: 6px;
    background: transparent;
    border: 1px solid transparent;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    padding: 0;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .nav-burger span {
    display: block;
    width: 22px;
    height: 1.75px;
    background: var(--color-text);
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.2s ease, background 0.3s ease;
  }

  .nav--overlay:not(.scrolled) .nav-burger span {
    background: #fff;
  }

  .nav.is-open .nav-burger span {
    background: var(--color-accent);
  }

  .nav.is-open .nav-burger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav.is-open .nav-burger span:nth-child(2) {
    opacity: 0;
  }

  .nav.is-open .nav-burger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Drawer ────────────────────────────────────────── */
  .nav-drawer {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #fff;
    border-top: 1px solid var(--color-surface);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    padding: 16px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transform: translateY(-12px);
    opacity: 0;
    transition: transform 0.25s ease, opacity 0.25s ease;
    pointer-events: none;
  }

  .nav.is-open .nav-drawer {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .nav-drawer[hidden] {
    display: none;
  }

  .nav-drawer-link {
    display: block;
    padding: 12px 8px;
    font-size: 0.9375rem;
    color: var(--color-text);
    border-radius: 4px;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-drawer-link:hover {
    background: var(--color-bg-alt);
    color: var(--color-accent);
  }

  .nav-drawer-link--head {
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.02em;
    margin-top: 4px;
  }

  .nav-drawer-sub {
    padding-left: 20px;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .nav-drawer-cta {
    margin-top: 12px;
    justify-content: center;
    padding: 14px 20px;
  }

  /* ── Breakpoints ───────────────────────────────────── */
  @media (max-width: 720px) {
    .nav-link--desktop,
    .nav-cta--desktop,
    .nav-pdf {
      display: none;
    }

    .nav-burger {
      display: flex;
    }

    /* EMD nav has no burger — keep essential items visible on mobile */
    .nav--emd .nav-link--desktop {
      display: inline-flex;
      font-size: 0.8125rem;
      padding: 8px 6px;
    }

    .nav--emd .nav-pdf {
      display: inline-flex;
      padding: 8px 12px;
      font-size: 0.75rem;
    }

    /* Hide the manual PDF on the smallest screens to keep room for WhatsApp */
    .nav--emd .nav-pdf--emd-manual {
      display: none;
    }
  }

  @media (max-width: 380px) {
    .nav--emd .nav-pdf {
      padding: 6px 10px;
    }

    .nav--emd .nav-logo img {
      height: 32px;
    }
  }
</style>

<script>
  function bootNav() {
    const nav = document.getElementById("nav");
    const burger = document.getElementById("navBurger");
    const drawer = document.getElementById("navDrawer");
    if (!nav || !burger || !drawer) return;
    if (nav.dataset.booted === "1") return;
    nav.dataset.booted = "1";

    const variant = nav.dataset.variant ?? "overlay";
    const threshold = 80;

    function update() {
      if (variant === "solid") return;
      nav.classList.toggle("scrolled", window.scrollY > threshold);
    }

    update();
    if (variant === "overlay") {
      window.addEventListener("scroll", update, { passive: true });
    }

    function setOpen(open) {
      nav.classList.toggle("is-open", open);
      burger.setAttribute("aria-expanded", String(open));
      if (open) {
        drawer.removeAttribute("hidden");
      } else {
        // Allow close transition to finish before hiding from a11y tree
        setTimeout(() => {
          if (!nav.classList.contains("is-open")) {
            drawer.setAttribute("hidden", "");
          }
        }, 260);
      }
    }

    burger.addEventListener("click", () => {
      const open = !nav.classList.contains("is-open");
      setOpen(open);
    });

    drawer.addEventListener("click", (e) => {
      if (e.target instanceof HTMLAnchorElement) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && nav.classList.contains("is-open")) {
        setOpen(false);
        burger.focus();
      }
    });

    const mq = window.matchMedia("(min-width: 721px)");
    mq.addEventListener("change", (e) => {
      if (e.matches && nav.classList.contains("is-open")) setOpen(false);
    });
  }

  bootNav();
  document.addEventListener("astro:page-load", bootNav);
</script>
