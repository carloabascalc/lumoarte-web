---
---

<header class="nav" id="nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="Lumo Arte">
      <img src="/images/logo-nav.png" alt="Lumo Arte" width="80" height="48" />
    </a>
    <nav class="nav-actions">
      <a
        href="/precios-lumoarte.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="btn nav-pdf"
      >Lista de precios ↓</a>
      <a
        href="/manual-lumoarte.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="btn nav-pdf"
      >¿Cómo enviar tu proyecto? ↓</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-h);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .nav.scrolled {
    background: #fff;
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.07);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    transition: filter 0.3s ease;
  }

  .nav.scrolled .nav-logo img {
    filter: none;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-pdf {
    padding: 10px 20px;
    font-size: 0.875rem;
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    background: transparent;
    transition: background 0.2s, color 0.2s;
  }

  .nav-pdf:hover {
    background: var(--color-accent);
    color: #fff;
  }

  /* Keep PDF link visible on dark (hero) background */
  .nav:not(.scrolled) .nav-pdf {
    border-color: rgba(255, 255, 255, 0.7);
    color: rgba(255, 255, 255, 0.9);
  }

  .nav:not(.scrolled) .nav-pdf:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border-color: #fff;
  }

  @media (max-width: 540px) {
    .nav-actions {
      gap: 8px;
    }

    .nav-pdf {
      padding: 8px 12px;
      font-size: 0.75rem;
    }
  }
</style>

<script>
  const nav = document.getElementById("nav")!;
  const threshold = 80;

  function update() {
    nav.classList.toggle("scrolled", window.scrollY > threshold);
  }

  update();
  window.addEventListener("scroll", update, { passive: true });
</script>
