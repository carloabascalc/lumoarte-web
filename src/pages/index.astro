---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import MaterialAssembly from "../components/MaterialAssembly.astro";
import Gallery from "../components/Gallery.astro";
import InstagramCTA from "../components/InstagramCTA.astro";
import QuoteForm from "../components/QuoteForm.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
---

<Base
  title="Lumo Arte — Fabricación digital en Cancún | Corte láser, impresión 3D y gran formato"
  description="Corte láser, impresión 3D e impresión gran formato en Cancún. Un solo taller, tres servicios. Cotización por WhatsApp en menos de 24 horas."
  ogImage="/og/default.jpg"
  schemaType="LocalBusiness"
>
  <Nav variant="solid" />
  <main>
    <Hero />
    <ServicesGrid />
    <MaterialAssembly />
    <Gallery
      title="Trabajos recientes"
      subtitle="Una muestra del taller. Para ver más por servicio, visita la página correspondiente."
    />
    <InstagramCTA />
    <QuoteForm />
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>
