---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { SITE } from "../../data/services";

const articles = [
  {
    slug: "preparar-archivo-corte-laser",
    topic: "Corte láser",
    title: "Cómo preparar un archivo para corte láser",
    excerpt:
      "Guía práctica para preparar archivos vectoriales que cortan limpio a la primera: trazos vs rellenos, escala, capas, formatos aceptados y errores comunes.",
    readingTime: "6 min",
    datePublished: "2026-05-27",
  },
  {
    slug: "fdm-vs-resina",
    topic: "Impresión 3D",
    title: "FDM vs resina: cuál impresión 3D elegir para tu proyecto",
    excerpt:
      "Comparativa práctica entre FDM y resina: precisión, costo, materiales, tamaño máximo, tiempos y casos de uso reales.",
    readingTime: "7 min",
    datePublished: "2026-05-27",
  },
  {
    slug: "sublimacion-vs-vinil",
    topic: "Impresión gran formato",
    title: "Sublimación vs vinil: cuál técnica conviene a tu proyecto",
    excerpt:
      "Cuándo usar sublimación vs impresión de vinil: materiales compatibles, durabilidad, costo, acabados y casos de uso.",
    readingTime: "6 min",
    datePublished: "2026-05-27",
  },
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  url: `${SITE.url}/recursos`,
  name: "Recursos — Lumo Cancún",
  description:
    "Guías técnicas sobre fabricación digital: corte láser, impresión 3D e impresión de gran formato.",
  publisher: { "@id": `${SITE.url}#organization` },
  hasPart: articles.map((a) => ({
    "@type": "Article",
    headline: a.title,
    url: `${SITE.url}/recursos/${a.slug}`,
    datePublished: a.datePublished,
    author: { "@id": `${SITE.url}#founder` },
  })),
};
---

<Base
  title="Recursos — Guías de fabricación digital | Lumo Cancún"
  description="Guías técnicas sobre fabricación digital en Cancún: cómo preparar archivos de corte láser, cuándo usar FDM vs resina, diferencias entre sublimación y vinil."
  canonical="/recursos"
  ogImage="/og/default.jpg"
  extraSchemas={[collectionSchema]}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Recursos" },
      ]}
    />

    <article class="recursos-page">
      <header class="recursos-hero container">
        <p class="recursos-eyebrow" data-reveal>Recursos</p>
        <h1 class="recursos-h1" data-reveal data-reveal-delay="0.06">
          Guías prácticas de fabricación digital.
        </h1>
        <p class="recursos-lede" data-reveal data-reveal-delay="0.12">
          Lo que nos preguntan más seguido, explicado en detalle. Material
          escrito por nuestro equipo, no copiado de internet.
        </p>
      </header>

      <section class="recursos-list-section section">
        <div class="container">
          <ul class="recursos-list" role="list">
            {articles.map((a) => (
              <li class="recurso-card" data-reveal>
                <a class="recurso-link" href={`/recursos/${a.slug}`}>
                  <p class="recurso-topic">{a.topic}</p>
                  <h2 class="recurso-title">{a.title}</h2>
                  <p class="recurso-excerpt">{a.excerpt}</p>
                  <p class="recurso-meta">
                    <span>
                      <time datetime={a.datePublished}>
                        {new Date(a.datePublished).toLocaleDateString("es-MX", { year: "numeric", month: "long", day: "numeric" })}
                      </time>
                      <span aria-hidden="true">·</span>
                      {a.readingTime} de lectura
                    </span>
                    <span class="recurso-arrow" aria-hidden="true">→</span>
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </article>
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  .recursos-page {
    padding-bottom: 60px;
  }

  .recursos-hero {
    padding: 32px 24px 16px;
    max-width: 820px;
    margin: 0 auto;
  }

  .recursos-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 18px;
  }

  .recursos-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 22px;
  }

  .recursos-lede {
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    line-height: 1.65;
    color: var(--color-muted);
    max-width: 580px;
  }

  .recursos-list-section {
    padding-top: 32px;
  }

  .recursos-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--color-surface);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    overflow: hidden;
  }

  .recurso-card {
    background: var(--color-bg);
    transition: background 0.2s ease;
  }

  .recurso-card:hover {
    background: #fff;
  }

  .recurso-link {
    display: block;
    padding: 32px 32px 28px;
    color: inherit;
  }

  .recurso-topic {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .recurso-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.25;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }

  .recurso-excerpt {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 18px;
    max-width: 720px;
  }

  .recurso-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .recurso-arrow {
    color: var(--color-accent);
    font-size: 1.125rem;
    transition: transform 0.2s ease;
  }

  .recurso-card:hover .recurso-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .recurso-link {
      padding: 24px 22px 22px;
    }
  }
</style>
