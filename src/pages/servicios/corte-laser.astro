---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServicePageHero from "../../components/ServicePageHero.astro";
import ServicePdfs from "../../components/ServicePdfs.astro";
import PricingFormula from "../../components/PricingFormula.astro";
import PriceTable from "../../components/PriceTable.astro";
import LaserShowcase from "../../components/LaserShowcase.astro";
import LaserAssembly from "../../components/LaserAssembly.astro";
import Materials from "../../components/Materials.astro";
import Gallery from "../../components/Gallery.astro";
import FAQ from "../../components/FAQ.astro";
import CrossServices from "../../components/CrossServices.astro";
import InstagramCTA from "../../components/InstagramCTA.astro";
import QuoteForm from "../../components/QuoteForm.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getService, SITE } from "../../data/services";
import { PRICING } from "../../data/pricing";

const service = getService("corte-laser");

// Rango de precios de materiales (sin IVA) para el schema — lo mismo que se
// muestra en HTML en <PriceTable>. Mantiene el dato estructurado en sync con
// la tabla visible, ambos desde src/data/pricing.ts.
const materialPrices = (PRICING["corte-laser"].materiales?.groups ?? [])
  .flatMap((g) => g.items.map((i) => i.price));

const sectores = [
  {
    label: "Arquitectura y diseño",
    description:
      "Maquetas a escala, paneles calados, celosías, planos en relieve y elementos decorativos para proyectos residenciales y comerciales.",
  },
  {
    label: "Eventos y bodas",
    description:
      "Invitaciones intricadas, números de mesa, seating charts, recuerdos personalizados y elementos de decoración únicos.",
  },
  {
    label: "Retail y branding",
    description:
      "Señalética interior y exterior, displays, escaparates, lettering volumétrico y piezas de marca a medida.",
  },
  {
    label: "Regalos corporativos",
    description:
      "Placas de reconocimiento, premios, llaveros, kits de bienvenida grabados con el logo de tu empresa.",
  },
  {
    label: "Decoración y arte",
    description:
      "Lámparas, esculturas, marcos, cuadros y piezas únicas para hogares, oficinas y espacios públicos.",
  },
  {
    label: "Producción en serie",
    description:
      "Lotes de cientos o miles de piezas con la misma precisión que una pieza única — souvenirs, líneas de producto, kits.",
  },
];

const serviceSchema = {
  name: service.name,
  serviceType: "Laser cutting and engraving",
  description: service.metaDescription,
  url: `${SITE.url}${service.slug}`,
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "MXN",
    lowPrice: Math.min(...materialPrices),
    highPrice: Math.max(...materialPrices),
    offerCount: materialPrices.length,
    description:
      "Precio de lámina completa de materiales para corte láser (MXN, sin IVA). El precio final de cada pieza depende del material y del tiempo de máquina.",
  },
};

const faqs = [
  {
    question: "¿Cuánto tarda un trabajo de corte láser?",
    answer:
      "Habitualmente menos de una semana. Cuando hay disponibilidad, una pieza pequeña (invitaciones, regalos, llaveros, placas) puede salir el mismo día. Si tu proyecto es urgente, dilo en la cotización — siempre revisamos prioridades.",
  },
  {
    question: "¿Qué tipo de archivo necesito enviar?",
    answer:
      "Trabajamos con vectores en formato AI, EPS, SVG, PDF o DXF. Si solo tienes una imagen JPG o PNG nítida, podemos vectorizarla por ti — incluido en la cotización si no es muy compleja. Lo importante es que las líneas estén limpias y la escala sea la real (en milímetros o centímetros).",
  },
  {
    question: "¿Cuál es el tamaño máximo de corte?",
    answer:
      "El área útil de nuestra máquina es de 130 × 90 cm en una sola pieza. Para piezas más grandes, las dividimos en módulos que ensamblan invisiblemente — así hemos hecho biombos de 2.5 m, paneles de 3 m y celosías arquitectónicas a escala completa.",
  },
  {
    question: "¿Aceptan pedidos de una sola pieza?",
    answer:
      "Sí. Cobramos por minuto de máquina, no por mínimo de lote. Una sola pieza personalizada (un regalo, un prototipo arquitectónico) puede salir el mismo día cuando hay disponibilidad. Para producción en serie ofrecemos descuento por volumen.",
  },
  {
    question: "¿Hacen entrega o envíos?",
    answer:
      "En Cancún hacemos entrega a domicilio dentro de la zona metropolitana con costo según ubicación. Para Playa del Carmen, Tulum, Mérida y otras ciudades enviamos por paquetería (DHL, Estafeta) — el costo lo agregamos a la cotización. También puedes recoger en el taller en Retorno Tejón, Supermanzana 20.",
  },
  {
    question: "¿Cómo pago?",
    answer:
      "Aceptamos transferencia bancaria, depósito en efectivo, tarjeta de débito y crédito (con pequeño cargo bancario). Para producciones grandes pedimos 50% de anticipo y 50% al entregar. Para piezas únicas y trabajos pequeños el pago es completo al confirmar.",
  },
];

const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Base
  title={`${service.name} en Cancún | Lumo Cancún`}
  description={service.metaDescription}
  canonical={service.slug}
  ogImage="/og/corte-laser.jpg"
  schemaType="Service"
  schemaData={serviceSchema}
  extraSchemas={[faqPageSchema]}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/#servicios" },
        { label: service.name },
      ]}
    />

    <ServicePageHero
      eyebrow="Precisión milimétrica"
      title="Corte láser en <em>Cancún</em> que le da forma a tus ideas"
      subtitle="Cortamos y grabamos materiales con precisión milimétrica. Desde una pieza única hasta producción en serie de miles de unidades, con acabados limpios y repetibles."
      primaryCta={{ label: "Solicita tu cotización", href: "#cotiza" }}
      secondaryCta={{ label: "Ver materiales", href: "#materiales" }}
      service="laser"
    >
      <LaserShowcase slot="showcase" />
    </ServicePageHero>

    <ServicePdfs service={service} />

    <LaserAssembly />

    <Materials />

    <PricingFormula serviceId="corte-laser" preciosPdf={service.preciosPdf} />

    <PriceTable serviceId="corte-laser" />

    <section class="sectores section">
      <div class="container">
        <div class="section-header">
          <p class="sectores-eyebrow" data-reveal>Para quién trabajamos</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Sectores que confían en el corte láser
          </h2>
          <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
            El láser es uno de los procesos más versátiles que existen. Estos
            son los sectores donde más se aprovecha lo que sale de nuestro
            taller.
          </p>
        </div>
        <ul class="sectores-grid" role="list">
          {sectores.map((s, i) => (
            <li class="sector-card" data-reveal data-reveal-delay={`${0.04 + i * 0.04}`}>
              <h3 class="sector-name">{s.label}</h3>
              <p class="sector-description">{s.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <Gallery
      filterService="corte-laser"
      title="Trabajos de corte láser"
      subtitle="Una selección del taller — productos terminados, lifestyle y trabajos a escala industrial."
    />

    <InstagramCTA />

    <CrossServices excludeId="corte-laser" />

    <section class="recurso-relacionado">
      <div class="container">
        <p class="rr-eyebrow">Lectura recomendada</p>
        <a class="rr-card" href="/recursos/preparar-archivo-corte-laser">
          <div class="rr-text">
            <p class="rr-topic">Corte láser</p>
            <h3 class="rr-title">Cómo preparar un archivo para corte láser</h3>
            <p class="rr-excerpt">Formatos aceptados, regla de trazos vs rellenos, escala real, capas y los cinco errores más comunes.</p>
          </div>
          <span class="rr-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <FAQ
      title="Preguntas frecuentes sobre corte láser"
      subtitle="Las dudas que nos hacen más seguido. Si la tuya no aparece, mándanos un WhatsApp."
      items={faqs}
    />

    <QuoteForm defaultService="corte-laser" />
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  .sectores {
    background: var(--color-bg-alt);
  }

  .sectores-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .sectores-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    overflow: hidden;
  }

  @media (max-width: 880px) {
    .sectores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .sectores-grid {
      grid-template-columns: 1fr;
    }
  }

  .sector-card {
    background: var(--color-bg);
    padding: 36px 32px;
    transition: background 0.25s ease;
  }

  .sector-card:hover {
    background: #fff;
  }

  .sector-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .sector-description {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .sector-card {
      padding: 28px 24px;
    }
  }

  /* ── Recurso relacionado ── */
  .recurso-relacionado {
    padding: 48px 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-surface);
  }

  .rr-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 14px;
  }

  .rr-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    padding: 28px 32px;
    transition: border-color 0.2s ease, background 0.2s ease;
    color: inherit;
  }

  .rr-card:hover {
    border-color: var(--color-accent);
    background: #fff;
  }

  .rr-card:hover .rr-arrow {
    transform: translateX(4px);
  }

  .rr-topic {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 8px;
  }

  .rr-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.25;
  }

  .rr-excerpt {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 640px;
  }

  .rr-arrow {
    font-size: 1.5rem;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  @media (max-width: 640px) {
    .rr-card {
      padding: 22px 20px;
    }
    .rr-arrow {
      display: none;
    }
  }
</style>
