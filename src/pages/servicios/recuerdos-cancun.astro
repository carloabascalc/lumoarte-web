<script>
  import { initCardTilt } from "../../scripts/cardTilt";

  const WA_NUMBER = "528138913891";

  function init() {
    // Catalog card "Pedir" → preselect product in form + scroll
    document.querySelectorAll<HTMLElement>(".catalog-cta").forEach((btn) => {
      btn.addEventListener("click", () => {
        const value = btn.dataset.pick || "";
        const select = document.getElementById("ofProduct") as HTMLSelectElement | null;
        if (select) select.value = value;
        document.getElementById("orderForm")?.scrollIntoView({ behavior: "smooth", block: "start" });
        (document.getElementById("ofDetails") as HTMLTextAreaElement | null)?.focus();
      });
    });

    // Form submit → build WhatsApp message
    document.getElementById("orderForm")?.addEventListener("submit", (e) => {
      e.preventDefault();
      const get = (id: string) =>
        ((document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null)?.value || "").trim();

      const product = get("ofProduct");
      const qty = get("ofQty");
      const details = get("ofDetails");
      const name = get("ofName");
      const phone = get("ofPhone");

      if (!product || !name || !phone) {
        alert("Falta producto, nombre o WhatsApp.");
        return;
      }

      const productLabel: Record<string, string> = {
        llavero: "Llavero personalizado",
        termo: "Termo grabado",
        portavasos: "Set de portavasos",
        custom: "Pedido a la medida",
      };

      const lines = [
        "Hola Lumo, quiero hacer un pedido:",
        "",
        `Producto: ${productLabel[product] || product}`,
        qty ? `Cantidad: ${qty}` : "",
        details ? `Detalles: ${details}` : "",
        "",
        `Contacto: ${name} · ${phone}`,
      ].filter(Boolean);

      const msg = encodeURIComponent(lines.join("\n"));
      window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, "_blank");
    });

    initCardTilt(".paso-card[data-tilt]");
    initCardTilt(".catalog-card[data-tilt]");
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
