</style>

<script>
  import { initCardTilt } from "../../scripts/cardTilt";

  type Bundle = 1 | 2 | 3 | 4 | 5;
  type Product = 'A' | 'B' | 'C' | 'D' | 'termo' | 'portavasos' | null;

  const WA_NUMBER = '528138913891';

  const BUNDLE_PRICE: Record<Bundle, number> = { 1: 11, 2: 20, 3: 29, 4: 35, 5: 40 };

  const PROD_LABEL: Record<string, string> = {
    A: 'Llavero Ocean',
    B: 'Llavero Tropical',
    C: 'Llavero Maya',
    D: 'Llavero Fiesta',
    termo: 'Termo 20oz',
    portavasos: 'Set 5 portavasos',
  };

  const state = {
    product: null as Product,
    bundle: 1 as Bundle,
    names: [''] as string[],
    addons: [{ opener: false, airtag: false }] as Array<{ opener: boolean; airtag: boolean }>,
    termo: { cancun: false, name: false, nameText: '' },
    delivery: 'hotel' as 'hotel' | 'address',
    hotel: '',
    room: '',
    addrCountry: '',
    addrStreet: '',
    clientName: '',
    clientPhone: '',
    clientEmail: '',
  };

  const FLOWS = {
    keychain: ['product', 'names', 'addons', 'delivery', 'summary'],
    termo: ['product', 'termo', 'delivery', 'summary'],
    portavasos: ['product', 'delivery', 'summary'],
  };

  function currentFlow(): string[] {
    if (!state.product) return ['product'];
    if (state.product === 'termo') return FLOWS.termo;
    if (state.product === 'portavasos') return FLOWS.portavasos;
    return FLOWS.keychain;
  }

  let stepIdx = 0;

  function isKeychain(p: Product): boolean {
    return p === 'A' || p === 'B' || p === 'C' || p === 'D';
  }

  function calcTotal(): number {
    if (!state.product) return 0;
    if (state.product === 'portavasos') return 15;
    if (state.product === 'termo') {
      const extras = (state.termo.cancun ? 5 : 0) + (state.termo.name ? 5 : 0);
      return 15 + extras;
    }
    let t = BUNDLE_PRICE[state.bundle] || 11;
    state.addons.forEach((a) => {
      if (a.opener) t += 1;
      if (a.airtag) t += 4;
    });
    return t;
  }

  function showStep(idx: number) {
    const flow = currentFlow();
    document.querySelectorAll<HTMLElement>('.wiz-panel').forEach((p) => {
      p.classList.toggle('visible', p.dataset.panel === flow[idx]);
    });
    document.querySelectorAll<HTMLElement>('.wiz-dot').forEach((d, i) => {
      d.classList.remove('active', 'done');
      if (i < flow.length) {
        if (i === idx) d.classList.add('active');
        else if (i < idx) d.classList.add('done');
      } else {
        d.style.display = 'none';
        return;
      }
      d.style.display = '';
    });

    const back = document.getElementById('wizBack') as HTMLButtonElement;
    const next = document.getElementById('wizNext') as HTMLButtonElement;
    back.disabled = idx === 0;
    if (idx >= flow.length - 1) next.classList.add('hidden');
    else next.classList.remove('hidden');

    if (flow[idx] === 'addons') renderAddons();
    if (flow[idx] === 'summary') updateSummary();
    refreshRunningTotal();
  }

  function refreshRunningTotal() {
    const el = document.getElementById('runningTotal');
    if (el) el.textContent = String(calcTotal());
  }

  function setProduct(p: Product) {
    state.product = p;
    document.querySelectorAll<HTMLElement>('.prod-card').forEach((c) => {
      c.classList.toggle('selected', c.dataset.product === p);
    });
    if (isKeychain(p)) {
      state.names = Array(state.bundle).fill('');
      state.addons = Array.from({ length: state.bundle }, () => ({ opener: false, airtag: false }));
      renderNameInputs();
    }
    refreshRunningTotal();
  }

  function setBundle(b: Bundle) {
    state.bundle = b;
    while (state.names.length < b) state.names.push('');
    while (state.names.length > b) state.names.pop();
    while (state.addons.length < b) state.addons.push({ opener: false, airtag: false });
    while (state.addons.length > b) state.addons.pop();
    document.querySelectorAll<HTMLElement>('.bundle-opt').forEach((o) => {
      o.classList.toggle('selected', Number(o.dataset.bundle) === b);
    });
    renderNameInputs();
    refreshRunningTotal();
  }

  function renderNameInputs() {
    const wrap = document.getElementById('nameInputs');
    if (!wrap) return;
    wrap.innerHTML = '';
    for (let i = 0; i < state.bundle; i++) {
      const row = document.createElement('div');
      row.className = 'name-input-row';
      row.innerHTML = `
        <label>Llavero ${i + 1}</label>
        <input type="text" maxlength="15" value="${state.names[i] || ''}" data-name-idx="${i}" placeholder="Ej. NIRVANA" />
        <span class="char-count" data-name-count="${i}">${(state.names[i] || '').length}/15</span>
      `;
      wrap.appendChild(row);
    }
    wrap.querySelectorAll<HTMLInputElement>('input').forEach((inp) => {
      inp.addEventListener('input', () => {
        const i = Number(inp.dataset.nameIdx);
        state.names[i] = inp.value.toUpperCase();
        inp.value = state.names[i];
        const counter = wrap.querySelector(`[data-name-count="${i}"]`);
        if (counter) counter.textContent = `${state.names[i].length}/15`;
        if (i === 0) {
          const prev = document.getElementById('previewName');
          if (prev) prev.textContent = state.names[0] || '—';
        }
      });
    });
    const prev = document.getElementById('previewName');
    if (prev) prev.textContent = state.names[0] || '—';
  }

  function renderAddons() {
    const list = document.getElementById('addonsList');
    if (!list) return;
    list.innerHTML = '';
    for (let i = 0; i < state.bundle; i++) {
      const name = state.names[i] || `Llavero ${i + 1}`;
      const block = document.createElement('div');
      block.className = 'addon-block';
      block.innerHTML = `
        <div class="addon-header">${name}</div>
        <button type="button" class="addon-row${state.addons[i].opener ? ' selected' : ''}" data-addon="opener" data-i="${i}">
          <span class="addon-info">
            <span class="addon-name">Destapador integrado</span>
            <span class="addon-desc">Abre tu chela donde sea.</span>
          </span>
          <span class="addon-right">
            <span class="addon-price">+$1</span>
            <span class="addon-check"></span>
          </span>
        </button>
        <button type="button" class="addon-row${state.addons[i].airtag ? ' selected' : ''}" data-addon="airtag" data-i="${i}">
          <span class="addon-info">
            <span class="addon-name">Soporte para AirTag</span>
            <span class="addon-desc">Rastreador Apple no incluido.</span>
          </span>
          <span class="addon-right">
            <span class="addon-price">+$4</span>
            <span class="addon-check"></span>
          </span>
        </button>
      `;
      list.appendChild(block);
    }
    list.querySelectorAll<HTMLElement>('.addon-row').forEach((row) => {
      row.addEventListener('click', () => {
        const i = Number(row.dataset.i);
        const key = row.dataset.addon as 'opener' | 'airtag';
        state.addons[i][key] = !state.addons[i][key];
        row.classList.toggle('selected', state.addons[i][key]);
        refreshRunningTotal();
      });
    });
  }

  function refreshTermoPreview() {
    const cancun = document.getElementById('tepCancun');
    const name = document.getElementById('tepName');
    if (cancun) cancun.classList.toggle('dim', !state.termo.cancun);
    if (name) {
      name.classList.toggle('dim', !state.termo.name);
      name.textContent = state.termo.nameText || (state.termo.name ? '…' : '—');
    }
    refreshRunningTotal();
  }

  function updateSummary() {
    const total = calcTotal();
    let label = '';
    let extras = '';

    if (state.product === 'portavasos') {
      label = 'Set 5 portavasos';
    } else if (state.product === 'termo') {
      label = 'Termo 20oz';
      const eng: string[] = [];
      if (state.termo.cancun) eng.push('CANCUN');
      if (state.termo.name && state.termo.nameText) eng.push(state.termo.nameText);
      if (eng.length) extras = `Grabado: ${eng.join(' + ')}`;
    } else if (state.product) {
      label = `${state.bundle}× ${PROD_LABEL[state.product]}`;
      const nameList = state.names.filter(Boolean).join(', ');
      if (nameList) extras = `Nombres: ${nameList}`;
      const opener = state.addons.filter((a) => a.opener).length;
      const airtag = state.addons.filter((a) => a.airtag).length;
      if (opener || airtag) {
        const e: string[] = [];
        if (opener) e.push(`${opener} destapador${opener > 1 ? 'es' : ''}`);
        if (airtag) e.push(`${airtag} soporte${airtag > 1 ? 's' : ''} AirTag`);
        extras += (extras ? ' · ' : '') + e.join(', ');
      }
    }

    const sumProduct = document.getElementById('sumProduct');
    if (sumProduct) sumProduct.textContent = label;
    const extrasRow = document.getElementById('sumExtrasRow');
    const extrasEl = document.getElementById('sumExtras');
    if (extras && extrasRow && extrasEl) {
      extrasRow.hidden = false;
      extrasEl.textContent = extras;
    } else if (extrasRow) {
      extrasRow.hidden = true;
    }

    const sumDelivery = document.getElementById('sumDelivery');
    if (sumDelivery) {
      sumDelivery.textContent =
        state.delivery === 'hotel'
          ? state.hotel
            ? `Hotel ${state.hotel} · Hab. ${state.room || '—'}`
            : 'Hotel en Cancún (sin costo)'
          : state.addrCountry
            ? `Envío a ${state.addrCountry}`
            : 'Envío a casa por FedEx';
    }

    const sumTotal = document.getElementById('sumTotal');
    if (sumTotal) sumTotal.textContent = String(total);
  }

  function buildWaMessage(): string {
    const total = calcTotal();
    const lines: string[] = [];
    lines.push('Hola Lumo, quiero pedir esto desde la página:');
    lines.push('');
    if (state.product === 'portavasos') {
      lines.push('• Set 5 portavasos personalizados');
    } else if (state.product === 'termo') {
      const eng: string[] = [];
      if (state.termo.cancun) eng.push('CANCUN');
      if (state.termo.name && state.termo.nameText) eng.push(state.termo.nameText);
      lines.push(`• Termo 20oz acero inoxidable`);
      if (eng.length) lines.push(`  Grabado: ${eng.join(' + ')}`);
    } else if (state.product) {
      lines.push(`• ${state.bundle}× ${PROD_LABEL[state.product]}`);
      state.names.forEach((n, i) => {
        if (n) lines.push(`  Llavero ${i + 1}: ${n}`);
      });
      const opener = state.addons.filter((a) => a.opener).length;
      const airtag = state.addons.filter((a) => a.airtag).length;
      if (opener) lines.push(`  + ${opener} destapador${opener > 1 ? 'es' : ''} (+$${opener})`);
      if (airtag) lines.push(`  + ${airtag} soporte${airtag > 1 ? 's' : ''} AirTag (+$${airtag * 4})`);
    }
    lines.push('');
    if (state.delivery === 'hotel') {
      lines.push(`Entrega: Hotel ${state.hotel || '(pendiente)'} · Hab. ${state.room || '(pendiente)'}`);
    } else {
      lines.push(`Envío: ${state.addrCountry || '(país pendiente)'} — ${state.addrStreet || '(dirección pendiente)'}`);
    }
    lines.push('');
    lines.push(`Total estimado: $${total} USD`);
    lines.push('');
    lines.push(`Contacto: ${state.clientName || '(nombre)'} · ${state.clientPhone || '(WhatsApp)'} · ${state.clientEmail || '(email)'}`);
    return lines.join('\n');
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.prod-card').forEach((c) => {
      c.addEventListener('click', () => {
        setProduct(c.dataset.product as Product);
        setTimeout(() => {
          stepIdx = 1;
          showStep(stepIdx);
        }, 150);
      });
    });

    document.querySelectorAll<HTMLElement>('.bundle-opt').forEach((b) => {
      b.addEventListener('click', () => setBundle(Number(b.dataset.bundle) as Bundle));
    });

    document.querySelectorAll<HTMLElement>('.termo-opt').forEach((t) => {
      t.addEventListener('click', () => {
        const key = t.dataset.termo as 'cancun' | 'name';
        state.termo[key] = !state.termo[key];
        t.classList.toggle('selected', state.termo[key]);
        const wrap = document.getElementById('termoNameWrap');
        if (wrap) wrap.classList.toggle('hidden', !state.termo.name);
        if (!state.termo.name) state.termo.nameText = '';
        refreshTermoPreview();
      });
    });
    const termoNameField = document.getElementById('termoNameField') as HTMLInputElement | null;
    if (termoNameField) {
      termoNameField.addEventListener('input', () => {
        state.termo.nameText = termoNameField.value.toUpperCase();
        termoNameField.value = state.termo.nameText;
        const count = document.getElementById('termoNameCount');
        if (count) count.textContent = `${state.termo.nameText.length}/15`;
        refreshTermoPreview();
      });
    }

    document.querySelectorAll<HTMLElement>('.del-opt').forEach((d) => {
      d.addEventListener('click', () => {
        state.delivery = d.dataset.delivery as 'hotel' | 'address';
        document.querySelectorAll<HTMLElement>('.del-opt').forEach((o) => {
          o.classList.toggle('selected', o === d);
        });
        document.getElementById('delHotelForm')?.classList.toggle('hidden', state.delivery !== 'hotel');
        document.getElementById('delAddressForm')?.classList.toggle('hidden', state.delivery !== 'address');
      });
    });

    const bind = (id: string, key: keyof typeof state) => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el) el.addEventListener('input', () => ((state as Record<string, unknown>)[key] = el.value));
    };
    bind('hotelName', 'hotel');
    bind('hotelRoom', 'room');
    bind('addrCountry', 'addrCountry');
    bind('addrStreet', 'addrStreet');
    bind('clientName', 'clientName');
    bind('clientPhone', 'clientPhone');
    bind('clientEmail', 'clientEmail');

    document.getElementById('wizBack')?.addEventListener('click', () => {
      if (stepIdx > 0) {
        stepIdx -= 1;
        showStep(stepIdx);
      }
    });
    document.getElementById('wizNext')?.addEventListener('click', () => {
      const flow = currentFlow();
      if (stepIdx < flow.length - 1) {
        stepIdx += 1;
        showStep(stepIdx);
      }
    });

    document.getElementById('btnSubmit')?.addEventListener('click', (e) => {
      e.preventDefault();
      const msg = encodeURIComponent(buildWaMessage());
      window.open(`https://wa.me/${WA_NUMBER}?text=${msg}`, '_blank');
    });

    renderNameInputs();
    showStep(0);
    initCardTilt('.paso-card[data-tilt]');
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
