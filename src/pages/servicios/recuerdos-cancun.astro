---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServicePageHero from "../../components/ServicePageHero.astro";
import RecuerdosShowcase from "../../components/RecuerdosShowcase.astro";
import CrossServices from "../../components/CrossServices.astro";
import FAQ from "../../components/FAQ.astro";
import InstagramCTA from "../../components/InstagramCTA.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getService, SITE } from "../../data/services";

const service = getService("recuerdos-cancun");

const serviceSchema = {
  name: service.name,
  serviceType: "Personalized souvenirs",
  description: service.metaDescription,
  url: `${SITE.url}${service.slug}`,
};

const pasos = [
  {
    n: "01",
    titulo: "Elige tu pieza",
    texto: "Llavero, termo, portavasos o algo a tu medida — diseño nuevo, logo de empresa, regalo de evento. Nosotros nos adaptamos.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="20"/><circle cx="24" cy="24" r="12"/><path d="M24 4v40M4 24h40"/></svg>`,
  },
  {
    n: "02",
    titulo: "Cuéntanos los detalles",
    texto: "Cantidad, nombres, fecha, diseño. Por WhatsApp acordamos lo que hace falta y te pasamos el precio final.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 38h32"/><path d="M14 32h20"/><path d="M16 14l4-8 4 8 4-8 4 8 4-8"/><path d="M10 24l4-4 4 4 4-4 4 4 4-4 4 4 4-4 4 4"/></svg>`,
  },
  {
    n: "03",
    titulo: "Lo recoges o te lo enviamos",
    texto: "Recoges sin costo en el taller (Retorno Tejón, SM 20), envío local en Cancún, o paquetería FedEx a otra ciudad. 72 h hábiles desde que confirmas el pago.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 42V18l18-10 18 10v24"/><path d="M6 42h36"/><path d="M18 42v-12h12v12"/><path d="M16 22h.01M28 22h.01M16 30h.01M28 30h.01"/></svg>`,
  },
];

const catalogo = [
  {
    id: "llavero",
    eyebrow: "Impresión 3D · Multi-color",
    name: "Llaveros",
    desc: "Cuatro diseños inspirados en Cancún o un modelo nuevo si tienes algo en mente. Con nombre grabado o sin él.",
    desde: "Desde $11 USD",
    bullets: ["1 a 50 piezas", "Hasta 15 caracteres grabados", "Add-ons: destapador, soporte AirTag"],
    icon: `<svg viewBox="0 0 56 72" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="28" cy="10" r="6"/><rect x="26" y="16" width="4" height="8" rx="1"/><rect x="14" y="24" width="28" height="42" rx="6" fill="rgba(165,58,4,0.10)"/><path d="M20 36h16M20 44h12M20 52h16"/></svg>`,
  },
  {
    id: "termo",
    eyebrow: "Grabado láser · Acero",
    name: "Termo 20oz",
    desc: "Acero inoxidable doble pared, mantiene frío 24h y caliente 12h. Grabado láser permanente — no se borra ni se despinta.",
    desde: "Desde $15 USD",
    bullets: ["591 ml · tapa hermética", "Grabamos CANCUN, tu nombre, o ambos", "Logo de empresa para pedidos 10+"],
    icon: `<svg viewBox="0 0 56 72" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="20" y="6" width="16" height="6" rx="2"/><rect x="18" y="12" width="20" height="3" rx="1"/><rect x="22" y="15" width="12" height="2"/><rect x="16" y="17" width="24" height="46" rx="3" fill="rgba(165,58,4,0.10)"/><path d="M22 28h12M22 36h12M22 44h8"/><rect x="20" y="63" width="16" height="3" rx="1"/></svg>`,
  },
  {
    id: "portavasos",
    eyebrow: "Corte láser · MDF",
    name: "Set de portavasos",
    desc: "Cinco portavasos cortados y grabados en MDF sellado contra humedad. Tu nombre, fecha, monograma o diseño a tu gusto.",
    desde: "$15 USD el set",
    bullets: ["5 piezas de 10 × 10 cm", "MDF sellado", "Caja de presentación incluida"],
    icon: `<svg viewBox="0 0 56 72" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="28" cy="56" rx="20" ry="5" fill="rgba(165,58,4,0.10)"/><ellipse cx="28" cy="50" rx="20" ry="5"/><ellipse cx="28" cy="44" rx="20" ry="5"/><ellipse cx="28" cy="38" rx="20" ry="5"/><ellipse cx="28" cy="32" rx="20" ry="5" fill="rgba(165,58,4,0.18)"/><text x="28" y="36" text-anchor="middle" font-family="Playfair Display, serif" font-size="6" font-style="italic" fill="currentColor">M&amp;A</text></svg>`,
  },
];

const faqs = [
  {
    question: "¿Cuánto tarda?",
    answer:
      "72 horas hábiles desde que confirmas el pago. Si necesitas algo más rápido —regalo de cumpleaños mañana, vuelo el viernes, evento el sábado— dilo al pedir y vemos qué tan apretado lo podemos hacer.",
  },
  {
    question: "¿Dónde lo recojo o cómo me llega?",
    answer:
      "Tres opciones: recoges sin costo en el taller (Retorno Tejón Mz 3 Lt 2, Supermanzana 20, Cancún — lun-vie 10am–6pm, sáb 10am–2pm), te lo enviamos en la ciudad con tarifa local según colonia, o paquetería FedEx para resto de México y extranjero. Te avisamos por WhatsApp en cuanto esté listo.",
  },
  {
    question: "¿Sirve para regalo o solo para mí?",
    answer:
      "Para los dos. La mitad de nuestros pedidos son regalos — cumpleaños, bodas, despedidas, kits de bienvenida corporativos, recuerdos de evento. Si tu pedido es regalo y quieres que llegue empacado bonito, dilo en el mensaje y le hacemos envoltura sin costo extra.",
  },
  {
    question: "¿Y si no quiero personalizarlo?",
    answer:
      "Va igual de bien. Los cuatro diseños de llavero y los portavasos se pueden pedir tal cual, sin nombre ni texto. El termo siempre lleva al menos la palabra CANCUN o un nombre grabado, porque sin grabado pierde gracia.",
  },
  {
    question: "¿Hacen pedidos grandes para eventos o empresas?",
    answer:
      "Sí. Para 20+ piezas damos descuento progresivo y ofrecemos diseño exclusivo con tu logo, fecha del evento o motivo personalizado. Lo más pedido: kits de bienvenida para conferencias, recuerdos para boda destino, regalos de fin de año corporativos. Mándanos un WhatsApp con la cantidad y el contexto, te cotizamos a la medida.",
  },
  {
    question: "¿Diseños fuera del catálogo?",
    answer:
      "Sí, todo el tiempo. Si tienes un boceto, una idea, un logo o algo que viste en Pinterest, nosotros lo digitalizamos y producimos. El diseño se cotiza aparte según complejidad. Para piezas únicas o limitadas funcionamos como taller a la medida — el catálogo es solo el punto de partida.",
  },
  {
    question: "¿Qué idiomas admiten en el grabado?",
    answer:
      "Cualquier alfabeto que se vea bien en pequeño: latino con acentos (José, Rocío, Iñaki), cirílico, hebreo, árabe, kanji, hangul, emojis básicos. Si tu nombre o frase tiene caracteres raros, los grabamos tal como los escribes.",
  },
  {
    question: "¿Cómo pago?",
    answer:
      "Tres opciones: tarjeta de crédito/débito por link de pago (Visa, Mastercard, Amex), transferencia SPEI a cuenta BBVA, o efectivo en el taller si vas a recoger. No empezamos a producir hasta que confirmamos el pago.",
  },
];
---

<Base
  title="Recuerdos Cancún con tu nombre | Lumo Arte"
  description={service.metaDescription}
  canonical={service.slug}
  ogImage="/og/default.jpg"
  schemaType="Service"
  schemaData={serviceSchema}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/#servicios" },
        { label: service.name },
      ]}
    />

    <ServicePageHero
      eyebrow="Personalizados, hechos en Cancún"
      title="Pide tu llavero, termo o portavasos <em>hecho aquí</em>"
      subtitle="Diseños listos para personalizar — o pídelos tal cual. También hacemos piezas a la medida para regalos, bodas, eventos y empresas. 72 horas hábiles desde que confirmas el pago."
      primaryCta={{ label: "Hacer pedido", href: "#pedido" }}
      secondaryCta={{ label: "Cómo funciona", href: "#funciona" }}
      service="laser"
    >
      <RecuerdosShowcase slot="showcase" />
    </ServicePageHero>

    <section class="pasos" id="funciona">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow" data-reveal>Cómo funciona</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Tres pasos, sin sorpresas
          </h2>
        </div>
        <ol class="pasos-grid">
          {pasos.map((p, i) => (
            <li class="paso-card" data-tilt data-reveal data-reveal-delay={`${0.08 + i * 0.06}`}>
              <span class="paso-glare" aria-hidden="true"></span>
              <div class="paso-icon" aria-hidden="true" set:html={p.icon} />
              <span class="paso-n">{p.n}</span>
              <h3 class="paso-titulo">{p.titulo}</h3>
              <p class="paso-texto">{p.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="catalog" id="pedido">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow" data-reveal>Qué pedimos</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            El catálogo
          </h2>
          <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
            Tres productos base. Cualquiera se personaliza con nombres, fechas, logos o diseño a tu gusto. ¿Necesitas algo que no está aquí? Pídelo igual — la mitad de lo que hacemos es a la medida.
          </p>
        </div>

        <ul class="catalog-grid" role="list">
          {catalogo.map((c, i) => (
            <li class="catalog-card" data-tilt data-reveal data-reveal-delay={`${0.06 + i * 0.06}`}>
              <span class="catalog-glare" aria-hidden="true"></span>
              <div class="catalog-visual" aria-hidden="true" set:html={c.icon} />
              <div class="catalog-body">
                <p class="catalog-eyebrow">{c.eyebrow}</p>
                <h3 class="catalog-name">{c.name}</h3>
                <p class="catalog-desc">{c.desc}</p>
                <ul class="catalog-bullets" role="list">
                  {c.bullets.map((b) => <li>{b}</li>)}
                </ul>
                <div class="catalog-foot">
                  <span class="catalog-price">{c.desde}</span>
                  <button type="button" class="catalog-cta" data-pick={c.id}>
                    Pedir
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </button>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <div class="order-card" data-reveal>
          <div class="order-head">
            <p class="order-eyebrow">Mándanos los detalles</p>
            <h3 class="order-title">Tu pedido por WhatsApp</h3>
            <p class="order-sub">
              Te respondemos en menos de una hora hábil con el resumen, el precio final y el link de pago.
            </p>
          </div>

          <form class="order-form" id="orderForm" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="ofProduct">¿Qué quieres?</label>
                <select id="ofProduct" required>
                  <option value="">Elige una opción</option>
                  <option value="llavero">Llavero personalizado</option>
                  <option value="termo">Termo grabado</option>
                  <option value="portavasos">Set de portavasos</option>
                  <option value="custom">Otro / pedido a la medida</option>
                </select>
              </div>
              <div class="form-group">
                <label for="ofQty">Cantidad (opcional)</label>
                <input type="text" id="ofQty" placeholder="1, 5, 50…" />
              </div>
            </div>

            <div class="form-group">
              <label for="ofDetails">Detalles del pedido</label>
              <textarea id="ofDetails" rows="5" placeholder="Nombres a grabar, fecha del evento, diseño o referencia, lo que sea. Si es para boda, despedida o empresa, dinos cuántas piezas y para cuándo."></textarea>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="ofName">Tu nombre</label>
                <input type="text" id="ofName" required />
              </div>
              <div class="form-group">
                <label for="ofPhone">WhatsApp</label>
                <input type="tel" id="ofPhone" placeholder="+52..." required />
              </div>
            </div>

            <button type="submit" class="btn-submit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              Enviar pedido por WhatsApp
            </button>
            <p class="submit-helper">Sin compromiso. El pedido se confirma una vez acordemos el detalle por mensaje.</p>
          </form>
        </div>
      </div>
    </section>

    <CrossServices excludeId="recuerdos-cancun" />

    <FAQ
      title="Preguntas frecuentes"
      subtitle="Las dudas que más nos hacen los clientes — locales y turistas. Si la tuya no aparece, mándanos un WhatsApp."
      items={faqs}
    />

    <InstagramCTA />
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  /* ── PASOS ── */
  .pasos {
    background: var(--color-bg-alt);
    padding: 96px 0;
  }
  .section-header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  .section-subtitle {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .pasos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    list-style: none;
    perspective: 1400px;
  }
  .paso-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 12px;
    padding: 40px 32px 36px;
    transform-style: preserve-3d;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .paso-card::before {
    content: "";
    position: absolute;
    top: -90px;
    right: -90px;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(165, 58, 4, 0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .paso-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 22px 48px rgba(20, 10, 4, 0.10);
  }
  .paso-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle 280px at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 240, 220, 0.30) 0%,
      rgba(255, 240, 220, 0.10) 25%,
      transparent 60%);
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
    border-radius: inherit;
    z-index: 1;
  }
  .paso-card:hover .paso-glare { opacity: 1; }
  .paso-card > *:not(.paso-glare) { position: relative; z-index: 2; }
  .paso-icon {
    width: 52px;
    height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    background: rgba(165, 58, 4, 0.06);
    border-radius: 12px;
    margin-bottom: 22px;
  }
  .paso-icon :global(svg) { width: 28px; height: 28px; }
  .paso-n {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .paso-titulo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .paso-texto {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  @media (hover: none), (prefers-reduced-motion: reduce) {
    .paso-card { transform-style: flat; }
    .paso-glare { display: none; }
  }
  @media (max-width: 720px) {
    .pasos { padding: 64px 0; }
    .pasos-grid { grid-template-columns: 1fr; perspective: none; }
    .paso-card { padding: 32px 28px; }
  }

  /* ── CATÁLOGO ── */
  .catalog {
    background: var(--color-bg);
    padding: 120px 0;
  }
  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    list-style: none;
    perspective: 1400px;
    margin-bottom: 80px;
  }
  .catalog-card {
    position: relative;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    border-radius: 14px;
    overflow: hidden;
    transform-style: preserve-3d;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, box-shadow 0.3s ease,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .catalog-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 22px 48px rgba(20, 10, 4, 0.10);
  }
  .catalog-glare {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background: radial-gradient(circle 320px at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 240, 220, 0.35) 0%,
      rgba(255, 240, 220, 0.12) 25%,
      transparent 60%);
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
    border-radius: inherit;
  }
  .catalog-card:hover .catalog-glare { opacity: 1; }
  .catalog-card > *:not(.catalog-glare) { position: relative; z-index: 2; }

  .catalog-visual {
    aspect-ratio: 4 / 3;
    background:
      radial-gradient(ellipse 90% 70% at 50% 30%, rgba(255, 255, 255, 0.55), transparent 70%),
      radial-gradient(ellipse 100% 80% at 50% 110%, rgba(165, 58, 4, 0.10), transparent 70%),
      linear-gradient(180deg, #f8f1e2 0%, #e8ddc6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-surface);
  }
  .catalog-visual :global(svg) {
    width: 70%;
    height: 70%;
    filter: drop-shadow(0 6px 14px rgba(20, 10, 4, 0.14));
  }
  .catalog-body {
    flex-grow: 1;
    padding: 28px 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .catalog-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .catalog-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .catalog-desc {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
  }
  .catalog-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 4px 0 8px;
    flex-grow: 1;
  }
  .catalog-bullets li {
    color: var(--color-text);
    font-size: 0.875rem;
    padding-left: 18px;
    position: relative;
  }
  .catalog-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 1.5px;
    background: var(--color-accent);
  }
  .catalog-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
