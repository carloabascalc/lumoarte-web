---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServicePageHero from "../../components/ServicePageHero.astro";
import RecuerdosShowcase from "../../components/RecuerdosShowcase.astro";
import CrossServices from "../../components/CrossServices.astro";
import FAQ from "../../components/FAQ.astro";
import InstagramCTA from "../../components/InstagramCTA.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getService, SITE } from "../../data/services";

const service = getService("recuerdos-cancun");

const serviceSchema = {
  name: service.name,
  serviceType: "Personalized souvenirs",
  description: service.metaDescription,
  url: `${SITE.url}${service.slug}`,
};

const pasos = [
  {
    n: "01",
    titulo: "Elige tu pieza",
    texto: "Llavero, termo o set de portavasos. Cuatro diseños de Cancún para el llavero, todos en color.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="20"/><circle cx="24" cy="24" r="12"/><path d="M24 4v40M4 24h40"/></svg>`,
  },
  {
    n: "02",
    titulo: "Personalízalo",
    texto: "Tu nombre grabado, hasta 15 caracteres. Lo escribes en mayúsculas, lo grabamos tal cual.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 38h32"/><path d="M14 32h20"/><path d="M16 14l4-8 4 8 4-8 4 8 4-8"/><path d="M10 24l4-4 4 4 4-4 4 4 4-4 4 4 4-4 4 4"/></svg>`,
  },
  {
    n: "03",
    titulo: "Entrega en tu hotel",
    texto: "En 72 horas lo tienes en recepción. Si ya regresaste a casa, te lo enviamos por FedEx.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 42V18l18-10 18 10v24"/><path d="M6 42h36"/><path d="M18 42v-12h12v12"/><path d="M16 22h.01M28 22h.01M16 30h.01M28 30h.01"/></svg>`,
  },
];

const faqs = [
  {
    question: "¿Cuánto tarda?",
    answer:
      "72 horas hábiles desde que confirmas el pedido por WhatsApp. Si llegas a Cancún el viernes y nos escribes ese mismo día, lo recibes el lunes en tu hotel. Si tu vuelo es antes, dilo en el mensaje y vemos cómo acelerarlo.",
  },
  {
    question: "¿En qué hoteles entregan?",
    answer:
      "Cualquier hotel de la Zona Hotelera de Cancún, Puerto Cancún, Centro, o Isla Mujeres. La entrega va a recepción a nombre del huésped — no necesitas estar presente.",
  },
  {
    question: "¿Y si ya regresé a mi país?",
    answer:
      "Te lo enviamos por FedEx a casi cualquier parte del mundo. El costo del envío se calcula al momento del pedido y lo agregamos al total. Llegada típica: 5 a 10 días hábiles según el destino.",
  },
  {
    question: "¿Qué idiomas admiten en el grabado?",
    answer:
      "Cualquier alfabeto que se vea bien en pequeño: latino (con acentos), cirílico, hebreo, árabe, kanji, hangul. Si tu nombre tiene caracteres especiales, los grabamos tal como los escribes.",
  },
  {
    question: "¿Cómo pago?",
    answer:
      "Por WhatsApp te mandamos un link de pago con tarjeta (Visa, Mastercard, American Express). También aceptamos transferencia SPEI si estás en México. No empezamos a producir hasta que confirmamos el pago.",
  },
  {
    question: "¿Puedo pedir más de un nombre?",
    answer:
      "Sí. En los llaveros puedes elegir packs de hasta 5 piezas, cada una con un nombre diferente — ideal para regalos a la familia o al grupo de amigos con el que vienes. En el termo solo va un nombre por pieza.",
  },
];
---

<Base
  title="Recuerdos Cancún con tu nombre | Lumo Arte"
  description={service.metaDescription}
  canonical={service.slug}
  ogImage="/og/default.jpg"
  schemaType="Service"
  schemaData={serviceSchema}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/#servicios" },
        { label: service.name },
      ]}
    />

    <ServicePageHero
      eyebrow="Recuerdos personalizados"
      title="Tu nombre, hecho en Cancún"
      subtitle="Llaveros impresos en 3D, termos grabados con láser y portavasos con tu nombre. Diseñas en línea, recibes en tu hotel en 72 horas."
      primaryCta={{ label: "Diseñar ahora", href: "#diseña" }}
      secondaryCta={{ label: "Cómo funciona", href: "#funciona" }}
      service="laser"
    >
      <RecuerdosShowcase slot="showcase" />
    </ServicePageHero>

    <section class="pasos" id="funciona">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow" data-reveal>Cómo funciona</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Tres pasos, sin sorpresas
          </h2>
        </div>
        <ol class="pasos-grid">
          {pasos.map((p, i) => (
            <li class="paso-card" data-tilt data-reveal data-reveal-delay={`${0.08 + i * 0.06}`}>
              <span class="paso-glare" aria-hidden="true"></span>
              <div class="paso-icon" aria-hidden="true" set:html={p.icon} />
              <span class="paso-n">{p.n}</span>
              <h3 class="paso-titulo">{p.titulo}</h3>
              <p class="paso-texto">{p.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="wizard" id="diseña">
      <div class="container container--narrow">
        <div class="section-header">
          <p class="eyebrow" data-reveal>Diséñalo</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Configura tu recuerdo
          </h2>
          <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
            Todos los precios en USD. Al final te enviamos el resumen al WhatsApp del taller para confirmar y pagar.
          </p>
        </div>

        <div class="wiz-shell" data-reveal data-reveal-delay="0.18">
          <div class="wiz-progress" aria-hidden="true">
            <span class="wiz-dot active" data-dot="0"></span>
            <span class="wiz-dot" data-dot="1"></span>
            <span class="wiz-dot" data-dot="2"></span>
            <span class="wiz-dot" data-dot="3"></span>
            <span class="wiz-dot" data-dot="4"></span>
          </div>

          <!-- STEP: PRODUCT -->
          <div class="wiz-panel visible" data-panel="product">
            <h3 class="wiz-title">¿Qué te llevas?</h3>
            <p class="wiz-sub">Personalizado, hecho en Cancún.</p>

            <p class="wiz-section-label">Llaveros impresos en 3D · desde $11 USD</p>
            <div class="prod-grid">
              <button type="button" class="prod-card" data-product="A">
                <span class="prod-icon" aria-hidden="true">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6c1.5 0 1.5 2 3 2s1.5-2 3-2 1.5 2 3 2 1.5-2 3-2 1.5 2 3 2 1.5-2 3-2 1.5 2 3 2"/><path d="M2 12c1.5 0 1.5 2 3 2s1.5-2 3-2 1.5 2 3 2 1.5-2 3-2 1.5 2 3 2 1.5-2 3-2 1.5 2 3 2"/><path d="M2 18c1.5 0 1.5 2 3 2s1.5-2 3-2 1.5 2 3 2 1.5-2 3-2 1.5 2 3 2 1.5-2 3-2 1.5 2 3 2"/></svg>
                </span>
                <span class="prod-name">Ocean</span>
                <span class="prod-desc">Olas y playa</span>
              </button>
              <button type="button" class="prod-card" data-product="B">
                <span class="prod-icon" aria-hidden="true">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6"/><path d="M8 6 4 4"/><path d="m16 6 4-2"/><path d="M12 8c-4 0-7 2-7 6 0 3 2 6 7 6s7-3 7-6c0-4-3-6-7-6Z"/><path d="M12 14h.01"/></svg>
                </span>
                <span class="prod-name">Tropical</span>
                <span class="prod-desc">Aves y selva</span>
              </button>
              <button type="button" class="prod-card" data-product="C">
                <span class="prod-icon" aria-hidden="true">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V8l7-5 7 5v13"/><path d="M9 21v-7h6v7"/><path d="M9 12h6"/></svg>
                </span>
                <span class="prod-name">Maya</span>
                <span class="prod-desc">Cultura maya</span>
              </button>
              <button type="button" class="prod-card" data-product="D">
                <span class="prod-icon" aria-hidden="true">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 0 1 0 18"/><path d="M3 12h18"/><path d="M12 3c2 3 2 15 0 18"/></svg>
                </span>
                <span class="prod-name">Fiesta</span>
                <span class="prod-desc">Colores y sabor</span>
              </button>
            </div>

            <p class="wiz-section-label">Termo grabado · desde $15 USD</p>
            <button type="button" class="prod-card prod-card--wide" data-product="termo">
              <span class="prod-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8"/><path d="M9 2v3"/><path d="M15 2v3"/><path d="M7 5h10v13a3 3 0 0 1-3 3h-4a3 3 0 0 1-3-3Z"/><path d="M9 10h6"/></svg>
              </span>
              <span class="prod-wide-body">
                <span class="prod-name">Termo 20oz acero inoxidable</span>
                <span class="prod-desc">Grabado láser: tu nombre, la palabra CANCUN, o ambos.</span>
              </span>
              <span class="prod-wide-price">$15+</span>
            </button>

            <p class="wiz-section-label">Otros</p>
            <button type="button" class="prod-card prod-card--wide" data-product="portavasos">
              <span class="prod-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>
              </span>
              <span class="prod-wide-body">
                <span class="prod-name">Set de 5 portavasos</span>
                <span class="prod-desc">Cinco portavasos personalizados con tu nombre o un diseño.</span>
              </span>
              <span class="prod-wide-price">$15</span>
            </button>
          </div>

          <!-- STEP: NAMES (keychains) -->
          <div class="wiz-panel" data-panel="names">
            <h3 class="wiz-title">Tu nombre en el llavero</h3>
            <p class="wiz-sub">Hasta 15 caracteres. Lo grabamos exactamente como lo escribes.</p>

            <div class="name-preview">
              <p class="preview-label">Vista previa</p>
              <p class="preview-cancun">CANCUN</p>
              <p class="preview-name" id="previewName">—</p>
            </div>

            <p class="wiz-section-label">¿Cuántos llaveros?</p>
            <div class="bundle-row">
              <button type="button" class="bundle-opt selected" data-bundle="1">
                <span class="b-qty">1 llavero</span>
                <span class="b-price">$11</span>
              </button>
              <button type="button" class="bundle-opt" data-bundle="2">
                <span class="b-qty">2 llaveros<span class="b-save">Ahorras $2</span></span>
                <span class="b-price">$20</span>
              </button>
              <button type="button" class="bundle-opt" data-bundle="3">
                <span class="b-qty">3 llaveros<span class="b-save">Ahorras $4</span></span>
                <span class="b-price">$29</span>
              </button>
              <button type="button" class="bundle-opt" data-bundle="4">
                <span class="b-qty">4 llaveros<span class="b-save">Ahorras $9</span></span>
                <span class="b-price">$35</span>
              </button>
              <button type="button" class="bundle-opt" data-bundle="5">
                <span class="b-qty">5 llaveros<span class="b-save">Mejor precio</span></span>
                <span class="b-price">$40</span>
              </button>
            </div>

            <p class="wiz-section-label">Nombre por llavero</p>
            <div class="name-inputs" id="nameInputs"></div>
          </div>

          <!-- STEP: ADDONS (keychains) -->
          <div class="wiz-panel" data-panel="addons">
            <h3 class="wiz-title">Extras opcionales</h3>
            <p class="wiz-sub">Súmale herramientas a cada llavero. Puedes saltar este paso.</p>
            <div id="addonsList"></div>
          </div>

          <!-- STEP: TERMO -->
          <div class="wiz-panel" data-panel="termo">
            <h3 class="wiz-title">Personaliza tu termo</h3>
            <p class="wiz-sub">Acero inoxidable 20oz. Elige qué grabamos.</p>

            <div class="termo-preview">
              <p class="preview-label">Vista previa</p>
              <p class="preview-cancun preview-cancun--termo" id="tepCancun">CANCUN</p>
              <p class="preview-name preview-name--termo" id="tepName">—</p>
            </div>

            <div class="termo-opts">
              <button type="button" class="termo-opt" data-termo="cancun">
                <span class="t-info">
                  <span class="t-name">Palabra CANCUN</span>
                  <span class="t-desc">Grabado en el termo en mayúsculas. +$5 USD.</span>
                </span>
                <span class="t-check" aria-hidden="true"></span>
              </button>
              <button type="button" class="termo-opt" data-termo="name">
                <span class="t-info">
                  <span class="t-name">Tu nombre</span>
                  <span class="t-desc">Hasta 15 caracteres. +$5 USD.</span>
                </span>
                <span class="t-check" aria-hidden="true"></span>
              </button>
              <div class="termo-name-input hidden" id="termoNameWrap">
                <input type="text" maxlength="15" id="termoNameField" placeholder="Tu nombre" />
                <span class="char-count" id="termoNameCount">0/15</span>
              </div>
            </div>
          </div>

          <!-- STEP: DELIVERY -->
          <div class="wiz-panel" data-panel="delivery">
            <h3 class="wiz-title">¿A dónde lo entregamos?</h3>
            <p class="wiz-sub">Entrega a hotel sin costo, o envío a casa por FedEx.</p>

            <div class="del-grid">
              <button type="button" class="del-opt selected" data-delivery="hotel">
                <span class="del-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V8l9-5 9 5v14"/><path d="M3 22h18"/><path d="M9 22v-6h6v6"/><path d="M9 10h.01M15 10h.01M9 14h.01M15 14h.01"/></svg>
                </span>
                <span class="del-name">Hotel en Cancún</span>
                <span class="del-info">Sin costo · 72 horas</span>
              </button>
              <button type="button" class="del-opt" data-delivery="address">
                <span class="del-icon" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>
                </span>
                <span class="del-name">Envío a casa</span>
                <span class="del-info">FedEx · 5-10 días</span>
              </button>
            </div>

            <div class="del-form" id="delHotelForm">
              <div class="form-group">
                <label for="hotelName">Hotel</label>
                <input type="text" id="hotelName" placeholder="Hotel Riu Cancún, Hotel Xcaret, etc." />
              </div>
              <div class="form-group">
                <label for="hotelRoom">Habitación</label>
                <input type="text" id="hotelRoom" placeholder="304" />
              </div>
            </div>
            <div class="del-form hidden" id="delAddressForm">
              <div class="form-group">
                <label for="addrCountry">País</label>
                <input type="text" id="addrCountry" placeholder="Estados Unidos, Canadá, España..." />
              </div>
              <div class="form-group">
                <label for="addrStreet">Dirección completa</label>
                <input type="text" id="addrStreet" placeholder="Calle, número, ciudad, código postal" />
              </div>
            </div>
          </div>

          <!-- STEP: SUMMARY -->
          <div class="wiz-panel" data-panel="summary">
            <h3 class="wiz-title">Tu pedido</h3>
            <p class="wiz-sub">Revisa, agrega tu contacto y te enviamos el resumen al WhatsApp del taller para confirmar y pagar.</p>

            <div class="summary-box">
              <div class="summary-row">
                <span class="s-label">Producto</span>
                <span class="s-value" id="sumProduct">—</span>
              </div>
              <div class="summary-row" id="sumExtrasRow" hidden>
                <span class="s-label">Extras</span>
                <span class="s-value" id="sumExtras">—</span>
              </div>
              <div class="summary-row">
                <span class="s-label">Entrega</span>
                <span class="s-value" id="sumDelivery">—</span>
              </div>
              <div class="summary-total">
                <span>Total</span>
                <span class="t-value"><span id="sumTotal">0</span> USD</span>
              </div>
            </div>

            <div class="form-group">
              <label for="clientName">Tu nombre</label>
              <input type="text" id="clientName" placeholder="Como apareces en el hotel" />
            </div>
            <div class="form-group">
              <label for="clientPhone">WhatsApp (con código de país)</label>
              <input type="tel" id="clientPhone" placeholder="+1 555 123 4567" />
            </div>
            <div class="form-group">
              <label for="clientEmail">Email</label>
              <input type="email" id="clientEmail" placeholder="tucorreo@dominio.com" />
            </div>

            <a href="#" class="btn-submit" id="btnSubmit">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              Enviar pedido por WhatsApp
            </a>
            <p class="submit-helper">Te respondemos en menos de una hora hábil con el link de pago.</p>
          </div>

          <!-- Footer nav -->
          <div class="wiz-footer">
            <button type="button" class="wiz-back" id="wizBack">Atrás</button>
            <div class="wiz-running">
              <span class="wiz-running-label">Total</span>
              <span class="wiz-running-total"><span id="runningTotal">11</span> USD</span>
            </div>
            <button type="button" class="wiz-next" id="wizNext">Siguiente</button>
          </div>
        </div>
      </div>
    </section>

    <CrossServices excludeId="recuerdos-cancun" />

    <FAQ
      title="Preguntas frecuentes"
      subtitle="Las dudas que más nos hacen los turistas. Si la tuya no aparece, mándanos un WhatsApp."
      items={faqs}
    />

    <InstagramCTA />
    <Contact />
    <Footer />
    <WhatsAppButton />
  </main>
</Base>

<style>
  .container--narrow { max-width: 760px; }

  .pasos {
    background: var(--color-bg-alt);
    padding: 96px 0;
  }
  .section-header { text-align: center; max-width: 720px; margin: 0 auto 56px; }
  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 16px;
  }
  .section-subtitle {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .pasos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    list-style: none;
    perspective: 1400px;
  }
  .paso-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 12px;
    padding: 40px 32px 36px;
    transform-style: preserve-3d;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .paso-card::before {
    content: "";
    position: absolute;
    top: -90px;
    right: -90px;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(165, 58, 4, 0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .paso-card:hover {
