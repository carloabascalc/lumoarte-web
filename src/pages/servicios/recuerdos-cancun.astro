---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServicePageHero from "../../components/ServicePageHero.astro";
import ServicePdfs from "../../components/ServicePdfs.astro";
import RecuerdosShowcase from "../../components/RecuerdosShowcase.astro";
import RecuerdosOrderBuilder from "../../components/RecuerdosOrderBuilder.astro";
import CrossServices from "../../components/CrossServices.astro";
import FAQ from "../../components/FAQ.astro";
import InstagramCTA from "../../components/InstagramCTA.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getService, SITE } from "../../data/services";

const service = getService("recuerdos-cancun");

const serviceSchema = {
  name: service.name,
  serviceType: "Personalized souvenirs",
  description: service.metaDescription,
  url: `${SITE.url}${service.slug}`,
};

const pasos = [
  {
    n: "01",
    titulo: "Elige cómo lo quieres",
    texto: "Mándanos tu propio modelo 3D para imprimirlo, o elige un llavero de nuestro catálogo. Tú dices.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="20"/><circle cx="24" cy="24" r="12"/><path d="M24 4v40M4 24h40"/></svg>`,
  },
  {
    n: "02",
    titulo: "Cuéntanos los detalles",
    texto: "Cantidad, nombres, fecha, diseño. Por WhatsApp acordamos lo que hace falta y te pasamos el precio final.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 38h32"/><path d="M14 32h20"/><path d="M16 14l4-8 4 8 4-8 4 8 4-8"/><path d="M10 24l4-4 4 4 4-4 4 4 4-4 4 4 4-4 4 4"/></svg>`,
  },
  {
    n: "03",
    titulo: "Lo recoges o te lo enviamos",
    texto: "Recoges sin costo en el taller (Retorno Tejón, SM 20), envío local en Cancún, o paquetería FedEx a otra ciudad. 72 h hábiles desde que confirmas el pago.",
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 42V18l18-10 18 10v24"/><path d="M6 42h36"/><path d="M18 42v-12h12v12"/><path d="M16 22h.01M28 22h.01M16 30h.01M28 30h.01"/></svg>`,
  },
];

const faqs = [
  {
    question: "¿Cuánto tarda?",
    answer:
      "72 horas hábiles desde que confirmas el pago. Si necesitas algo más rápido —regalo de cumpleaños mañana, vuelo el viernes, evento el sábado— dilo al pedir y vemos qué tan apretado lo podemos hacer.",
  },
  {
    question: "¿Dónde lo recojo o cómo me llega?",
    answer:
      "Tres opciones: recoges sin costo en el taller (Retorno Tejón Mz 3 Lt 2, Supermanzana 20, Cancún — lun-vie 10am–6pm, sáb 10am–2pm), te lo enviamos en la ciudad con tarifa local según colonia, o paquetería FedEx para resto de México y extranjero. Te avisamos por WhatsApp en cuanto esté listo.",
  },
  {
    question: "¿Sirve para regalo o solo para mí?",
    answer:
      "Para los dos. La mitad de nuestros pedidos son regalos — cumpleaños, bodas, despedidas, kits de bienvenida corporativos, recuerdos de evento. Si tu pedido es regalo y quieres que llegue empacado bonito, dilo en el mensaje y le hacemos envoltura sin costo extra.",
  },
  {
    question: "¿Y si no tengo un diseño propio?",
    answer:
      "Pide uno de nuestro catálogo. Son diseños ya hechos inspirados en Cancún —listos para imprimir, sin que tú tengas que mandarnos nada— y salen más rápido.",
  },
  {
    question: "¿Qué archivos puedo mandarles para imprimir mi modelo?",
    answer:
      "Lo ideal es .stl, .3mf o .obj. Si solo tienes un boceto, una foto o una idea, también nos funciona — lo modelamos por ti y te cotizamos aparte el diseño según complejidad.",
  },
  {
    question: "¿Hacen pedidos grandes para eventos o empresas?",
    answer:
      "Sí. Para 20+ piezas damos descuento progresivo y ofrecemos diseño exclusivo con tu logo, fecha del evento o motivo personalizado. Lo más pedido: kits de bienvenida para conferencias, recuerdos para boda destino, regalos de fin de año corporativos. Mándanos un WhatsApp con la cantidad y el contexto, te cotizamos a la medida.",
  },
  {
    question: "¿Diseños fuera del catálogo?",
    answer:
      "Sí, todo el tiempo. Si tienes un boceto, una idea, un logo o algo que viste en Pinterest, nosotros lo digitalizamos y producimos. El diseño se cotiza aparte según complejidad. Funcionamos como taller a la medida — el catálogo es solo un punto de partida.",
  },
  {
    question: "¿Qué idiomas admiten en el grabado?",
    answer:
      "Cualquier alfabeto que se vea bien en pequeño: latino con acentos (José, Rocío, Iñaki), cirílico, hebreo, árabe, kanji, hangul, emojis básicos. Si tu nombre o frase tiene caracteres raros, los grabamos tal como los escribes.",
  },
  {
    question: "¿Cómo pago?",
    answer:
      "Tres opciones: tarjeta de crédito/débito por link de pago (Visa, Mastercard, Amex), transferencia SPEI a cuenta BBVA, o efectivo en el taller si vas a recoger. No empezamos a producir hasta que confirmamos el pago.",
  },
];

const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Base
  title="Recuerdos Cancún con tu nombre | Lumo Cancún"
  description={service.metaDescription}
  canonical={service.slug}
  ogImage="/og/default.jpg"
  schemaType="Service"
  schemaData={serviceSchema}
  extraSchemas={[faqPageSchema]}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/#servicios" },
        { label: service.name },
      ]}
    />

    <ServicePageHero
      eyebrow="Llaveros de Cancún, hechos aquí"
      title="Tu llavero de Cancún, <em>hecho en Cancún</em>"
      subtitle="Mándanos tu propio modelo 3D para imprimirlo, o elige uno de nuestro catálogo. También hacemos diseños a la medida para bodas, eventos y empresas. 72 horas hábiles desde que confirmas el pago."
      primaryCta={{ label: "Hacer pedido", href: "#pedido" }}
      secondaryCta={{ label: "Cómo funciona", href: "#funciona" }}
      service="laser"
    >
      <RecuerdosShowcase slot="showcase" />
    </ServicePageHero>

    <ServicePdfs service={service} />

    <section class="pasos" id="funciona">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow" data-reveal>Cómo funciona</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Tres pasos, sin sorpresas
          </h2>
        </div>
        <ol class="pasos-grid">
          {pasos.map((p, i) => (
            <li class="paso-card" data-tilt data-reveal data-reveal-delay={`${0.08 + i * 0.06}`}>
              <span class="paso-glare" aria-hidden="true"></span>
              <div class="paso-icon" aria-hidden="true" set:html={p.icon} />
              <span class="paso-n">{p.n}</span>
              <h3 class="paso-titulo">{p.titulo}</h3>
              <p class="paso-texto">{p.texto}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <RecuerdosOrderBuilder />

    <CrossServices excludeId="recuerdos-cancun" />

    <FAQ
      title="Preguntas frecuentes"
      subtitle="Las dudas que más nos hacen los clientes — locales y turistas. Si la tuya no aparece, mándanos un WhatsApp."
      items={faqs}
    />

    <InstagramCTA />
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  /* ── PASOS ── */
  .pasos {
    background: var(--color-bg-alt);
    padding: 96px 0;
  }
  .section-header {
    text-align: center;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 16px;
    text-align: center;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 16px;
    text-align: center;
  }
  .section-subtitle {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .pasos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    list-style: none;
    perspective: 1400px;
  }
  .paso-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 12px;
    padding: 40px 32px 36px;
    transform-style: preserve-3d;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease,
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .paso-card::before {
    content: "";
    position: absolute;
    top: -90px;
    right: -90px;
    width: 220px;
    height: 220px;
    background: radial-gradient(circle, rgba(165, 58, 4, 0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .paso-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 22px 48px rgba(20, 10, 4, 0.10);
  }
  .paso-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle 280px at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 240, 220, 0.30) 0%,
      rgba(255, 240, 220, 0.10) 25%,
      transparent 60%);
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
    border-radius: inherit;
    z-index: 1;
  }
  .paso-card:hover .paso-glare { opacity: 1; }
  .paso-card > *:not(.paso-glare) { position: relative; z-index: 2; }
  .paso-icon {
    width: 52px;
    height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    background: rgba(165, 58, 4, 0.06);
    border-radius: 12px;
    margin-bottom: 22px;
  }
  .paso-icon :global(svg) { width: 28px; height: 28px; }
  .paso-n {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.18em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .paso-titulo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .paso-texto {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  @media (hover: none), (prefers-reduced-motion: reduce) {
    .paso-card { transform-style: flat; }
    .paso-glare { display: none; }
  }
  @media (max-width: 720px) {
    .pasos { padding: 64px 0; }
    .pasos-grid { grid-template-columns: 1fr; perspective: none; }
    .paso-card { padding: 32px 28px; }
  }
</style>

<script>
  import { initCardTilt } from "../../scripts/cardTilt";

  function init() {
    initCardTilt(".paso-card[data-tilt]");
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
