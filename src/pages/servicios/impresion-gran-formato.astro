---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServicePageHero from "../../components/ServicePageHero.astro";
import ServicePdfs from "../../components/ServicePdfs.astro";
import PricingFormula from "../../components/PricingFormula.astro";
import PlotterShowcase from "../../components/PlotterShowcase.astro";
import PlotterAssembly from "../../components/PlotterAssembly.astro";
import Gallery from "../../components/Gallery.astro";
import FAQ from "../../components/FAQ.astro";
import CrossServices from "../../components/CrossServices.astro";
import QuoteForm from "../../components/QuoteForm.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getService, SITE } from "../../data/services";

const service = getService("impresion-gran-formato");

const usos = [
  {
    label: "Lonas y banners",
    description:
      "Para eventos, restaurantes, hoteles, real estate y retail. Imprimimos en lona frontlit (visible con luz frontal) o blockout (totalmente opaca, ideal para colgar al aire).",
  },
  {
    label: "Viniles",
    description:
      "Vinil adhesivo para rotulación de ventanas, pisos, vehículos y mobiliario — desde campañas de corto plazo hasta rotulación de largo plazo.",
  },
];

const specs = [
  { label: "Ancho de impresión", value: "Hasta 1.80 m" },
  { label: "Resolución", value: "Hasta 1440 dpi" },
  { label: "Velocidad", value: "8 a 12 m²/h" },
  { label: "Cabezal", value: "Epson XP600" },
  { label: "Materiales", value: "Lona y vinil" },
];

const serviceSchema = {
  name: service.name,
  serviceType: "Large format printing",
  description: service.metaDescription,
  url: `${SITE.url}${service.slug}`,
};

const faqs = [
  {
    question: "¿Cuánto tarda imprimir una lona o un wrap?",
    answer:
      "Habitualmente menos de una semana. Cuando hay disponibilidad, una lona estándar puede salir el mismo día. El tiempo exacto te lo confirmamos en la cotización.",
  },
  {
    question: "¿Qué archivo necesito enviar?",
    answer:
      "Para impresión gran formato necesitamos tu diseño en alta resolución (mínimo 100 dpi al tamaño final, idealmente 150 dpi). Aceptamos AI, PDF, PSD, TIFF y JPG/PNG en alta calidad. Coloca todas las fuentes en curvas y deja al menos 2 cm de sangrado. Si no tienes el diseño listo, te conectamos con un diseñador o lo cotizamos.",
  },
  {
    question: "¿Hacen instalación de wraps y rotulación?",
    answer:
      "Sí. Tenemos un instalador certificado para wraps vehiculares y rotulación de ventanas/locales. La instalación se cotiza aparte de la impresión y se programa con cita. Si prefieres instalar tú o tu equipo, entregamos el material listo con instrucciones.",
  },
  {
    question: "¿Cuál es el tamaño máximo de impresión?",
    answer:
      "El ancho máximo en una sola pieza es 1.80 m. El largo es prácticamente ilimitado — imprimimos en rollos continuos. Para piezas más anchas (un banner de 4 m de altura, por ejemplo), las imprimimos en módulos que se unen invisiblemente con sellado térmico o costura.",
  },
  {
    question: "¿Qué dura más, vinil o lona?",
    answer:
      "La lona frontlit dura 1–2 años a la intemperie sin perder color. La lona blockout (totalmente opaca) dura 2–3 años. El vinil de campaña dura 6 meses a 1 año. El vinil automotriz de calidad dura 5–7 años. Si necesitas algo permanente, dinos el uso y te recomendamos el material adecuado.",
  },
  {
    question: "¿Hay cantidad mínima?",
    answer:
      "No. Imprimimos desde una sola pieza — un banner para tu evento, un wrap para un coche, una playera personalizada. Para producción en serie ofrecemos descuento por volumen.",
  },
];

const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Base
  pageAccent="plotter"
  title={`${service.name} en Cancún | Lumo Cancún`}
  description={service.metaDescription}
  canonical={service.slug}
  ogImage="/og/impresion-gran-formato.jpg"
  schemaType="Service"
  schemaData={serviceSchema}
  extraSchemas={[faqPageSchema]}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/#servicios" },
        { label: service.name },
      ]}
      backHref="/#servicios"
      backLabel="Regresar a servicios"
    />

    <ServicePageHero
      eyebrow="Impresión gran formato"
      title="Impresión en gran formato de hasta 1.80 m de ancho"
      subtitle="Lonas y viniles en una máquina industrial — desde un banner para tu evento hasta la rotulación completa de tu vehículo. El ancho máximo depende del material."
      primaryCta={{ label: "Solicita tu cotización", href: "#cotiza" }}
      secondaryCta={{ label: "Ver usos", href: "#usos" }}
      service="plotter"
    >
      <PlotterShowcase slot="showcase" />
    </ServicePageHero>

    <ServicePdfs service={service} />

    <PlotterAssembly />

    <section class="usos section" id="usos">
      <div class="container">
        <div class="section-header">
          <p class="usos-eyebrow" data-reveal>Lonas y viniles</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Lo que sale del plotter
          </h2>
          <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
            La misma impresora cubre desde el banner para tu evento hasta la
            rotulación de tu local. Cambiamos el material — no la calidad.
          </p>
        </div>
        <div class="usos-grid">
          {usos.map((u, i) => (
            <article class="uso-card" data-tilt data-reveal data-reveal-delay={`${0.04 + i * 0.08}`}>
              <h3 class="uso-name">{u.label}</h3>
              <p class="uso-description">{u.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="specs section" id="especificaciones">
      <div class="container">
        <div class="specs-inner">
          <div class="specs-text">
            <p class="specs-eyebrow" data-reveal>Especificaciones técnicas</p>
            <h2 class="specs-title" data-reveal data-reveal-delay="0.06">
              Equipo industrial, calidad de fotograbado
            </h2>
            <p class="specs-description" data-reveal data-reveal-delay="0.12">
              Trabajamos con un plotter industrial de cabezal Epson XP600 para
              impresión directa sobre lona y vinil. Esto te da en una misma
              cotización todas las piezas de tu campaña.
            </p>
          </div>
          <ul class="specs-list" role="list" data-reveal data-reveal-delay="0.18">
            {specs.map((s) => (
              <li class="spec-row">
                <span class="spec-label">{s.label}</span>
                <span class="spec-value">{s.value}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <PricingFormula serviceId="impresion-gran-formato" />

    <Gallery
      filterService="impresion-gran-formato"
      title="Trabajos de gran formato"
      subtitle="Estamos documentando los proyectos del taller. Mientras tanto, sigue nuestro Instagram para ver lo más reciente."
    />

    <CrossServices excludeId="impresion-gran-formato" />

    <FAQ
      title="Preguntas frecuentes sobre impresión gran formato"
      subtitle="Las dudas que nos hacen más seguido. Si la tuya no aparece, mándanos un WhatsApp."
      items={faqs}
    />

    <QuoteForm defaultService="impresion-gran-formato" />
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  .usos {
    background: var(--color-bg-alt);
  }

  .usos-eyebrow,
  .specs-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .usos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    perspective: 1400px;
  }

  .uso-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    transform-style: preserve-3d;
    isolation: isolate;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .uso-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 22px 48px rgba(20, 10, 4, 0.10);
  }

  .uso-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle 280px at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 240, 220, 0.30) 0%,
      rgba(255, 240, 220, 0.10) 25%,
      transparent 60%);
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
    border-radius: inherit;
    z-index: 1;
  }

  .uso-card:hover::after { opacity: 1; }

  .uso-card > * { position: relative; z-index: 2; }

  @media (hover: none), (prefers-reduced-motion: reduce) {
    .uso-card { transform-style: flat; }
    .uso-card::after { display: none; }
  }

  .uso-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .uso-description {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  .uso-examples-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: -8px;
  }

  .uso-examples {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .uso-examples li {
    color: var(--color-muted);
    font-size: 0.9375rem;
    padding-left: 18px;
    position: relative;
    line-height: 1.5;
  }

  .uso-examples li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 1.5px;
    background: var(--color-accent);
  }

  /* ── Specs ──────────────────────────────────────────── */
  .specs {
    background: var(--color-bg);
  }

  .specs-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .specs-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.4vw, 2.5rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--color-text);
    margin-bottom: 24px;
  }

  .specs-description {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.75;
  }

  .specs-list {
    list-style: none;
    border-top: 1px solid var(--color-surface);
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-surface);
    align-items: baseline;
  }

  .spec-label {
    color: var(--color-muted);
    font-size: 0.875rem;
    letter-spacing: 0.02em;
  }

  .spec-value {
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.9375rem;
    text-align: right;
  }

  @media (max-width: 880px) {
    .specs-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .uso-card {
      padding: 28px 24px;
    }
  }

  /* ── Recurso relacionado ── */
  .recurso-relacionado {
    padding: 48px 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-surface);
  }

  .rr-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 14px;
  }

  .rr-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    padding: 28px 32px;
    transition: border-color 0.2s ease, background 0.2s ease;
    color: inherit;
  }

  .rr-card:hover {
    border-color: var(--color-accent);
    background: #fff;
  }

  .rr-card:hover .rr-arrow {
    transform: translateX(4px);
  }

  .rr-topic {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 8px;
  }

  .rr-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.25;
  }

  .rr-excerpt {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 640px;
  }

  .rr-arrow {
    font-size: 1.5rem;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  @media (max-width: 640px) {
    .rr-card {
      padding: 22px 20px;
    }
    .rr-arrow {
      display: none;
    }
  }
</style>

<script>
  import { initCardTilt } from "../../scripts/cardTilt";
  const init = () => initCardTilt(".uso-card[data-tilt]");
  init();
  document.addEventListener("astro:page-load", init);
</script>
