---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServicePageHero from "../../components/ServicePageHero.astro";
import ServicePdfs from "../../components/ServicePdfs.astro";
import PricingFormula from "../../components/PricingFormula.astro";
import TresDShowcase from "../../components/TresDShowcase.astro";
import TresDAssembly from "../../components/TresDAssembly.astro";
import Gallery from "../../components/Gallery.astro";
import FAQ from "../../components/FAQ.astro";
import CrossServices from "../../components/CrossServices.astro";
import QuoteForm from "../../components/QuoteForm.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppButton from "../../components/WhatsAppButton.astro";
import { getService, SITE } from "../../data/services";

const service = getService("impresion-3d");

const technologies = [
  {
    label: "FDM — plástico fundido",
    eyebrow: "Bambu Lab H2C · Línea de impresoras Bambu Lab",
    description:
      "Imprimimos con filamentos termoplásticos en máquinas Bambu Lab. La H2C imprime hasta cuatro colores en una misma pieza con una velocidad y consistencia de nivel industrial.",
    materiales: ["Gran variedad de colores"],
    usos: [
      "Prototipos funcionales",
      "Piezas mecánicas y repuestos",
    ],
  },
  {
    label: "Resina — alta definición",
    eyebrow: "Resina · MSLA / DLP",
    description:
      "La impresión por resina captura detalle a nivel de micras — superficies lisas y geometría imposible para FDM. Es nuestra herramienta para piezas pequeñas, intricadas o que necesitan un acabado premium directamente desde la máquina.",
    materiales: ["Gran variedad de colores"],
    usos: [
      "Miniaturas y figuras coleccionables",
      "Joyería y prototipos para fundición",
      "Cabezas de personajes y detalle escultórico",
      "Moldes y matrices de precisión",
    ],
  },
];

const machines = [
  {
    name: "Bambu Lab H2C",
    spec: "Volumen 256 × 256 × 256 mm · Multi-color hasta 4 filamentos",
    note: "Para piezas con detalle de color, lotes pequeños y prototipos rápidos.",
  },
  {
    name: "Formato XL",
    spec: "Volumen 300 × 300 × 400 mm",
    note: "Para piezas grandes que normalmente requerirían dividir el modelo.",
  },
  {
    name: "Impresora de resina",
    spec: "Volumen ≈ 150 × 80 × 165 mm · Resolución de fotograbado",
    note: "Para detalle fino, miniaturas y piezas con superficie lisa.",
  },
];

const serviceSchema = {
  name: service.name,
  serviceType: "3D printing",
  description: service.metaDescription,
  url: `${SITE.url}${service.slug}`,
};

const faqs = [
  {
    question: "¿Cuánto tarda imprimir una pieza?",
    answer:
      "Habitualmente menos de una semana. Cuando hay disponibilidad, una pieza pequeña puede salir el mismo día. Lotes y producciones se cotizan caso por caso.",
  },
  {
    question: "¿Qué archivo necesitan para imprimir?",
    answer:
      "Lo ideal es un STL o STEP listo para imprimir, con paredes cerradas y geometría sólida. Si solo tienes un dibujo, una foto o una idea, podemos modelarlo desde cero — el modelado 3D se cotiza por separado dependiendo de la complejidad. También aceptamos OBJ, 3MF y archivos de Fusion 360 / SolidWorks.",
  },
  {
    question: "¿Cómo elijo entre FDM y resina?",
    answer:
      "FDM (filamento) es ideal para piezas funcionales, prototipos, repuestos, soportes y piezas grandes. Es más resistente y económico. Resina es para alta definición — miniaturas, joyería, cabezas de personajes con detalle escultórico. Si no estás seguro, mándanos el archivo y te recomendamos sin compromiso.",
  },
  {
    question: "¿Cuál es el tamaño máximo que pueden imprimir?",
    answer:
      "En una sola pieza FDM imprimimos hasta 30 × 30 × 40 cm. En multi-color hasta 25.6 × 25.6 × 25.6 cm (Bambu Lab H2C). En resina hasta 15 × 8 × 16.5 cm. Para piezas más grandes, las dividimos en módulos que se ensamblan después con casi ninguna línea visible.",
  },
  {
    question: "¿Pintan o dan acabado a la pieza?",
    answer:
      "Sí. Ofrecemos lijado, primer, pintura con aerógrafo y acabados especiales (mate, satinado, brillante, metalizado). El acabado se cotiza aparte porque toma tiempo de mano de obra. Para FDM también podemos hacer alisado con vapor de acetona en piezas ABS.",
  },
  {
    question: "¿Hay cantidad mínima?",
    answer:
      "No. Imprimimos desde una sola pieza. Para producción en serie ofrecemos descuento progresivo por cantidad — entre más unidades, menor el costo por pieza.",
  },
];

const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<Base
  title={`${service.name} en Cancún | Lumo Cancún`}
  description={service.metaDescription}
  canonical={service.slug}
  ogImage="/og/impresion-3d.jpg"
  schemaType="Service"
  schemaData={serviceSchema}
  pageAccent="3d"
  extraSchemas={[faqPageSchema]}
>
  <Nav variant="solid" />
  <main>
    <Breadcrumb
      items={[
        { label: "Inicio", href: "/" },
        { label: "Servicios", href: "/#servicios" },
        { label: service.name },
      ]}
      backHref="/#servicios"
      backLabel="Regresar a servicios"
    />

    <ServicePageHero
      eyebrow="Impresión 3D profesional"
      title="Del prototipo al producto final, imprimido en Cancún"
      subtitle="Imprimimos en 3D con máquinas profesionales Bambu Lab — FDM multi-color, formato XL y resina de alta definición. Tu pieza, en el material y la técnica que mejor se ajuste al proyecto, sin enviarla fuera de la ciudad."
      primaryCta={{ label: "Solicita tu cotización", href: "#cotiza" }}
      secondaryCta={{ label: "Ver tecnologías", href: "#tecnologias" }}
      service="3d"
    >
      <TresDShowcase slot="showcase" />
    </ServicePageHero>

    <ServicePdfs service={service} />

    <TresDAssembly />

    <section class="tech section" id="tecnologias">
      <div class="container">
        <div class="section-header">
          <p class="tech-eyebrow" data-reveal>Dos tecnologías, un mismo taller</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Elegimos la técnica según la pieza
          </h2>
          <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
            FDM y resina son procesos complementarios. Te recomendamos cuál usar
            sin compromiso, evaluando geometría, tamaño, detalle y uso final.
          </p>
        </div>
        <div class="tech-grid">
          {technologies.map((t, i) => (
            <article class="tech-card" data-tilt data-reveal data-reveal-delay={`${0.04 + i * 0.08}`}>
              <p class="tech-card-eyebrow">{t.eyebrow}</p>
              <h3 class="tech-card-name">{t.label}</h3>
              <p class="tech-card-description">{t.description}</p>
              <div class="tech-card-section">
                <p class="tech-card-section-label">Materiales</p>
                <ul class="tech-card-tags" role="list">
                  {t.materiales.map((m) => <li class="tech-card-tag">{m}</li>)}
                </ul>
              </div>
              <div class="tech-card-section">
                <p class="tech-card-section-label">Usos típicos</p>
                <ul class="tech-card-list" role="list">
                  {t.usos.map((u) => <li>{u}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="machines section" id="maquinas">
      <div class="container">
        <div class="section-header">
          <p class="machines-eyebrow" data-reveal>Equipo del taller</p>
          <h2 class="section-title" data-reveal data-reveal-delay="0.06">
            Tamaños y características
          </h2>
          <p class="section-subtitle" data-reveal data-reveal-delay="0.12">
            Máquinas trabajando en paralelo. Esto se traduce en tiempos
            de entrega cortos, capacidad para piezas grandes y la flexibilidad
            de dividir lotes complejos sin renegociar plazos.
          </p>
        </div>
        <ul class="machines-grid" role="list">
          {machines.map((m, i) => (
            <li class="machine-card" data-reveal data-reveal-delay={`${0.04 + i * 0.06}`}>
              <h3 class="machine-name">{m.name}</h3>
              <p class="machine-spec">{m.spec}</p>
              <p class="machine-note">{m.note}</p>
            </li>
          ))}
        </ul>
        <p class="lead-time" data-reveal>
          <strong>Tiempos de entrega:</strong> habitualmente menos de una semana;
          cuando hay disponibilidad, el mismo día. Pedidos urgentes se cotizan en el momento.
        </p>
      </div>
    </section>

    <PricingFormula serviceId="impresion-3d" />

    <Gallery
      filterService="impresion-3d"
      title="Trabajos de impresión 3D"
      subtitle="Estamos documentando los proyectos del taller. Mientras tanto, sigue nuestro Instagram para ver lo más reciente."
    />

    <CrossServices excludeId="impresion-3d" />

    <section class="recurso-relacionado">
      <div class="container">
        <p class="rr-eyebrow">Lectura recomendada</p>
        <a class="rr-card" href="/recursos/fdm-vs-resina">
          <div class="rr-text">
            <p class="rr-topic">Impresión 3D</p>
            <h3 class="rr-title">FDM vs resina: cuál impresión 3D elegir para tu proyecto</h3>
            <p class="rr-excerpt">Comparativa técnica: precisión (0.025–0.05 mm resina vs 0.12–0.28 mm FDM), costo, tamaño máximo y casos de uso reales.</p>
          </div>
          <span class="rr-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <FAQ
      title="Preguntas frecuentes sobre impresión 3D"
      subtitle="Las dudas que nos hacen más seguido. Si la tuya no aparece, mándanos un WhatsApp."
      items={faqs}
    />

    <QuoteForm defaultService="impresion-3d" />
  </main>
  <div class="page-end">
    <Contact />
    <Footer />
  </div>
  <WhatsAppButton />
</Base>

<style>
  .tech {
    background: var(--color-bg-alt);
  }

  .tech-eyebrow,
  .machines-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 16px;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 24px;
    perspective: 1400px;
  }

  .tech-card {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    transform-style: preserve-3d;
    isolation: isolate;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .tech-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 22px 48px rgba(20, 10, 4, 0.10);
  }

  .tech-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle 280px at var(--gx, 50%) var(--gy, 50%),
      rgba(255, 240, 220, 0.30) 0%,
      rgba(255, 240, 220, 0.10) 25%,
      transparent 60%);
    opacity: 0;
    mix-blend-mode: screen;
    transition: opacity 0.3s ease;
    border-radius: inherit;
    z-index: 1;
  }

  .tech-card:hover::after { opacity: 1; }

  .tech-card > * { position: relative; z-index: 2; }

  @media (hover: none), (prefers-reduced-motion: reduce) {
    .tech-card { transform-style: flat; }
    .tech-card::after { display: none; }
  }

  .tech-card-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .tech-card-name {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: -12px;
  }

  .tech-card-description {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .tech-card-section-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .tech-card-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tech-card-tag {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-surface);
    color: var(--color-text);
    font-size: 0.8125rem;
    padding: 6px 12px;
    border-radius: 4px;
  }

  .tech-card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tech-card-list li {
    color: var(--color-muted);
    font-size: 0.9375rem;
    padding-left: 18px;
    position: relative;
  }

  .tech-card-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 10px;
    width: 8px;
    height: 1.5px;
    background: var(--color-accent);
  }

  /* ── Machines ──────────────────────────────────────── */
  .machines {
    background: var(--color-bg);
  }

  .machines-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 32px;
  }

  .machine-card {
    background: var(--color-bg);
    padding: 32px 28px;
  }

  .machine-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .machine-spec {
    color: var(--color-accent);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: 12px;
  }

  .machine-note {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .lead-time {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.7;
    border-left: 3px solid var(--color-accent);
    padding-left: 20px;
  }

  .lead-time strong {
    color: var(--color-text);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .tech-card {
      padding: 32px 28px;
    }

    .machine-card {
      padding: 28px 24px;
    }
  }

  /* ── Recurso relacionado ── */
  .recurso-relacionado {
    padding: 48px 0;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-surface);
  }

  .rr-eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 14px;
  }

  .rr-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-surface);
    border-radius: 8px;
    padding: 28px 32px;
    transition: border-color 0.2s ease, background 0.2s ease;
    color: inherit;
  }

  .rr-card:hover {
    border-color: var(--color-accent);
    background: #fff;
  }

  .rr-card:hover .rr-arrow {
    transform: translateX(4px);
  }

  .rr-topic {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 8px;
  }

  .rr-title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 10px;
    line-height: 1.25;
  }

  .rr-excerpt {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 640px;
  }

  .rr-arrow {
    font-size: 1.5rem;
    color: var(--color-accent);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  @media (max-width: 640px) {
    .rr-card {
      padding: 22px 20px;
    }
    .rr-arrow {
      display: none;
    }
  }
</style>

<script>
  import { initCardTilt } from "../../scripts/cardTilt";
  const init = () => initCardTilt(".tech-card[data-tilt]");
  init();
  document.addEventListener("astro:page-load", init);
</script>
